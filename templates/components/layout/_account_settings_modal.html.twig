<div data-controller="modal" data-modal-event-name-value="modal:open-account-settings">
    {# Modal backdrop/dialog #}
    <div data-modal-target="dialog" 
         class="hidden fixed inset-0 bg-black/75 backdrop-blur-sm z-50 flex items-center justify-center p-4" 
         data-action="click->modal#closeBackdrop">
         
         <div class="bg-gray-900 border border-gray-800 rounded-2xl w-full max-w-lg p-6 relative shadow-2xl flex flex-col max-h-[90vh]">
              {# Close button #}
              <button type="button"
                      data-action="click->modal#close"
                      class="modal-close"
                      aria-label="{{ 'modal.close'|trans }}">
                  <span aria-hidden="true" class="text-xl leading-none">✕</span>
                  <span class="sr-only">{{ 'modal.close'|trans }}</span>
              </button>

              {# Title #}
              <h2 class="text-xl font-bold text-white mb-4 border-b border-gray-800 pb-3 flex items-center gap-2">
                  <span>⚙️</span> {{ 'settings.title'|trans }}
              </h2>

              <div class="space-y-6 overflow-y-auto pr-1 flex-1">
                  {# 1. Language Selector #}
                  <div class="space-y-2">
                      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">{{ 'settings.language'|trans }}</h3>
                      <div class="grid grid-cols-2 gap-2">
                          <a href="{{ path('app_change_locale', { locale: 'cs' }) }}" 
                             class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl border transition-all text-sm {{ app.request.locale == 'cs' ? 'border-emerald-500 bg-emerald-500/10 text-emerald-400 font-bold' : 'border-gray-800 bg-gray-950/40 text-gray-400 hover:bg-gray-800 hover:text-gray-200' }}">
                              Čeština (CS)
                          </a>
                          <a href="{{ path('app_change_locale', { locale: 'en' }) }}" 
                             class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl border transition-all text-sm {{ app.request.locale == 'en' ? 'border-emerald-500 bg-emerald-500/10 text-emerald-400 font-bold' : 'border-gray-800 bg-gray-950/40 text-gray-400 hover:bg-gray-800 hover:text-gray-200' }}">
                              English (EN)
                          </a>
                      </div>
                  </div>

                  <hr class="border-gray-800" />

                  {# 2. Email Change (with AJAX) #}
                  <div data-controller="account-settings" class="space-y-4">
                      {# Email Form #}
                      <form data-action="submit->account-settings#changeEmail" class="space-y-3">
                          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">{{ 'settings.email.title'|trans }}</h3>
                          
                          <div class="flex flex-col gap-1.5">
                              <label for="account_new_email" class="text-xs text-gray-400 font-medium">{{ 'settings.email.label'|trans }}</label>
                              <div class="flex gap-2">
                                  <input type="email" id="account_new_email" data-account-settings-target="emailInput" required
                                         placeholder="{{ app.user.email }}"
                                         class="flex-1 rounded-lg bg-gray-950 border border-gray-800 px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-emerald-500">
                                  <button type="submit" data-account-settings-target="emailSubmitBtn" 
                                          class="bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-bold px-4 py-2 rounded-lg text-xs transition-colors cursor-pointer">
                                      {{ 'settings.email.submit'|trans }}
                                  </button>
                              </div>
                          </div>

                          {# Inline Alerts #}
                          <div data-account-settings-target="emailError" class="hidden text-xs text-red-400 bg-red-950/20 border border-red-900/50 rounded-lg p-2.5"></div>
                          <div data-account-settings-target="emailSuccess" class="hidden text-xs text-green-400 bg-green-950/20 border border-green-900/50 rounded-lg p-2.5"></div>
                      </form>

                      <hr class="border-gray-800" />

                      {# 3. Cancel Account #}
                      <div class="space-y-3">
                          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider text-red-400">{{ 'settings.delete.title'|trans }}</h3>
                          <p class="text-xs text-gray-500">{{ 'settings.delete.warning'|trans }}</p>

                          {# Trigger Button #}
                          <button data-action="click->account-settings#showCancelConfirm" 
                                  class="w-full bg-red-950/20 hover:bg-red-950/40 text-red-400 border border-red-900/40 hover:border-red-900 font-semibold py-2 px-4 rounded-lg text-xs transition-all cursor-pointer">
                              {{ 'settings.delete.btn'|trans }}
                          </button>

                          {# Confirmation Prompt Panel #}
                          <div data-account-settings-target="cancelConfirmPanel" class="hidden bg-gray-950/80 border border-red-900/30 rounded-xl p-4 space-y-3 transition-all">
                              <p class="text-xs text-red-300 font-medium">{{ 'settings.delete.confirm_msg'|trans }}</p>
                              <div class="flex gap-2">
                                  <button data-action="click->account-settings#submitCancelAccount" data-account-settings-target="cancelSubmitBtn"
                                          class="flex-1 bg-red-600 hover:bg-red-500 text-white font-bold py-1.5 px-3 rounded text-xs cursor-pointer transition-colors">
                                      {{ 'settings.delete.confirm_yes'|trans }}
                                  </button>
                                  <button data-action="click->account-settings#hideCancelConfirm"
                                          class="flex-1 bg-gray-800 hover:bg-gray-750 text-gray-300 font-bold py-1.5 px-3 rounded text-xs cursor-pointer transition-colors">
                                      {{ 'settings.delete.confirm_no'|trans }}
                                  </button>
                              </div>
                          </div>

                          {# Inline Alerts #}
                          <div data-account-settings-target="cancelError" class="hidden text-xs text-red-400 bg-red-950/20 border border-red-900/50 rounded-lg p-2.5"></div>
                          <div data-account-settings-target="cancelSuccess" class="hidden text-xs text-green-400 bg-green-950/20 border border-green-900/50 rounded-lg p-2.5"></div>
                      </div>
                  </div>
              </div>
         </div>
    </div>
</div>
