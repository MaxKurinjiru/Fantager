{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'training.title'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="space-y-8 max-w-7xl mx-auto" data-controller="training"
     data-training-success-queue-value="{{ 'js_flash.training.success_queue'|trans }}"
     data-training-success-cancel-value="{{ 'js_flash.training.success_cancel'|trans }}"
     data-training-error-fetch-value="{{ 'js_flash.training.error_fetch'|trans }}"
     data-training-error-queue-value="{{ 'js_flash.training.error_queue'|trans }}"
     data-training-error-cancel-value="{{ 'js_flash.training.error_cancel'|trans }}"
     data-training-text-queueing-value="{{ 'js_flash.training.text_queueing'|trans }}"
     data-training-text-cancelling-value="{{ 'js_flash.training.text_cancelling'|trans }}"
     data-training-text-processing-value="{{ 'js_flash.training.text_processing'|trans }}"
>
    
    {# --- Header Section --- #}
    {% set right_content %}
        <div class="bg-gray-900/60 border border-gray-800 rounded-xl px-4 py-3 backdrop-blur-md text-sm shrink-0 flex items-center gap-3">
            <div>
                <span class="block text-[10px] text-gray-555 uppercase font-bold tracking-wider">{{ 'training.scheduled_ticks'|trans }}</span>
                <span class="text-white font-extrabold">{{ 'training.ticks_schedule'|trans }}</span>
            </div>
        </div>
    {% endset %}

    {% include 'components/ui/page_header.html.twig' with {
        title: 'training.title',
        subtitle: 'training.subtitle',
        right_content: right_content
    } %}

    {# --- Alert Box --- #}
    {% include 'components/ui/alert_box.html.twig' with {
        target: 'training',
        message_target: 'alertMessage',
        close_action: 'training#hideAlert'
    } %}

    {# --- Multi-Tab Navigation — controlled by tab_controller.js §9.2 --- #}
    <div class="flex border-b border-gray-850 gap-2 overflow-x-auto pb-px" data-controller="tab">
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="attributes-tab"
                class="tab-btn tab-btn--active">
            💪 {{ 'training.tab_attrs'|trans }}
        </button>
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="magic-tab"
                class="tab-btn">
            🔮 {{ 'training.tab_magic'|trans }}
        </button>
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="recovery-tab"
                class="tab-btn">
            🛌 {{ 'training.tab_recovery'|trans }}
        </button>
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="queue-tab"
                class="tab-btn flex items-center gap-2">
            📋 {{ 'training.tab_queue'|trans }}
            <span class="text-[10px] bg-gray-800 text-gray-400 px-2 py-0.5 rounded-full font-bold border border-gray-700">{{ queue|length }}</span>
        </button>
    </div>

    {# --- Hero & Trainer Selection Configuration --- #}
    {% include 'components/training/config_panel.html.twig' with { heroes: heroes, trainers: trainers } %}

    {# ========================================== #}
    {# TAB 1: ATTRIBUTES TRAINING                 #}
    {# ========================================== #}
    {% include 'components/training/attributes_tab.html.twig' %}

    {# ========================================== #}
    {# TAB 2: MAGIC CAPACITY                      #}
    {# ========================================== #}
    {% include 'components/training/magic_tab.html.twig' %}

    {# ========================================== #}
    {# TAB 3: RECOVERY & REST                     #}
    {# ========================================== #}
    {% include 'components/training/recovery_tab.html.twig' %}

    {# ========================================== #}
    {# TAB 4: ACTIVE QUEUE                        #}
    {# ========================================== #}
    {% include 'components/training/queue_tab.html.twig' with { queue: queue } %}

</div>

{% endblock %}
