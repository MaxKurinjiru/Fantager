{# templates/components/hero/recent_activity.html.twig #}
<div class="hero-panel space-y-6">
    <div>
        <h2 class="hero-panel__title hero-panel__title--tight">{{ 'heroes.recent_activity'|trans }}</h2>
        <p class="hero-panel__desc">{{ 'heroes.recent_activity_desc'|trans }}</p>
    </div>

    <div class="space-y-3 max-h-[175px] overflow-y-auto pr-1">
        {% if summonRecord %}
            <div class="hero-activity-item">
                <div>
                    <div class="hero-activity-item__title">🌀 {{ 'heroes.summoned'|trans }}</div>
                    <div class="hero-activity-item__time">{{ summonRecord.summonedAt|date('Y-m-d H:i') }}</div>
                </div>
                <div class="text-right shrink-0">
                    <span class="text-[10px] font-bold text-indigo-400 bg-indigo-950/40 px-2 py-0.5 rounded border border-indigo-900/30">
                        {{ ('heroes.race_' ~ summonRecord.raceSelected.value)|trans }}
                    </span>
                </div>
            </div>
        {% endif %}
        {% for log in trainingHistory %}
            <div class="hero-activity-item">
                <div>
                    <div class="hero-activity-item__title">
                        {% if log.trainingType.value == 'attribute' %}
                            💪 {{ 'training.type_attribute'|trans }}: {{ ('training.attr.' ~ log.targetAttribute)|trans }}
                        {% elseif log.trainingType.value == 'magic' %}
                            🔮 {{ 'training.type_magic'|trans }}
                        {% else %}
                            🛌 {{ 'training.type_form'|trans }}
                        {% endif %}
                    </div>
                    <div class="hero-activity-item__time">{{ log.completedAt ? log.completedAt|date('Y-m-d H:i') : log.executeAt|date('Y-m-d H:i') }}</div>
                </div>
                <div class="text-right shrink-0">
                    {% if log.status.value == 'completed' %}
                        <span class="text-[10px] font-bold text-green-400 bg-green-950/40 px-2 py-0.5 rounded border border-green-900/30">
                            {% if log.statGain is not null and log.statGain > 0 %}
                                +{{ (log.statGain / 10)|number_format(1) }}
                            {% else %}
                                {{ 'training.status.completed'|trans }}
                            {% endif %}
                        </span>
                    {% elseif log.status.value == 'pending' %}
                        <span class="text-[10px] font-bold text-amber-400 bg-amber-950/40 px-2 py-0.5 rounded border border-amber-900/30">{{ 'training.status.pending'|trans }}</span>
                    {% elseif log.status.value == 'in_progress' %}
                        <span class="text-[10px] font-bold text-indigo-400 bg-indigo-950/40 px-2 py-0.5 rounded border border-indigo-900/30">{{ 'training.status.in_progress'|trans }}</span>
                    {% else %}
                        <span class="status-tag status-tag--cancelled">{{ 'training.status.cancelled'|trans }}</span>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="hero-activity-empty">
                <span class="text-2xl block mb-1">💤</span>
                <span class="hero-panel__desc">{{ 'heroes.no_activity'|trans }}</span>
            </div>
        {% endfor %}
    </div>
</div>
