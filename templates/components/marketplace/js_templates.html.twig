{# My Listings Row Template #}
<template id="template-listing-row">
    <tr class="border-b border-gray-800 text-sm text-gray-300 hover:bg-gray-950/40 transition">
        <td class="py-3.5 px-4 font-bold text-white js-name"></td>
        <td class="py-3.5 px-4 js-type-mode"></td>
        <td class="py-3.5 px-4 font-semibold js-price"></td>
        <td class="py-3.5 px-4 font-semibold text-amber-500 js-highest-bid"></td>
        <td class="py-3.5 px-4 text-xs font-semibold text-red-400 js-expires"></td>
        <td class="py-3.5 px-4">
            <span class="js-status"></span>
        </td>
        <td class="py-3.5 px-4 text-right js-action"></td>
    </tr>
</template>

{# History Row Template #}
<template id="template-history-row">
    <tr class="border-b border-gray-800 text-sm text-gray-300 hover:bg-gray-950/40 transition">
        <td class="py-3.5 px-4 font-mono text-gray-400 js-id"></td>
        <td class="py-3.5 px-4 font-bold text-white">
            <span class="js-name"></span>
            <span class="text-xs text-gray-400 block font-normal js-category"></span>
        </td>
        <td class="py-3.5 px-4 js-seller"></td>
        <td class="py-3.5 px-4 js-buyer"></td>
        <td class="py-3.5 px-4 font-bold text-emerald-400 js-amount"></td>
        <td class="py-3.5 px-4 text-red-400 js-fee"></td>
        <td class="py-3.5 px-4 text-xs font-semibold text-gray-400 js-date"></td>
    </tr>
</template>

{# Loading Grid Template #}
<template id="template-loading-grid">
    <div class="col-span-3 flex justify-center py-12">
        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-emerald-500"></div>
    </div>
</template>

{# Empty Grid Template #}
<template id="template-empty-grid">
    <div class="col-span-3 text-center text-gray-500 py-12 js-empty-text"></div>
</template>

{# Error Grid Template #}
<template id="template-error-grid">
    <div class="col-span-3 text-center text-red-500 py-8 js-error-text"></div>
</template>

{# Loading Row Template #}
<template id="template-loading-row">
    <tr>
        <td colspan="7" class="text-center py-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-500 mx-auto"></div>
        </td>
    </tr>
</template>

{# Empty Row Template #}
<template id="template-empty-row">
    <tr>
        <td colspan="7" class="text-center text-gray-500 py-8 js-empty-text"></td>
    </tr>
</template>

{# Error Row Template #}
<template id="template-error-row">
    <tr>
        <td colspan="7" class="text-center text-red-500 py-8 js-error-text"></td>
    </tr>
</template>

{# Bid Form Template #}
<template id="template-bid-form">
    <div class="flex items-center space-x-2 w-full mt-2 border-t border-gray-800 pt-3">
        <input type="number" class="form-input text-center w-24 js-bid-input">
        <button type="button" class="btn btn-outline whitespace-nowrap js-bid-btn"></button>
    </div>
</template>

{# Cancel Button Template #}
<template id="template-cancel-btn">
    <button type="button" class="btn btn-danger btn--sm js-cancel-btn"></button>
</template>

{# Active Auction Span Template #}
<template id="template-active-auction-span">
    <span class="text-[10px] text-gray-550 font-medium js-active-span"></span>
</template>
