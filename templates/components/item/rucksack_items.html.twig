{# templates/components/item/rucksack_items.html.twig #}
<div class="inventory-rucksack">
    <h2 class="hero-panel__title">{{ 'inventory.rucksack'|trans }}</h2>

    <div class="item-cards-grid">
        {% for item in items %}
            {% set is_equipped = item.equippedHero is not null %}
            {% set is_equipped_on_selected = selected_hero and is_equipped and item.equippedHero.id == selected_hero.id %}

            <div class="item-card">
                <div class="layout-stack layout-stack--sm">
                    {# Item Header #}
                    <div class="item-card__header">
                        <div class="layout-cluster">
                            <span class="emoji-icon emoji-icon--lg">
                                {% if item.slotType.value == 'main_hand' or item.slotType.value == 'weapon' %}🗡️
                                {% elseif item.slotType.value == 'head' %}🪖
                                {% elseif item.slotType.value == 'body' %}🛡️
                                {% elseif item.slotType.value == 'ring' %}💍
                                {% else %}🎒{% endif %}
                            </span>
                            <div>
                                <h3 class="item-card__title">{{ item.name }}</h3>
                                <span class="item-card__rarity-line rarity-tag rarity-tag--{{ item.rarity.value }}">
                                    {{ ('inventory.rarity_' ~ item.rarity.value)|trans }} &bull; {{ ('inventory.slot_' ~ item.slotType.value)|trans }}
                                </span>
                            </div>
                        </div>
                        
                        <span class="item-durability-badge">
                            {{ 'inventory.durability'|trans }}: {{ item.durability }}%
                        </span>
                    </div>

                    {# Stats / Bonuses #}
                    <div class="item-bonus-panel">
                        {% for stat, bonus in item.bonuses %}
                            <span class="item-bonus-tag">
                                {{ stat|upper }}: <strong class="item-bonus-tag__value">+{{ bonus }}</strong>
                            </span>
                        {% else %}
                            <span class="item-bonus-empty">{{ 'inventory.no_bonuses'|trans }}</span>
                        {% endfor %}
                    </div>
                </div>

                {# Actions panel #}
                <div class="panel-divider panel-divider-row">
                    {# Equipped Badge / State #}
                    <div class="item-card__footer-meta">
                        {% if is_equipped %}
                            {{ 'inventory.equipped_by'|trans({'%hero%': '<span class="item-card__equipped-name">' ~ item.equippedHero.name ~ '</span>'})|raw }}
                        {% else %}
                            <span class="item-available-label">{{ 'inventory.available'|trans }}</span>
                        {% endif %}
                    </div>

                    {# Dynamic Swap/Equip Buttons #}
                    <div class="item-card__actions">
                        {# Repair option if durability < 100 #}
                        {% if item.durability < 100 %}
                            <button type="button" data-action="click->equipment#repair" data-item-id="{{ item.id }}"
                                    class="btn btn-outline-warning btn--sm btn--compact">
                                {{ 'inventory.repair'|trans }}
                            </button>
                        {% endif %}

                        {# Dismantle option if NOT equipped #}
                        {% if not is_equipped %}
                            <button type="button" data-action="click->equipment#dismantle" data-item-id="{{ item.id }}"
                                    class="btn btn-outline-danger btn--sm btn--compact">
                                {{ 'inventory.dismantle'|trans }}
                            </button>
                        {% endif %}

                        {# Equip to selected hero if selected, matches slot type, and NOT already equipped there #}
                        {% if selected_hero and not is_equipped %}
                            <button type="button" data-action="click->equipment#equip" data-item-id="{{ item.id }}" data-slot="{{ item.slotType.value }}"
                                    class="btn btn-primary btn--sm btn--compact">
                                {{ 'inventory.equip_slot_btn'|trans }}
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="item-empty-state">
                <span class="emoji-icon emoji-icon--xl item-empty-state__icon">📭</span>
                <h4 class="item-empty-state__title">{{ 'inventory.rucksack_empty'|trans }}</h4>
                <p class="hero-panel__desc">{{ 'inventory.rucksack_empty_desc'|trans }}</p>
            </div>
        {% endfor %}
    </div>
</div>
