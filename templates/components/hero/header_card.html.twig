{# templates/components/hero/header_card.html.twig #}
<div class="hero-panel">
    <div class="panel-accent-glow panel-accent-glow--lg"></div>

    <div class="hero-header__layout">
        {% include 'components/hero/avatar.html.twig' with { race: hero.race, style: 'box', size_class: 'hero-avatar-box--header' } %}

        <div class="hero-header__body">
            <div class="hero-header__title-row">
                <div class="hero-header__rename-group group">
                    <h1 data-hero-rename-target="nameDisplay" class="hero-header__title">
                        {{ hero.name }}
                    </h1>
                    <label for="hero-rename-input" class="sr-only">{{ 'heroes.rename_title'|trans }}</label>
                    <input type="text" id="hero-rename-input" data-hero-rename-target="nameInput" data-action="keydown.enter->hero-rename#save keydown.esc->hero-rename#cancel"
                           class="form-input form-input--rename hidden">

                    <button type="button" data-hero-rename-target="editBtn" data-action="click->hero-rename#edit"
                            class="hero-header__rename-btn"
                            title="{{ 'heroes.rename_title'|trans }}"
                            aria-label="{{ 'heroes.rename_title'|trans }}">
                        ✏️
                    </button>

                    <div data-hero-rename-target="actions" class="hero-header__rename-actions hidden">
                        <button type="button" data-action="click->hero-rename#save" class="btn btn-primary btn--sm">{{ 'heroes.save'|trans }}</button>
                        <button type="button" data-action="click->hero-rename#cancel" class="btn btn-outline btn--sm">{{ 'heroes.cancel'|trans }}</button>
                    </div>
                </div>

                {% include 'components/hero/status_badge.html.twig' with { status: hero.status, rounded_full: true } %}
            </div>

            <div class="hero-header__meta">
                <span class="hero-header__meta-item">
                    <span class="emoji-icon emoji-icon--sm">🧬</span>
                    {{ 'heroes.race'|trans }}: <strong class="hero-header__meta-strong">{{ ('heroes.race_' ~ hero.race.value)|trans }}</strong>
                </span>
                <span class="hero-header__divider"></span>
                <span class="hero-header__meta-item">
                    <span class="emoji-icon emoji-icon--sm">{{ hero_age_phase_icon(hero) }}</span>
                    {{ 'heroes.age'|trans }}: <strong class="hero-header__meta-strong">{{ hero.age }} {{ 'heroes.years'|trans }}</strong>
                    <span class="hero-header__phase-badge">
                        {{ ('heroes.age_phase.' ~ hero_age_phase(hero)|lower)|trans }}
                    </span>
                    {% if hero_at_mortality_threshold(hero) %}
                        <span class="hero-header__mortality-warning" title="{{ 'heroes.mortality_threshold_warning'|trans({'%threshold%': hero_mortality_threshold(hero)}) }}">
                            ⚠️
                        </span>
                    {% endif %}
                </span>
                <span class="hero-header__divider"></span>
                <span class="hero-header__meta-item">
                    <span class="emoji-icon emoji-icon--sm">🔥</span>
                    {{ 'heroes.level'|trans }}: <strong class="hero-header__meta-strong">{{ hero.level }}</strong>
                </span>
                <span class="hero-header__divider"></span>
                <span class="hero-header__meta-item">
                    {% include 'components/hero/rating_badge.html.twig' with { hero: hero, show_complex: true, layout: 'inline' } %}
                </span>
                {% if hero.trait %}
                    <span class="hero-header__divider"></span>
                    <span class="hero-header__meta-item">
                        {% include 'components/hero/trait_badge.html.twig' with { trait: hero.trait } %}
                    </span>
                {% endif %}
            </div>

            <div class="hero-header__xp-track">
                <div class="hero-header__xp-labels">
                    <span>{{ 'heroes.xp'|trans }}</span>
                    {% set next_level_xp = 1000 * hero.level %}
                    <span>{{ hero.xp }} / {{ next_level_xp }} XP</span>
                </div>
                {% set xp_pct = min(100, (hero.xp / next_level_xp) * 100) %}
                {% include 'components/ui/progress_bar.html.twig' with {
                    percentage: xp_pct,
                    container_class: 'ui-progress ui-progress--xp',
                    progress_class: 'ui-progress__fill ui-progress__fill--xp'
                } %}
            </div>
        </div>
    </div>
</div>
