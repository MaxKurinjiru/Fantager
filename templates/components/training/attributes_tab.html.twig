{# templates/components/training/attributes_tab.html.twig #}
<div id="attributes-tab" class="tab-content space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {% set attributes = [
            {key: 'str', name: 'training.attr.str'|trans, icon: '🏋️', desc: 'training.attr.str_desc'|trans},
            {key: 'dex', name: 'training.attr.dex'|trans, icon: '🎯', desc: 'training.attr.dex_desc'|trans},
            {key: 'kon', name: 'training.attr.kon'|trans, icon: '🛡️', desc: 'training.attr.kon_desc'|trans},
            {key: 'spd', name: 'training.attr.spd'|trans, icon: '⚡', desc: 'training.attr.spd_desc'|trans},
            {key: 'int', name: 'training.attr.int'|trans, icon: '🧠', desc: 'training.attr.int_desc'|trans},
            {key: 'wil', name: 'training.attr.wil'|trans, icon: '🔮', desc: 'training.attr.wil_desc'|trans},
            {key: 'cha', name: 'training.attr.cha'|trans, icon: '👑', desc: 'training.attr.cha_desc'|trans},
            {key: 'lck', name: 'training.attr.lck'|trans, icon: '🎲', desc: 'training.attr.lck_desc'|trans}
        ] %}

        {% for attr in attributes %}
            <div data-attribute-card="{{ attr.key }}" 
                 class="bg-gray-900/40 border border-gray-800 rounded-2xl p-5 flex flex-col justify-between backdrop-blur-md shadow-md min-h-[175px]">
                <div class="space-y-3">
                    <div class="flex items-center gap-2.5">
                        <span class="text-3xl select-none">{{ attr.icon }}</span>
                        <h3 class="font-extrabold text-white leading-tight">{{ attr.name }}</h3>
                    </div>
                    <p class="text-[10px] text-gray-500">{{ attr.desc }}</p>
                </div>

                <div class="border-t border-gray-850 mt-4 pt-4 flex flex-col gap-2">
                    <span data-cost-text class="text-xs font-bold text-gray-500">{{ 'training.cost_select_hero'|trans }}</span>
                    <button type="button" data-training-btn data-action="click->training#startAttributeTraining" data-attribute="{{ attr.key }}" disabled
                            class="btn btn-outline btn--sm w-full py-2 font-bold uppercase tracking-wider text-[10px] disabled:opacity-40 disabled:cursor-not-allowed">
                        {{ 'training.queue_training'|trans }}
                    </button>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
