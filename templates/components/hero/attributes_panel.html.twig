{# templates/components/hero/attributes_panel.html.twig #}
<div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 backdrop-blur-md shadow-lg space-y-6">
    <div>
        <h2 class="text-xl font-bold text-white mb-1">{{ 'heroes.primary_attrs'|trans }}</h2>
        <p class="text-xs text-gray-500">{{ 'heroes.primary_attrs_desc'|trans }}</p>
    </div>

    <div class="space-y-4">
        {% set attr_keys = ['str', 'dex', 'kon', 'spd', 'int', 'wil', 'cha', 'lck'] %}

        {% for attr_key in attr_keys %}
            {% set val = attribute(hero, attr_key == 'int' ? 'intel' : attr_key) %}
            {% set bonus = statBonuses[attr_key] ?? 0 %}
            {% include 'components/hero/attribute_bar.html.twig' with {
                label: ('training.attr.' ~ attr_key)|trans,
                val: val,
                bonus: bonus,
                max_val: 20
            } %}
        {% endfor %}
    </div>
</div>
