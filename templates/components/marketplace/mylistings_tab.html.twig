{# templates/components/marketplace/mylistings_tab.html.twig #}
<div data-marketplace-target="tabContent" data-tab-name="mylistings" class="layout-stack{% if tab|default('browse') != 'mylistings' %} hidden{% endif %}">
    <div class="game-panel game-panel--scroll">
        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'marketplace.col_entity'|trans }}</th>
                    <th>{{ 'marketplace.col_type_mode'|trans }}</th>
                    <th>{{ 'marketplace.col_base_price'|trans }}</th>
                    <th>{{ 'marketplace.label_highest_bid'|trans }}</th>
                    <th>{{ 'marketplace.label_expires'|trans }}</th>
                    <th>{{ 'marketplace.col_status'|trans }}</th>
                    <th class="data-table__col--end">{{ 'marketplace.col_actions'|trans }}</th>
                </tr>
            </thead>
            <tbody data-marketplace-target="myListingsContainer">
                {# AJAX Loaded list #}
                <tr>
                    <td colspan="7" class="data-table__col--center">
                        <div class="loading-spinner loading-spinner--table"><div class="loading-spinner__icon loading-spinner__icon--sm" aria-hidden="true"></div></div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <nav class="news-pagination hidden" data-marketplace-target="myListingsPagination">
        <button type="button" data-action="click->marketplace#myListingsPrevPage" data-marketplace-target="myListingsPrevBtn" class="btn btn-outline btn--sm">{{ 'news.prev_page'|trans }}</button>
        <span class="news-pagination__info" data-marketplace-target="myListingsPageInfo"></span>
        <button type="button" data-action="click->marketplace#myListingsNextPage" data-marketplace-target="myListingsNextBtn" class="btn btn-outline btn--sm">{{ 'news.next_page'|trans }}</button>
    </nav>
</div>
