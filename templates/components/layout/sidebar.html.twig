{% set route = route|default(app.request.attributes.get('_route') ?? '') %}
<aside data-mobile-menu-target="menu" class="game-sidebar mobile-menu">
    <div class="game-sidebar__nav">
        {# Mobile Header & Close Button #}
        <div class="game-sidebar__mobile-header">
            <span class="game-sidebar__brand">Fantager</span>
            <button type="button" data-action="click->mobile-menu#close" class="game-sidebar__close-btn" aria-label="{{ 'modal.close'|trans }}">
                <svg class="game-sidebar__close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        {# Active Navigation Links #}
        {% set nav_links = [
            { route: 'app_dashboard', emoji: '📊', label: 'nav.dashboard', active_check: 'exact' },
            { route: 'app_heroes', emoji: '👥', label: 'nav.heroes', active_check: 'starts_with' },
            { route: 'app_summon', emoji: '🌀', label: 'nav.summon', active_check: 'exact' },
            { route: 'app_hq', emoji: '🏰', label: 'nav.hq', active_check: 'exact' },
            { route: 'app_training', emoji: '🏋️', label: 'nav.training', active_check: 'exact' },
            { route: 'app_inventory', emoji: '🎒', label: 'nav.inventory', active_check: 'exact' },
            { route: 'app_spells', emoji: '📖', label: 'nav.spells', active_check: 'exact' },
            { route: 'app_formation', emoji: '🛡️', label: 'nav.formation', active_check: 'exact' },
            { route: 'app_league', emoji: '🏆', label: 'nav.league', active_check: 'exact' },
            { route: 'app_calendar', emoji: '📅', label: 'nav.calendar', active_check: 'exact' },
            { route: 'app_arena', emoji: '🏟️', label: 'nav.arena', active_check: 'exact' },
            { route: 'app_finance', emoji: '🪙', label: 'finance.title', active_check: 'exact' },
            { route: 'app_marketplace', emoji: '⚖️', label: 'nav.marketplace', active_check: 'exact' },
            { route: 'app_community', emoji: '💬', label: 'nav.community', active_check: 'starts_with' }
        ] %}

        {% for link in nav_links %}
            {% set is_active = (link.active_check == 'exact' and route == link.route) or (link.active_check == 'starts_with' and route starts with link.route) %}
            {% include 'components/layout/sidebar_link.html.twig' with {
                route: link.route,
                emoji: link.emoji,
                label: link.label,
                is_active: is_active
            } %}
        {% endfor %}

        <div class="game-sidebar__divider"></div>

        {# Future phases placeholders #}
        <div class="game-sidebar__section-label">{{ 'sidebar.future_content'|trans }}</div>
        
        {% set locked_links = [
            { emoji: '🪦', label: 'nav.graveyard' }
        ] %}

        {% for link in locked_links %}
            {% include 'components/layout/sidebar_locked_link.html.twig' with {
                emoji: link.emoji,
                label: link.label
            } %}
        {% endfor %}
    </div>
</aside>
