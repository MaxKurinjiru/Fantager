{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'league.title'|trans }} | Fantager{% endblock %}

{% block body %}
<div class="space-y-6">
    {# Page Header #}
    {% set right_content %}
        {% if season is not null %}
            {# Info Badge #}
            <div class="bg-gray-900 border border-gray-800 py-1.5 px-3 rounded-md text-xs text-gray-300">
                <span class="text-gray-550 font-semibold uppercase text-[10px] block">{{ 'auth.kingdom_season'|trans }} {{ season.seasonNumber }}</span>
                {{ season.startDate|date('d. m. Y') }} — {{ season.endDate|date('d. m. Y') }}
            </div>

            {# Group Select Dropdown #}
            <form method="GET" action="{{ path('app_league') }}" class="flex items-center gap-2">
                <label for="group-select" class="sr-only">{{ 'league.select_group'|trans }}</label>
                <select id="group-select" name="groupId" onchange="this.form.submit()" class="form-input py-2 bg-gray-900 border-gray-800 text-sm focus:border-emerald-500">
                    {% for g in groups %}
                        <option value="{{ g.id }}" {% if selectedGroup and selectedGroup.id == g.id %}selected{% endif %}>
                            {{ g.tier.tierName }} — {{ g.groupName }}
                        </option>
                    {% endfor %}
                </select>
            </form>
        {% endif %}
    {% endset %}

    {% include 'components/ui/page_header.html.twig' with {
        title: 'league.title',
        subtitle: 'league.subtitle',
        right_content: right_content
    } %}

    {% if season is null %}
        {# No Active Season State #}
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-10 text-center max-w-lg mx-auto mt-12">
            <div class="text-5xl mb-4 select-none">🏆</div>
            <h3 class="text-lg font-bold text-gray-200 mb-2">{{ 'league.no_active_season'|trans }}</h3>
            <p class="text-gray-400 text-sm mb-6">{{ 'league.no_active_season_desc'|trans }}</p>
            <a href="{{ path('app_dashboard') }}" class="btn btn-primary">{{ 'nav.dashboard'|trans }}</a>
        </div>
    {% else %}
        {# Main League View #}
        <div data-controller="tab" class="space-y-6">
            {# Tab Switcher Buttons #}
            <div class="flex border-b border-gray-800 overflow-x-auto scrollbar-none">
                <button type="button" data-tab-target="btn" data-action="click->tab#switch" data-tab="tab-standings" class="tab-btn tab-btn--active">
                    🏆 {{ 'league.tab_standings'|trans }}
                </button>
                <button type="button" data-tab-target="btn" data-action="click->tab#switch" data-tab="tab-fixtures" class="tab-btn">
                    📅 {{ 'league.tab_fixtures'|trans }}
                </button>
                <button type="button" data-tab-target="btn" data-action="click->tab#switch" data-tab="tab-leaderboard" class="tab-btn">
                    🌎 {{ 'league.tab_leaderboard'|trans }}
                </button>
            </div>

            {# ==================== TAB 1: STANDINGS ==================== #}
            <div id="tab-standings" class="space-y-4">
                {% if standings is empty %}
                    <p class="text-sm text-gray-500 text-center py-6">{{ 'league.no_standings'|trans }}</p>
                {% else %}
                    {# Legend / Promotion-Relegation Settings #}
                    {% set groups_count = selectedGroup.tier.groups|length %}
                    {% set tier_promo = selectedGroup.tier.promotionSlots %}
                    {% set tier_releg = selectedGroup.tier.relegationSlots %}
                    {% set total_teams = standings|length %}

                    {% set k_promo = (tier_promo / groups_count)|round(0, 'floor') %}
                    {% set rem_promo = tier_promo % groups_count %}

                    {% set k_releg = (tier_releg / groups_count)|round(0, 'floor') %}
                    {% set rem_releg = tier_releg % groups_count %}

                    <div class="flex flex-wrap gap-4 text-xs text-gray-400 bg-gray-900/40 p-3 rounded border border-gray-800/30">
                        {% if k_promo > 0 %}
                            <div class="flex items-center gap-1.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                                <span>{{ 'league.direct_promotion_zone'|trans }}: {{ 'league.top_x_direct'|trans({'%count%': k_promo}) }}</span>
                            </div>
                        {% endif %}
                        {% if rem_promo > 0 %}
                            <div class="flex items-center gap-1.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500/40 border border-emerald-400/80"></span>
                                <span>{{ 'league.possible_promotion_zone'|trans }}: {{ 'league.top_x_possible'|trans({'%count%': rem_promo}) }}</span>
                            </div>
                        {% endif %}
                        {% if k_releg > 0 %}
                            <div class="flex items-center gap-1.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
                                <span>{{ 'league.direct_relegation_zone'|trans }}: {{ 'league.bottom_x_direct'|trans({'%count%': k_releg}) }}</span>
                            </div>
                        {% endif %}
                        {% if rem_releg > 0 %}
                            <div class="flex items-center gap-1.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-rose-500/40 border border-rose-400/80"></span>
                                <span>{{ 'league.possible_relegation_zone'|trans }}: {{ 'league.bottom_x_possible'|trans({'%count%': rem_releg}) }}</span>
                            </div>
                        {% endif %}
                    </div>

                    {# Table #}
                    <div class="overflow-x-auto bg-gray-900 border border-gray-800 rounded-lg">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-gray-800 text-xs font-semibold text-gray-400 uppercase bg-gray-900/80">
                                    <th class="py-3 px-4 w-16 text-center">{{ 'league.col_rank'|trans }}</th>
                                    <th class="py-3 px-4">{{ 'league.col_team'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-16">{{ 'league.col_played'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-16">{{ 'league.col_wins'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-16">{{ 'league.col_draws'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-16">{{ 'league.col_losses'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_diff'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_points'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-40">{{ 'league.col_form'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-800/50">
                                {% for standing in standings %}
                                    {% set is_own_team = standing.team.id == team.id %}
                                    {% set is_direct_promo = loop.index <= k_promo %}
                                    {% set is_possible_promo = (rem_promo > 0) and (loop.index == k_promo + 1) %}
                                    {% set is_direct_releg = loop.index > (total_teams - k_releg) %}
                                    {% set is_possible_releg = (rem_releg > 0) and (loop.index == (total_teams - k_releg)) %}

                                    <tr class="transition-colors {% if is_own_team %}bg-emerald-500/10 text-emerald-400 font-bold border-l-4 border-emerald-500{% else %}hover:bg-gray-800/30{% endif %}">
                                        {# Rank / Position #}
                                        <td class="py-3.5 px-4 text-center font-mono">
                                            <div class="flex items-center justify-center gap-1">
                                                {% if is_direct_promo %}
                                                    <span class="text-emerald-500 text-xs font-semibold" title="{{ 'league.direct_promotion_zone'|trans }}">▲</span>
                                                {% elseif is_possible_promo %}
                                                    <span class="text-emerald-400/50 text-xs font-semibold" title="{{ 'league.possible_promotion_zone'|trans }}">▲</span>
                                                {% elseif is_direct_releg %}
                                                    <span class="text-rose-500 text-xs font-semibold" title="{{ 'league.direct_relegation_zone'|trans }}">▼</span>
                                                {% elseif is_possible_releg %}
                                                    <span class="text-rose-400/50 text-xs font-semibold" title="{{ 'league.possible_relegation_zone'|trans }}">▼</span>
                                                {% endif %}
                                                {{ loop.index }}
                                            </div>
                                        </td>
                                        
                                        {# Team Name #}
                                        <td class="py-3.5 px-4">
                                            <div class="flex items-center gap-2">
                                                {% if standing.team.emblem %}
                                                    <span class="text-base select-none">{{ standing.team.emblem }}</span>
                                                {% else %}
                                                    <span class="text-base select-none">🛡️</span>
                                                {% endif %}
                                                <span>{{ standing.team.name }}</span>
                                                {% if standing.team.isNpc %}
                                                    <span class="text-[9px] bg-gray-800 text-gray-500 px-1 py-0.5 rounded font-mono uppercase">{{ 'dashboard.npc'|trans }}</span>
                                                {% endif %}
                                            </div>
                                        </td>
                                        
                                        {# Stats #}
                                        <td class="py-3.5 px-4 text-center font-mono text-gray-300">{{ standing.played }}</td>
                                        <td class="py-3.5 px-4 text-center font-mono text-gray-300">{{ standing.wins }}</td>
                                        <td class="py-3.5 px-4 text-center font-mono text-gray-300">{{ standing.draws }}</td>
                                        <td class="py-3.5 px-4 text-center font-mono text-gray-300">{{ standing.losses }}</td>
                                        
                                        {# Goal Diff #}
                                        <td class="py-3.5 px-4 text-center font-mono {% if standing.goalDifference > 0 %}text-emerald-500{% elseif standing.goalDifference < 0 %}text-rose-500{% else %}text-gray-400{% endif %}">
                                            {{ standing.goalDifference > 0 ? '+' : '' }}{{ standing.goalDifference }}
                                        </td>
                                        
                                        {# Points #}
                                        <td class="py-3.5 px-4 text-center font-mono font-bold text-gray-200">{{ standing.points }}</td>
                                        
                                        {# Form #}
                                        <td class="py-3.5 px-4">
                                            <div class="flex items-center justify-center gap-1.5">
                                                {% set team_form = forms[standing.team.id] ?? [] %}
                                                {% if team_form is empty %}
                                                    <span class="text-xs text-gray-600">—</span>
                                                {% else %}
                                                    {% for result in team_form %}
                                                        {% if result == 'W' %}
                                                            <span class="w-5 h-5 flex items-center justify-center text-[10px] font-bold rounded-full bg-emerald-950 text-emerald-400 border border-emerald-800/30 cursor-default" title="{{ 'finance.actor_active'|trans }}">W</span>
                                                        {% elseif result == 'D' %}
                                                            <span class="w-5 h-5 flex items-center justify-center text-[10px] font-bold rounded-full bg-gray-800 text-gray-400 border border-gray-700/30 cursor-default" title="{{ 'finance.actor_passive'|trans }}">D</span>
                                                        {% else %}
                                                            <span class="w-5 h-5 flex items-center justify-center text-[10px] font-bold rounded-full bg-rose-950 text-rose-400 border border-rose-800/30 cursor-default" title="{{ 'flash.invalid_credentials'|trans }}">L</span>
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>

            {# ==================== TAB 2: FIXTURES ==================== #}
            <div id="tab-fixtures" class="hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    {# My Matches (Left) #}
                    <div class="space-y-4">
                        <h3 class="text-base font-bold text-emerald-400 border-b border-gray-800 pb-2">
                            👤 {{ 'league.my_fixtures'|trans }}
                        </h3>
                        
                        {% if myFixtures is empty %}
                            <p class="text-sm text-gray-500 text-center py-6">{{ 'dashboard.no_matches'|trans }}</p>
                        {% else %}
                            <div class="space-y-2.5">
                                {% for f in myFixtures %}
                                    {% set is_home = f.homeTeam.id == team.id %}
                                    {% set is_completed = f.status.value == 'completed' %}
                                    
                                    <div class="bg-gray-900 border border-gray-800 rounded p-4 flex flex-col sm:flex-row items-center justify-between gap-4 {% if is_completed %}opacity-80{% endif %}">
                                        <div class="text-xs text-gray-500">
                                            <span class="block font-semibold uppercase text-[9px] text-gray-400">
                                                {{ f.scheduledAt|date('d. m. Y') }}
                                            </span>
                                            {{ f.scheduledAt|date('H:i') }}
                                        </div>
                                        
                                        {# Match Score Board #}
                                        <div class="flex items-center justify-center gap-3 text-sm flex-1">
                                            <span class="font-medium text-right flex-1 {% if is_home %}text-emerald-400 font-bold{% endif %}">{{ f.homeTeam.name }}</span>
                                            
                                            <span class="px-2.5 py-1 bg-gray-950 rounded border border-gray-800 font-mono text-xs font-semibold text-gray-300">
                                                {% if is_completed and f.battle %}
                                                    {{ f.battle.scoreA }} — {{ f.battle.scoreB }}
                                                {% else %}
                                                    VS
                                                {% endif %}
                                            </span>
                                            
                                            <span class="font-medium text-left flex-1 {% if not is_home %}text-emerald-400 font-bold{% endif %}">{{ f.awayTeam.name }}</span>
                                        </div>
                                        
                                        <div>
                                            {% if is_completed and f.battle %}
                                                <span class="text-[10px] bg-gray-800 text-gray-400 py-1 px-2.5 rounded font-medium select-none uppercase">
                                                    {{ 'training.status.completed'|trans }}
                                                </span>
                                            {% else %}
                                                <span class="text-[10px] bg-emerald-950/40 text-emerald-400 border border-emerald-800/20 py-1 px-2.5 rounded font-medium select-none uppercase">
                                                    {{ 'training.status.pending'|trans }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Group Fixtures by Round (Right) #}
                    <div class="space-y-4">
                        <h3 class="text-base font-bold text-emerald-400 border-b border-gray-800 pb-2">
                            🏆 {{ 'league.group_fixtures'|trans }}
                        </h3>

                        {% if fixtures is empty %}
                            <p class="text-sm text-gray-500 text-center py-6">{{ 'dashboard.no_matches'|trans }}</p>
                        {% else %}
                            <div class="space-y-6 max-h-[70vh] overflow-y-auto pr-2 custom-scrollbar">
                                {% set current_date = null %}
                                {% set round_count = 0 %}
                                {% for f in fixtures %}
                                    {% set f_date = f.scheduledAt|date('Y-m-d H:i') %}
                                    {% if f_date != current_date %}
                                        {% set current_date = f_date %}
                                        {% set round_count = round_count + 1 %}
                                        <div class="border-b border-gray-800 pb-2 pt-2 first:pt-0">
                                            <h4 class="text-xs font-bold text-emerald-500/80 uppercase tracking-wide">
                                                {{ 'league.round'|trans }} {{ round_count }} — {{ f.scheduledAt|date('d. m. Y H:i') }}
                                            </h4>
                                        </div>
                                    {% endif %}

                                    <div class="flex items-center justify-between py-2 px-3 rounded hover:bg-gray-800/20 text-xs border border-transparent hover:border-gray-800/40 gap-2">
                                        <div class="w-5/12 text-right truncate {% if f.homeTeam.id == team.id %}font-bold text-emerald-400{% endif %}" title="{{ f.homeTeam.name }}">
                                            {{ f.homeTeam.name }}
                                        </div>
                                        
                                        <div class="w-2/12 text-center bg-gray-950 py-0.5 px-2 rounded font-mono text-[11px] text-gray-400 border border-gray-800/50">
                                            {% if f.status.value == 'completed' and f.battle %}
                                                {{ f.battle.scoreA }}-{{ f.battle.scoreB }}
                                            {% else %}
                                                VS
                                            {% endif %}
                                        </div>
                                        
                                        <div class="w-5/12 text-left truncate {% if f.awayTeam.id == team.id %}font-bold text-emerald-400{% endif %}" title="{{ f.awayTeam.name }}">
                                            {{ f.awayTeam.name }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# ==================== TAB 3: GLOBAL LEADERBOARD ==================== #}
            <div id="tab-leaderboard" class="hidden space-y-4">
                {% if globalLeaderboard is empty %}
                    <p class="text-sm text-gray-500 text-center py-6">{{ 'league.no_standings'|trans }}</p>
                {% else %}
                    <div class="overflow-x-auto bg-gray-900 border border-gray-800 rounded-lg">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-gray-800 text-xs font-semibold text-gray-400 uppercase bg-gray-900/80">
                                    <th class="py-3 px-4 w-16 text-center">{{ 'league.col_rank'|trans }}</th>
                                    <th class="py-3 px-4">{{ 'league.col_team'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-24">{{ 'auth.choose_kingdom'|trans }} Tier</th>
                                    <th class="py-3 px-4 text-center w-32">{{ 'league.col_group'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_played'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_wins'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_draws'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-20">{{ 'league.col_losses'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-24">{{ 'league.col_diff'|trans }}</th>
                                    <th class="py-3 px-4 text-center w-24 font-bold">{{ 'league.col_points'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-800/50">
                                {% for standing in globalLeaderboard %}
                                    {% set is_own_team = standing.team.id == team.id %}
                                    <tr class="transition-colors {% if is_own_team %}bg-emerald-500/10 text-emerald-400 font-bold border-l-4 border-emerald-500{% else %}hover:bg-gray-800/30{% endif %}">
                                        <td class="py-3 px-4 text-center font-mono text-gray-400">{{ loop.index }}</td>
                                        <td class="py-3 px-4">
                                            <div class="flex items-center gap-2">
                                                {% if standing.team.emblem %}
                                                    <span class="text-base select-none">{{ standing.team.emblem }}</span>
                                                {% else %}
                                                    <span class="text-base select-none">🛡️</span>
                                                {% endif %}
                                                <span>{{ standing.team.name }}</span>
                                                {% if standing.team.isNpc %}
                                                    <span class="text-[9px] bg-gray-800 text-gray-500 px-1 py-0.5 rounded font-mono uppercase">{{ 'dashboard.npc'|trans }}</span>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td class="py-3 px-4 text-center text-gray-300">{{ standing.group.tier.tierName }}</td>
                                        <td class="py-3 px-4 text-center text-gray-300">{{ standing.group.groupName }}</td>
                                        <td class="py-3 px-4 text-center font-mono text-gray-400">{{ standing.played }}</td>
                                        <td class="py-3 px-4 text-center font-mono text-gray-400">{{ standing.wins }}</td>
                                        <td class="py-3 px-4 text-center font-mono text-gray-400">{{ standing.draws }}</td>
                                        <td class="py-3 px-4 text-center font-mono text-gray-400">{{ standing.losses }}</td>
                                        <td class="py-3 px-4 text-center font-mono {% if standing.goalDifference > 0 %}text-emerald-500{% elseif standing.goalDifference < 0 %}text-rose-500{% else %}text-gray-400{% endif %}">
                                            {{ standing.goalDifference > 0 ? '+' : '' }}{{ standing.goalDifference }}
                                        </td>
                                        <td class="py-3 px-4 text-center font-mono font-bold text-gray-200">{{ standing.points }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
