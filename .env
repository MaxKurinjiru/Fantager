NODE_ENV=production

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=71d9e8169041a46d51be3927e439c5bc3dd249ef908e05e1596d3c9c4e603209
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL=
###< doctrine/doctrine-bundle ###
DATABASE_LEGACY_URL=

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=
###< symfony/routing ###

###> symfony/messenger ###
# Messenger: Doctrine transport — uses the same DB as DATABASE_URL.
# Set DATABASE_URL first; this value must match.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM="Fantager <noreply@fantager.cz>"
###< symfony/mailer ###

###> sentry/sentry-symfony ###
SENTRY_DSN=
