{# templates/components/league/calendar_tab.html.twig #}
<div id="tab-calendar" class="league-tab-panel {{ tab != 'calendar' ? 'hidden' : '' }}"
     data-controller="calendar"
     data-calendar-kingdom-id-value="{{ kingdom.id }}"
     data-calendar-team-id-value="{{ team.id }}"
     data-calendar-timezone-value="{{ kingdom.timezone }}"
     data-calendar-translations-value="{{ {
         'loading': 'calendar.loading'|trans,
         'empty': 'calendar.empty'|trans,
         'error': 'calendar.error'|trans,
         'filter_team_only': 'calendar.filter_team_only'|trans,
         'filter_show_system': 'calendar.filter_show_system'|trans,
         'type_system_tick': 'calendar.type_system_tick'|trans,
         'type_league_match': 'calendar.type_league_match'|trans,
         'type_world_event': 'calendar.type_world_event'|trans,
         'type_training_queue': 'calendar.type_training_queue'|trans,
         'status_scheduled': 'calendar.status_scheduled'|trans,
         'status_completed': 'calendar.status_completed'|trans,
         'status_failed': 'calendar.status_failed'|trans
     }|json_encode|e('html_attr') }}">

    <div class="filter-bar game-panel mb-6">
        <div class="flex flex-wrap gap-4 items-center">
            <label class="form-check cursor-pointer">
                <input type="checkbox" data-calendar-target="teamOnlyToggle" data-action="change->calendar#reload" class="rounded form-control-accent">
                <span>{{ 'calendar.filter_team_only'|trans }}</span>
            </label>
            <label class="form-check cursor-pointer">
                <input type="checkbox" data-calendar-target="systemToggle" data-action="change->calendar#reload" class="rounded form-control-accent">
                <span>{{ 'calendar.filter_show_system'|trans }}</span>
            </label>
        </div>
        <div class="cal-week-nav">
            <button type="button" data-action="click->calendar#prevWeek" class="btn btn-outline btn--sm">←</button>
            <span data-calendar-target="rangeLabel" class="cal-week-nav__label"></span>
            <button type="button" data-action="click->calendar#nextWeek" class="btn btn-outline btn--sm">→</button>
        </div>
    </div>

    <div data-calendar-target="feedContainer" class="space-y-3">
        <div class="loading-spinner">
            <div class="loading-spinner__icon" aria-hidden="true"></div>
        </div>
    </div>

    <template id="template-calendar-loading">
        <div class="cal-feed-loading"><div class="cal-feed-loading__spinner" aria-hidden="true"></div></div>
    </template>
    <template id="template-calendar-empty">
        <p class="cal-feed-empty js-cal-empty"></p>
    </template>
    <template id="template-calendar-error">
        <p class="cal-feed-error js-cal-error"></p>
    </template>
    <template id="template-calendar-event">
        <article class="cal-event">
            <div class="cal-event__date">
                <div class="cal-event__weekday js-cal-weekday"></div>
                <div class="cal-event__day js-cal-day"></div>
                <div class="cal-event__time js-cal-time"></div>
            </div>
            <div class="cal-event__body">
                <div class="cal-event__meta">
                    <span class="cal-event__type js-cal-type"></span>
                    <span class="cal-event__status js-cal-status"></span>
                </div>
                <h3 class="cal-event__title js-cal-title"></h3>
                <p class="cal-event__description js-cal-description"></p>
            </div>
        </article>
    </template>
</div>
