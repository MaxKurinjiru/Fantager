{# templates/components/ui/page_header.html.twig #}
{% set title = title|default('') %}
{% set subtitle = subtitle|default('') %}

<div class="page-header">
    <div class="page-header__body">
        <h1 class="page-header__title">{{ title|trans }}</h1>
        {% if subtitle %}
            <p class="page-header__subtitle">{{ subtitle|trans }}</p>
        {% endif %}
    </div>

    {% if right_content is defined and right_content is not null %}
        <div class="page-header__actions">
            {{ right_content|raw }}
        </div>
    {% endif %}
</div>
