{# templates/components/marketplace/js_templates.html.twig #}
{# ─────────────────────────────────────────────────────────────────────────────
   HTML TEMPLATES (CLONED IN STIMULUS CONTROLLER FOR DYNAMIC UI RENDERING)
   ───────────────────────────────────────────────────────────────────────────── #}

{# Hero Card Template #}
<template id="template-card-hero">
    <div class="marketplace-card marketplace-card--hero">
        <div class="layout-stack layout-stack--sm">
            <div class="layout-cluster layout-cluster--between">
                <span class="marketplace-card__type-badge marketplace-card__type-badge--hero">👥 {{ 'marketplace.type_hero'|trans }}</span>
                <span class="marketplace-card__level js-level"></span>
            </div>
            <h3 class="marketplace-card__title js-name"></h3>
            <div class="marketplace-card__details">
                <div>{{ 'heroes.race'|trans }}: <span class="marketplace-card__detail-value js-race"></span></div>
                <div>{{ 'heroes.age'|trans }}: <span class="marketplace-card__detail-value js-age"></span></div>
                <div>{{ 'marketplace.card_form'|trans }} <span class="marketplace-card__detail-value js-form"></span></div>
                <div>{{ 'heroes.fatigue'|trans }}: <span class="marketplace-card__detail-value js-fatigue"></span></div>
            </div>
            <div class="marketplace-card__stats">
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_str'|trans }}<span class="marketplace-card__stat-value js-str"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_dex'|trans }}<span class="marketplace-card__stat-value js-dex"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_kon'|trans }}<span class="marketplace-card__stat-value js-kon"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_spd'|trans }}<span class="marketplace-card__stat-value js-spd"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_int'|trans }}<span class="marketplace-card__stat-value js-int"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_wil'|trans }}<span class="marketplace-card__stat-value js-wil"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_cha'|trans }}<span class="marketplace-card__stat-value js-cha"></span></div>
                <div class="marketplace-card__stat-item">{{ 'heroes.abbr_lck'|trans }}<span class="marketplace-card__stat-value js-lck"></span></div>
            </div>
        </div>
        <div class="marketplace-card__footer js-footer-info">
            <div class="marketplace-card__footer-row">
                <span>{{ 'marketplace.col_seller'|trans }}: <span class="marketplace-card__seller-name js-seller-name"></span></span>
                <span class="marketplace-card__time-remaining js-time-remaining"></span>
            </div>
            <div class="marketplace-card__footer-row js-buyout-section hidden">
                <span class="marketplace-card__footer-label">{{ 'marketplace.label_buyout'|trans }}:</span>
                <span class="marketplace-card__price">🪙&nbsp;<span class="js-buyout-price"></span></span>
            </div>
            <div class="marketplace-card__footer-row js-bid-section hidden">
                <span class="marketplace-card__footer-label">{{ 'marketplace.label_highest_bid'|trans }}:</span>
                <span class="marketplace-card__price js-highest-bid"></span>
            </div>
        </div>
        <div class="js-actions-section"></div>
    </div>
</template>

{# Item Card Template #}
<template id="template-card-item">
    <div class="marketplace-card">
        <div class="layout-stack layout-stack--sm">
            <div class="layout-cluster layout-cluster--between">
                <span class="marketplace-card__type-badge marketplace-card__type-badge--item">🗡️ {{ 'marketplace.type_item'|trans }}</span>
                <span class="js-rarity"></span>
            </div>
            <h3 class="marketplace-card__title js-name"></h3>
            <div class="marketplace-card__meta">
                {{ 'marketplace.card_slot'|trans }} <span class="marketplace-card__detail-value js-slot"></span> &bull;
                {{ 'marketplace.card_durability'|trans }} <span class="marketplace-card__detail-value js-durability"></span>
            </div>
            <div class="marketplace-card__bonuses js-bonuses"></div>
        </div>
        <div class="marketplace-card__footer js-footer-info">
            <div class="marketplace-card__footer-row">
                <span>{{ 'marketplace.col_seller'|trans }}: <span class="marketplace-card__seller-name js-seller-name"></span></span>
                <span class="marketplace-card__time-remaining js-time-remaining"></span>
            </div>
            <div class="marketplace-card__footer-row js-buyout-section hidden">
                <span class="marketplace-card__footer-label">{{ 'marketplace.label_buyout'|trans }}:</span>
                <span class="marketplace-card__price">🪙&nbsp;<span class="js-buyout-price"></span></span>
            </div>
            <div class="marketplace-card__footer-row js-bid-section hidden">
                <span class="marketplace-card__footer-label">{{ 'marketplace.label_highest_bid'|trans }}:</span>
                <span class="marketplace-card__price js-highest-bid"></span>
            </div>
        </div>
        <div class="js-actions-section"></div>
    </div>
</template>

