{# templates/components/hq/facility_card.html.twig #}
{% set key = facility.type.value %}
{% set facility_emojis = {
    'training': '🏋️',
    'medical': '🏥',
    'library': '📚',
    'treasury': '💰',
    'barracks': '⛺',
    'summoning_chamber': '🌀',
    'arena': '🏟️'
} %}
{% set emoji = facility_emojis[key] ?? '🏰' %}
{% set upgrade_cost = hq_upgrade_cost(facility.type, facility.level) %}

<div data-facility-card class="facility-card">
    <div class="facility-card__content">
        <div class="facility-card__header">
            <div class="facility-card__identity">
                <span class="facility-card__emoji" aria-hidden="true">{{ emoji }}</span>
                <div>
                    <h3 class="facility-card__name">{{ ('hq.facilities_list.' ~ key ~ '.name')|trans }}</h3>
                    <p class="facility-card__desc">{{ ('hq.facilities_list.' ~ key ~ '.desc')|trans }}</p>
                </div>
            </div>
            <span data-facility-level class="facility-card__level">
                {{ 'js_flash.hq.lvl_short'|trans }} {{ facility.level }}
            </span>
        </div>

        <div class="facility-card__bonuses-panel">
            <span class="facility-card__bonuses-label">{{ 'hq.passive_effects'|trans }}</span>
            <ul data-facility-bonuses class="facility-card__bonuses">
                {% for name, value in facility.passiveBonuses %}
                    <li class="facility-bonus-row">
                        <span class="facility-bonus-row__name">{{ ('hq.bonus_' ~ name)|trans }}:</span>
                        <span class="facility-bonus-row__value">+{{ value }}{{ name ends with '_pct' ? '%' : '' }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="facility-card__footer">
        <div>
            <span class="facility-card__cost-label">{{ 'hq.upgrade_cost'|trans }}</span>
            <span data-facility-cost class="facility-card__cost">🪙 {{ upgrade_cost|number_format(0, '.', ' ') }}</span>
        </div>
        <button type="button" data-action="click->hq#upgrade" data-facility="{{ key }}" data-cost="{{ upgrade_cost }}" data-cost-original="{{ upgrade_cost }}"
                {% if team.gold < upgrade_cost %}disabled title="{{ 'hq.insufficient_gold'|trans }}"{% endif %}
                class="btn btn-outline btn--sm"
                aria-label="{{ 'hq.upgrade_btn'|trans }}">
            {{ 'hq.upgrade_btn'|trans }}
        </button>
    </div>
</div>
