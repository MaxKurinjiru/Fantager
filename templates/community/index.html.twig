{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'nav.community'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="page-content" data-controller="community"
     data-community-active-team-id-value="{{ team.id }}"
     data-community-kingdom-id-value="{{ kingdom.id }}"
     data-community-empty-threads-msg-value="{{ 'community.no_threads'|trans }}"
     data-community-translations-value="{{ {
         'error_load_threads': 'community.error_load_threads'|trans,
         'warning_fill_fields': 'community.warning_fill_fields'|trans,
         'text_sending': 'community.text_sending'|trans,
         'error_create_thread': 'community.error_create_thread'|trans,
         'success_create_thread': 'community.success_create_thread'|trans,
         'btn_unlock': 'community.btn_unlock'|trans,
         'btn_lock': 'community.btn_lock'|trans,
         'error_load_thread_detail': 'community.error_load_thread_detail'|trans,
         'error_send_reply': 'community.error_send_reply'|trans,
         'error_refresh_posts': 'community.error_refresh_posts'|trans,
         'error_toggle_lock': 'community.error_toggle_lock'|trans,
         'post_reply': 'community.post_reply'|trans,
         'back_to_threads': 'community.back_to_threads'|trans,
         'categories': {
             'general': 'community.category_general'|trans,
             'strategy': 'community.category_strategy'|trans,
             'trading': 'community.category_trading'|trans,
             'bugs': 'community.category_bugs'|trans
         }
     }|json_encode|e('html_attr') }}"
>
    {% include 'components/ui/page_header.html.twig' with {
        title: 'community.title',
        subtitle: 'community.subtitle'
    } %}

    {% include 'components/ui/alert_box.html.twig' with {
        target: 'community',
        message_target: 'alertMessage',
        close_action: 'community#hideAlert'
    } %}

    <div class="page-grid page-grid--sidebar">
        <div class="community-sidebar-col">
            <div class="community-sidebar">
                <h3 class="community-sidebar__heading">{{ 'community.categories'|trans }}</h3>
                <button type="button" data-action="click->community#filterCategory" data-category="all" class="community-tab-btn community-tab-btn--active" data-community-target="categoryBtn">
                    📁 {{ 'community.all_threads'|trans }}
                </button>
                {% for cat in categories %}
                    <button type="button" data-action="click->community#filterCategory" data-category="{{ cat }}" class="community-tab-btn" data-community-target="categoryBtn">
                        💬 {{ ('community.category_' ~ cat)|trans }}
                    </button>
                {% endfor %}
            </div>
            <button type="button" data-action="click->community#openNewThreadModal" class="btn btn-primary community-new-thread-btn">
                ➕ {{ 'community.new_thread'|trans }}
            </button>
        </div>

        <div class="community-main-col">
            <div data-community-target="threadsContainer" class="community-panel">
                <h2 class="community-panel__title">{{ 'community.threads_list'|trans }}</h2>
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>{{ 'community.col_title'|trans }}</th>
                                <th>{{ 'community.col_author'|trans }}</th>
                                <th class="data-table__col--center">{{ 'community.col_replies'|trans }}</th>
                                <th class="data-table__col--end">{{ 'community.col_created'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody data-community-target="threadsTableBody">
                            {% for thread in threads %}
                                <tr class="community-row" data-action="click->community#viewThread" data-thread-id="{{ thread.id }}">
                                    <td class="data-table__cell--title">
                                        <div class="data-table__title-row">
                                            {% if thread.isLocked %}<span class="lock-badge lock-badge--icon" title="{{ 'community.locked'|trans }}" aria-label="{{ 'community.locked'|trans }}">🔒</span>{% endif %}
                                            <span>{{ thread.title }}</span>
                                        </div>
                                        <span class="category-badge">{{ ('community.category_' ~ thread.category)|trans }}</span>
                                    </td>
                                    <td>
                                        <div class="data-table__author-row">
                                            <span class="team-color-dot" style="--team-color-primary: {{ thread.authorTeam.colors.primary ?? '#10b981' }}; --team-color-secondary: {{ thread.authorTeam.colors.secondary ?? '#0f1720' }};"></span>
                                            <span>{{ thread.authorTeam.name }}</span>
                                        </div>
                                    </td>
                                    <td class="data-table__col--center data-table__cell--numeric">{{ thread.posts|length }}</td>
                                    <td class="data-table__col--end data-table__cell--muted">{{ thread.createdAt|date('d. m. Y H:i') }}</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="empty-state">{{ 'community.no_threads'|trans }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div data-community-target="threadDetailContainer" class="hidden community-panel thread-detail">
                <div class="thread-detail__header">
                    <div>
                        <button type="button" data-action="click->community#backToThreads" class="back-link">⬅️ {{ 'community.back_to_threads'|trans }}</button>
                        <h2 data-community-target="threadTitle" class="thread-detail__title"></h2>
                        <span data-community-target="threadCategory" class="category-badge thread-detail__category"></span>
                    </div>
                    <div class="thread-detail__actions">
                        <span data-community-target="threadLockBadge" class="hidden lock-badge">🔒 {{ 'community.locked'|trans }}</span>
                        <button type="button" data-community-target="lockBtn" data-action="click->community#toggleLock" class="hidden btn btn-outline btn--sm">{{ 'community.btn_lock'|trans }}</button>
                    </div>
                </div>
                <div data-community-target="postsTimeline" class="posts-timeline"></div>
                <div data-community-target="replyFormContainer" class="training-reply-form">
                    <label for="reply-body" class="form-label">{{ 'community.add_reply'|trans }}</label>
                    <textarea id="reply-body" data-community-target="replyInput" class="form-input" rows="5" placeholder="{{ 'community.reply_placeholder'|trans }}" required></textarea>
                    <button type="button" data-community-target="submitReplyBtn" data-action="click->community#submitReply" class="btn btn-primary">{{ 'community.post_reply'|trans }}</button>
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'components/community/new_thread_modal.html.twig' with { categories: categories } %}
{% include 'components/community/js_templates.html.twig' %}
{% endblock %}
