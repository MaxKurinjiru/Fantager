{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'marketplace.title'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="space-y-6" data-controller="marketplace"
     data-marketplace-tax-rate-value="{{ taxRate }}"
     data-marketplace-current-team-id-value="{{ team.id }}"
     data-marketplace-csrf-token-value="{{ csrf_token('api') }}"
     data-marketplace-races-value="{{ {
         'human': 'heroes.race_human'|trans,
         'elf': 'heroes.race_elf'|trans,
         'dwarf': 'heroes.race_dwarf'|trans,
         'orc': 'heroes.race_orc'|trans,
         'undead': 'heroes.race_undead'|trans,
         'giant': 'heroes.race_giant'|trans,
         'ent': 'heroes.race_ent'|trans,
         'genie': 'heroes.race_genie'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-rarities-value="{{ {
         'common': 'inventory.rarity_common'|trans,
         'uncommon': 'inventory.rarity_uncommon'|trans,
         'rare': 'inventory.rarity_rare'|trans,
         'epic': 'inventory.rarity_epic'|trans,
         'legendary': 'inventory.rarity_legendary'|trans,
         'mythic': 'inventory.rarity_mythic'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-slots-value="{{ {
         'head': 'inventory.slot_head'|trans,
         'amulet': 'inventory.slot_amulet'|trans,
         'body': 'inventory.slot_body'|trans,
         'hands': 'inventory.slot_hands'|trans,
         'main_hand': 'inventory.slot_main_hand'|trans,
         'weapon': 'inventory.slot_weapon'|trans,
         'off_hand': 'inventory.slot_off_hand'|trans,
         'ring': 'inventory.slot_ring'|trans,
         'feet': 'inventory.slot_feet'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-statuses-value="{{ {
         'active': 'marketplace.status_active'|trans,
         'sold': 'marketplace.status_sold'|trans,
         'expired': 'marketplace.status_expired'|trans,
         'cancelled': 'marketplace.status_cancelled'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-translations-value="{{ {
         'own_listing_hint': 'marketplace.own_listing_hint'|trans,
         'select_entity_first': 'marketplace.select_entity_first'|trans,
         'confirm_cancel': 'marketplace.confirm_cancel'|trans,
         'confirm_bid': 'marketplace.confirm_bid'|trans,
         'confirm_buyout': 'marketplace.confirm_buyout'|trans,
         'time_expired': 'marketplace.time_expired'|trans,
         'time_remaining': 'marketplace.time_remaining'|trans,
         'time_remaining_hours': 'marketplace.time_remaining_hours'|trans,
         'empty_listings': 'marketplace.empty_listings'|trans,
         'empty_my_listings': 'marketplace.empty_my_listings'|trans,
         'empty_history': 'marketplace.empty_history'|trans,
         'label_min_bid': 'marketplace.label_min_bid'|trans,
         'label_buyout_price': 'marketplace.label_buyout_price'|trans,
         'label_no_bonuses': 'marketplace.label_no_bonuses'|trans,
         'none_selected': 'marketplace.select_entity_placeholder'|trans,
         'active_auction': 'marketplace.status_active'|trans,
         'direct_buy': 'marketplace.mode_buy_now'|trans,
         'mode_auction': 'marketplace.mode_auction'|trans,
         'highest_bid_format': 'marketplace.label_highest_bid_val'|trans,
         'no_bids': 'marketplace.label_no_bids_val'|trans,
         'btn_bid': 'marketplace.btn_bid'|trans,
         'btn_buyout': 'marketplace.btn_buyout'|trans,
         'btn_cancel': 'marketplace.btn_cancel'|trans,
         'years_suffix': 'marketplace.years_suffix'|trans,
         'type_hero': 'marketplace.type_hero_sing'|trans,
         'type_item': 'marketplace.type_item_sing'|trans,
         'type_trainer': 'marketplace.type_trainer_sing'|trans,
         'error_fetch_listings': 'marketplace.error_fetch_listings'|trans,
         'error_fetch_my_listings': 'marketplace.error_fetch_my_listings'|trans,
         'error_listing': 'marketplace.error_listing'|trans,
         'error_purchase': 'marketplace.error_purchase'|trans,
         'error_bid': 'marketplace.error_bid'|trans,
         'error_cancel': 'marketplace.error_cancel'|trans,
         'flash_created': 'marketplace.flash_created'|trans,
         'flash_purchased': 'marketplace.flash_purchased'|trans,
         'flash_bid': 'marketplace.flash_bid'|trans,
         'flash_cancelled': 'marketplace.flash_cancelled'|trans,
         'unknown_entity': 'marketplace.col_entity'|trans,
         'label_processing': 'marketplace.label_processing'|trans
     }|json_encode|e('html_attr') }}">    {# Hub Header #}
    {% set right_content %}
        <div class="treasury-badge">
            <span class="treasury-badge__label">{{ 'dashboard.treasury'|trans }}:</span>
            <span class="treasury-badge__value">
                <span class="mr-1">🪙</span> {{ team.gold }} {{ 'dashboard.gold'|trans }}
            </span>
        </div>
    {% endset %}

    {% include 'components/ui/page_header.html.twig' with {
        title: 'marketplace.title',
        subtitle: 'marketplace.subtitle',
        right_content: right_content
    } %}

    {# --- Alert Box --- #}
    {% include 'components/ui/alert_box.html.twig' with {
        target: 'marketplace',
        message_target: 'alertMessage',
        close_action: 'marketplace#hideAlert'
    } %}

    {# Hub Tabs #}
    <div class="tab-nav-bar">
        <button type="button" data-action="click->marketplace#switchTab" data-tab="browse" data-marketplace-target="tabButton"
                class="tab-btn tab-btn--active">
            ⚖️ {{ 'marketplace.tab_browse'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="sell" data-marketplace-target="tabButton"
                class="tab-btn">
            💰 {{ 'marketplace.tab_sell'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="mylistings" data-marketplace-target="tabButton"
                class="tab-btn">
            📦 {{ 'marketplace.tab_my_listings'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="history" data-marketplace-target="tabButton"
                class="tab-btn">
            📜 {{ 'marketplace.tab_history'|trans }}
        </button>
    </div>

    {# TABS CONTENT #}
    
    {# 1. BROWSE TAB #}
    {% include 'components/marketplace/browse_tab.html.twig' %}

    {# 2. SELL TAB #}
    {% include 'components/marketplace/sell_tab.html.twig' with {
        heroes: heroes,
        items: items,
        trainers: trainers,
        taxRate: taxRate,
        team: team
    } %}

    {# 3. MY LISTINGS TAB #}
    {% include 'components/marketplace/mylistings_tab.html.twig' %}

    {# 4. TRANSACTION HISTORY TAB #}
    {% include 'components/marketplace/history_tab.html.twig' %}
</div>

{# HTML TEMPLATES #}
{% include 'components/marketplace/js_templates.html.twig' %}
{% endblock %}
