{% extends 'layouts/public.html.twig' %}

{% block title %}{{ 'auth.reset_password_confirm_title'|trans }} — Fantager{% endblock %}

{% block guest_body %}
<div class="auth-page">
    <h1 class="auth-panel__title">{{ 'auth.reset_password_confirm_title'|trans }}</h1>

    {% if token is empty %}
        <div class="alert alert-error" role="alert">{{ 'auth.reset_password_invalid_token'|trans }}</div>
    {% else %}
        <form method="POST" action="{{ path('app_password_reset_confirm', {token: token}) }}" class="auth-form">
            <input type="hidden" name="_token" value="{{ csrf_token('password_reset_confirm') }}">

            <div class="form-field">
                <label for="password" class="form-label">
                    {{ 'auth.reset_password_confirm_new'|trans }}
                    <span class="copy-muted">{{ 'auth.password_hint'|trans }}</span>
                </label>
                <input type="password" id="password" name="password" required minlength="8" maxlength="4096" autofocus
                       autocomplete="new-password"
                       class="form-input">
            </div>

            <div class="form-field">
                <label for="confirm_password" class="form-label">{{ 'auth.reset_password_confirm_confirm'|trans }}</label>
                <input type="password" id="confirm_password" name="confirm_password" required
                       autocomplete="new-password"
                       class="form-input">
            </div>

            <button type="submit" class="btn btn-primary btn--block">
                {{ 'auth.reset_password_confirm_submit'|trans }}
            </button>
        </form>
    {% endif %}

    <p class="auth-page__footer">
        <a href="{{ path('app_login') }}">{{ 'auth.back_to_login'|trans }}</a>
    </p>
</div>
{% endblock %}
