{% set val = status.value is defined ? status.value : status %}
{% set rounded_full = rounded_full|default(false) %}
{% set extra_classes = extra_classes|default('') %}

<span class="text-[10px] font-bold uppercase py-1 border {{ rounded_full ? 'px-3 rounded-full font-extrabold tracking-wider' : 'px-2.5 rounded' }} {{ extra_classes }}
    {% if val == 'available' %}bg-green-950/40 text-green-400 border-green-900/40
    {% elseif val == 'tired' %}bg-yellow-950/40 text-yellow-400 border-yellow-900/40
    {% elseif val == 'training' %}bg-amber-950/40 text-amber-400 border-amber-900/40
    {% elseif val == 'in_match' %}bg-indigo-950/40 text-indigo-400 border-indigo-900/40
    {% elseif val == 'dead' %}bg-red-950/40 text-red-400 border-red-900/40
    {% else %}bg-gray-950 text-gray-400 border-gray-800{% endif %}">
    {{ val|replace({'_': ' '}) }}
</span>
