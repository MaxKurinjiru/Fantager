{# templates/components/dashboard/recent_expenses.html.twig #}
<div class="db-expenses-card">
    <div class="db-expenses-card__header">
        <h3 class="db-expenses-card__title">{{ 'finance.summary_recent_expenses'|trans }}</h3>
        <a href="{{ path('app_finance') }}" class="db-expenses-card__link">{{ 'finance.view_full_ledger'|trans }}</a>
    </div>

    <div class="db-expenses-card__list">
        {% for item in recent_expenses %}
            <div class="db-expenses-item">
                <div class="db-expenses-item__main">
                    <div class="db-expenses-item__row">
                        <span class="db-expenses-item__title">{{ ('finance.type_' ~ item.type)|trans }}</span>
                        <span class="db-expenses-item__amount">−{{ item.amount|number_format(0, '.', ' ') }} 🪙</span>
                    </div>
                    <div class="db-expenses-item__time">{{ item.created_at|date('Y-m-d H:i') }}</div>
                </div>
            </div>
        {% else %}
            <div class="db-expenses-empty">
                <span class="text-2xl block mb-1">🪙</span>
                <span>{{ 'finance.no_records'|trans }}</span>
            </div>
        {% endfor %}
    </div>
</div>
