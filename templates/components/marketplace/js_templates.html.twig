{# templates/components/marketplace/js_templates.html.twig #}
{# ─────────────────────────────────────────────────────────────────────────────
   HTML TEMPLATES (CLONED IN STIMULUS CONTROLLER FOR DYNAMIC UI RENDERING)
   ───────────────────────────────────────────────────────────────────────────── #}

{# Hero Card Template #}
<template id="template-card-hero">
    <div class="marketplace-card marketplace-card--hero">
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <span class="text-xs uppercase font-bold text-blue-400 bg-blue-950/60 px-2.5 py-0.5 rounded border border-blue-900">👥 {{ 'marketplace.type_hero'|trans }}</span>
                <span class="text-xs text-gray-400 font-medium js-level"></span>
            </div>
            <h3 class="text-lg font-bold text-white leading-tight js-name"></h3>
            <div class="marketplace-card__details">
                <div>{{ 'heroes.race'|trans }}: <span class="text-gray-200 font-semibold js-race"></span></div>
                <div>{{ 'heroes.age'|trans }}: <span class="text-gray-200 font-semibold js-age"></span></div>
                <div>Forma: <span class="text-gray-200 font-semibold js-form"></span></div>
                <div>{{ 'heroes.fatigue'|trans }}: <span class="text-gray-200 font-semibold js-fatigue"></span></div>
            </div>
            <div class="marketplace-card__stats">
                <div class="marketplace-card__stat-item">STR <span class="block text-xs text-gray-300 font-bold mt-0.5 js-str"></span></div>
                <div class="marketplace-card__stat-item">DEX <span class="block text-xs text-gray-300 font-bold mt-0.5 js-dex"></span></div>
                <div class="marketplace-card__stat-item">KON <span class="block text-xs text-gray-300 font-bold mt-0.5 js-kon"></span></div>
                <div class="marketplace-card__stat-item">SPD <span class="block text-xs text-gray-300 font-bold mt-0.5 js-spd"></span></div>
            </div>
        </div>
        <div class="border-t border-gray-800/80 pt-3 space-y-1 js-footer-info">
            <div class="flex justify-between text-[11px] text-gray-500 pb-1 border-b border-gray-800/40">
                <span>{{ 'marketplace.col_seller'|trans }}: <span class="text-gray-300 font-medium js-seller-name"></span></span>
                <span class="text-red-400 font-semibold js-time-remaining"></span>
            </div>
            <div class="flex items-center justify-between py-1 border-b border-gray-800/60 js-buyout-section hidden">
                <span class="text-xs text-gray-400">{{ 'marketplace.label_buyout'|trans }}:</span>
                <span class="text-sm font-bold text-amber-400 flex items-center">🪙&nbsp;<span class="js-buyout-price"></span></span>
            </div>
            <div class="flex items-center justify-between py-1 js-bid-section hidden">
                <span class="text-xs text-gray-400">{{ 'marketplace.label_highest_bid'|trans }}:</span>
                <span class="text-sm font-bold text-amber-500 flex items-center js-highest-bid"></span>
            </div>
        </div>
        <div class="js-actions-section"></div>
    </div>
</template>

{# Item Card Template #}
<template id="template-card-item">
    <div class="marketplace-card">
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <span class="text-xs uppercase font-bold text-emerald-400 bg-emerald-950/60 px-2.5 py-0.5 rounded border border-emerald-900">🗡️ {{ 'marketplace.type_item'|trans }}</span>
                <span class="js-rarity"></span>
            </div>
            <h3 class="text-lg font-bold text-white leading-tight js-name"></h3>
            <div class="text-xs text-gray-400">
                Slot: <span class="text-gray-200 font-semibold js-slot"></span> &bull; 
                Ochrana/Dur: <span class="text-gray-200 font-semibold js-durability"></span>
            </div>
            <div class="flex flex-wrap gap-1.5 text-[10px] js-bonuses"></div>
        </div>
        <div class="border-t border-gray-800/80 pt-3 space-y-1 js-footer-info">
            <div class="flex justify-between text-[11px] text-gray-500 pb-1 border-b border-gray-800/40">
                <span>{{ 'marketplace.col_seller'|trans }}: <span class="text-gray-300 font-medium js-seller-name"></span></span>
                <span class="text-red-400 font-semibold js-time-remaining"></span>
