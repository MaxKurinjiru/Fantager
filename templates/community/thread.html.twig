{% extends 'layouts/game.html.twig' %}

{% block title %}{{ thread.title }} — {{ 'nav.community'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="community-thread-page page-shell" data-controller="community-thread"
     data-community-thread-thread-id-value="{{ thread.id }}"
     data-community-thread-is-locked-value="{{ thread.isLocked ? 'true' : 'false' }}"
     data-community-thread-translations-value="{{ {
         'warning_fill_fields': 'community.warning_fill_fields'|trans,
         'text_sending': 'community.text_sending'|trans,
         'error_send_reply': 'community.error_send_reply'|trans,
         'post_reply': 'community.post_reply'|trans,
         'btn_unlock': 'community.btn_unlock'|trans,
         'btn_lock': 'community.btn_lock'|trans,
         'error_toggle_lock': 'community.error_toggle_lock'|trans,
         'locked': 'community.locked'|trans
     }|json_encode|e('html_attr') }}"
>
    <nav class="forum-detail-nav" aria-label="{{ 'community.back_to_threads'|trans }}">
        <a href="{{ path('app_community', active_category != 'all' ? { category: active_category } : {}) }}"
           class="back-link">
            ⬅️ {{ 'community.back_to_threads'|trans }}
        </a>
    </nav>

    {% include 'components/ui/alert_box.html.twig' with {
        target: 'community-thread',
        message_target: 'alertMessage',
        close_action: 'community-thread#hideAlert'
    } %}

    <header class="thread-detail-header game-panel">
        <div class="thread-detail-header__body">
            <div class="thread-detail-header__badges">
                {% if thread.isPinned %}
                    <span class="category-badge category-badge--accent">📌 {{ 'community.pinned'|trans }}</span>
                {% endif %}
                <span class="category-badge">{{ ('community.category_' ~ thread.category)|trans }}</span>
                {% if thread.isLocked %}
                    <span class="lock-badge" data-community-thread-target="lockBadge">🔒 {{ 'community.locked'|trans }}</span>
                {% else %}
                    <span class="lock-badge hidden" data-community-thread-target="lockBadge">🔒 {{ 'community.locked'|trans }}</span>
                {% endif %}
            </div>
            <h1 class="thread-detail-header__title">{{ thread.title }}</h1>
            <p class="thread-detail-header__meta">
                {% if thread.authorTeam %}
                    <span class="thread-detail-header__emblem">{{ thread.authorTeam.emblem ?: '🛡️' }}</span>
                    {{ thread.authorUser.displayName }} · {{ thread.authorTeam.name }}
                {% else %}
                    <span class="thread-detail-header__emblem">👤</span>
                    {{ thread.authorUser.displayName }}
                {% endif %}
                · {{ 'community.started_at'|trans }} {{ thread.createdAt|date('d. m. Y H:i') }}
            </p>
        </div>

        {% if is_author %}
            <div class="thread-detail-header__actions">
                <button type="button"
                        data-community-thread-target="lockBtn"
                        data-action="click->community-thread#toggleLock"
                        class="btn btn-outline btn--sm">
                    {% if thread.isLocked %}
                        🔓 {{ 'community.btn_unlock'|trans }}
                    {% else %}
                        🔒 {{ 'community.btn_lock'|trans }}
                    {% endif %}
                </button>
            </div>
        {% endif %}
    </header>

    {% if original_post %}
        {% include 'components/community/forum_post.html.twig' with {
            post: original_post,
            is_original: true
        } %}
    {% endif %}

    {% if replies is not empty %}
        <section class="forum-replies">
            <h2 class="forum-replies__title">
                {{ 'community.replies_heading'|trans({'%count%': replies|length}) }}
            </h2>
            {% for post in replies %}
                {% include 'components/community/forum_post.html.twig' with { post: post } %}
            {% endfor %}
        </section>
    {% endif %}

    <div data-community-thread-target="replyFormContainer"
         class="forum-reply-form game-panel{% if thread.isLocked %} hidden{% endif %}">
        <label for="reply-body" class="form-label">{{ 'community.add_reply'|trans }}</label>
        <textarea id="reply-body"
                  data-community-thread-target="replyInput"
                  class="form-input"
                  rows="4"
                  placeholder="{{ 'community.reply_placeholder'|trans }}"
                  required></textarea>
        <div class="forum-reply-form__actions">
            <button type="button"
                    data-community-thread-target="submitReplyBtn"
                    data-action="click->community-thread#submitReply"
                    class="btn btn-primary">
                {{ 'community.post_reply'|trans }}
            </button>
        </div>
    </div>

    {% if thread.isLocked %}
        <div class="forum-locked-notice game-panel" data-community-thread-target="lockedNotice">
            <p>{{ 'community.thread_locked_notice'|trans }}</p>
        </div>
    {% else %}
        <div class="forum-locked-notice game-panel hidden" data-community-thread-target="lockedNotice">
            <p>{{ 'community.thread_locked_notice'|trans }}</p>
        </div>
    {% endif %}
</div>
{% endblock %}
