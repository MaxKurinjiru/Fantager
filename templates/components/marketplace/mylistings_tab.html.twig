{# templates/components/marketplace/mylistings_tab.html.twig #}
<div data-marketplace-target="tabContent" data-tab-name="mylistings" class="space-y-6 hidden">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-xl overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                    <th class="py-3 px-4">{{ 'marketplace.col_entity'|trans }}</th>
                    <th class="py-3 px-4">{{ 'marketplace.col_type_mode'|trans }}</th>
                    <th class="py-3 px-4">{{ 'marketplace.col_base_price'|trans }}</th>
                    <th class="py-3 px-4">{{ 'marketplace.label_highest_bid'|trans }}</th>
                    <th class="py-3 px-4">{{ 'marketplace.label_expires'|trans }}</th>
                    <th class="py-3 px-4">{{ 'marketplace.col_status'|trans }}</th>
                    <th class="py-3 px-4 text-right">{{ 'marketplace.col_actions'|trans }}</th>
                </tr>
            </thead>
            <tbody data-marketplace-target="myListingsContainer">
                {# AJAX Loaded list #}
                <tr>
                    <td colspan="7" class="text-center py-12">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-500 mx-auto"></div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
