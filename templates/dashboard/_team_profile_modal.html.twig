<div data-controller="modal" data-modal-event-name-value="modal:open-team-profile">
    {# Modal backdrop/dialog — uses .modal-overlay + .modal-box atoms per ui-guidelines §5.1 #}
    <div data-modal-target="dialog"
         class="hidden modal-overlay"
         data-action="click->modal#closeBackdrop">

         <div class="modal-box relative flex flex-col"
              role="dialog"
              aria-modal="true"
              aria-labelledby="team-profile-title">

              {# Close button — §5.1.1 standard close button #}
              <button type="button"
                      data-action="click->modal#close"
                      class="modal-close"
                      aria-label="{{ 'modal.close'|trans }}">
                  <span aria-hidden="true" class="text-xl leading-none">✕</span>
                  <span class="sr-only">{{ 'modal.close'|trans }}</span>
              </button>

              {# Title #}
              <h2 id="team-profile-title" class="text-xl font-bold text-text-primary px-6 pt-6 mb-4 border-b border-border pb-3 flex items-center gap-2">
                  <span>🛡️</span> {{ 'team_profile.title'|trans }}
              </h2>

              <div class="space-y-6 overflow-y-auto flex-1 px-6 pb-6" data-controller="profile-settings"
                   data-profile-settings-team-id-value="{{ team.id }}"
                   data-profile-settings-text-saving-value="{{ 'js_flash.team_profile.saving'|trans }}"
                   data-profile-settings-error-save-value="{{ 'js_flash.team_profile.failed'|trans }}"
                   data-profile-settings-success-save-value="{{ 'js_flash.team_profile.success'|trans }}"
              >
                  {# Success and Error Alerts #}
                  {% include 'components/ui/alert_box.html.twig' with {
                      target: 'profile-settings',
                      message_target: 'alertMessage',
                      close_action: 'profile-settings#closeAlert',
                      classes: 'mb-4 text-sm'
                  } %}

                  <form data-action="submit->profile-settings#save" class="space-y-5">
                      {# Team Name #}
                      <div class="mb-4">
                          <label for="settings_name" class="form-label">{{ 'team_profile.name'|trans }}</label>
                          <input type="text" id="settings_name" name="name" required maxlength="100"
                                 value="{{ team.name }}"
                                 class="form-input">
                      </div>

                      {# Emblem emoji picker #}
                      <div class="mb-4">
                          <label class="form-label">{{ 'team_profile.emblem'|trans }}</label>
                          <div class="flex items-center gap-4">
                              <div data-profile-settings-target="emblemPreview"
                                   class="w-16 h-16 rounded-xl border border-border flex items-center justify-center text-3xl shadow-inner select-none shrink-0 bg-surface-base">
                                  {{ team.emblem ?: '🛡️' }}
                              </div>
                              <div class="flex-1">
                                  <input type="hidden" id="settings_emblem" name="emblem" value="{{ team.emblem ?: '🛡️' }}">
                                  <div class="grid grid-cols-8 gap-1 p-2 rounded-lg border border-border bg-surface-base">
                                      {% for icon in ['🛡️', '⚔️', '🦁', '🐉', '🦅', '🐺', '🦉', '🦊', '🦄', '💀', '🔥', '❄️', '⚡', '🌟', '🔱', '💎'] %}
                                          <button type="button"
                                                  data-action="click->profile-settings#selectEmblem"
                                                  data-emblem="{{ icon }}"
                                                  aria-label="{{ icon }}"
                                                  class="emblem-btn w-8 h-8 flex items-center justify-center text-lg rounded cursor-pointer {{ (team.emblem ?: '🛡️') == icon ? 'emblem-btn--selected' : '' }}">
                                              {{ icon }}
                                          </button>
                                      {% endfor %}
                                  </div>
                              </div>
                          </div>
                      </div>

                      {# Color Options #}
                      <div class="mb-4">
                          <label class="form-label">{{ 'team_profile.colors'|trans }}</label>
                          <div class="grid grid-cols-2 gap-4">
                              {# Primary Color #}
                              <div>
                                  <label for="settings_color_primary" class="form-label">{{ 'team_profile.color_primary'|trans }}</label>
                                  <div class="flex gap-2">
                                      <input type="color" id="settings_color_primary"
                                             data-profile-settings-target="colorPrimaryPicker"
                                             value="{{ team.colors.primary ?? '#10b981' }}"
                                             class="w-10 h-9 rounded border border-border bg-transparent p-0.5 cursor-pointer">
                                      <label for="settings_color_primary_text" class="sr-only">{{ 'team_profile.color_primary'|trans }}</label>
                                      <input type="text"
                                             id="settings_color_primary_text"
                                             data-profile-settings-target="colorPrimaryText"
                                             value="{{ team.colors.primary ?? '#10b981' }}"
                                             class="form-input uppercase">
                                  </div>
                              </div>

                              {# Secondary Color #}
                              <div>
                                  <label for="settings_color_secondary" class="form-label">{{ 'team_profile.color_secondary'|trans }}</label>
                                  <div class="flex gap-2">
                                      <input type="color" id="settings_color_secondary"
                                             data-profile-settings-target="colorSecondaryPicker"
                                             value="{{ team.colors.secondary ?? '#0f1720' }}"
                                             class="w-10 h-9 rounded border border-border bg-transparent p-0.5 cursor-pointer">
                                      <label for="settings_color_secondary_text" class="sr-only">{{ 'team_profile.color_secondary'|trans }}</label>
                                      <input type="text"
                                             id="settings_color_secondary_text"
                                             data-profile-settings-target="colorSecondaryText"
                                             value="{{ team.colors.secondary ?? '#0f1720' }}"
                                             class="form-input uppercase">
                                  </div>
                              </div>
                          </div>
                      </div>

                      {# Submit Button #}
                      <div class="border-t border-border pt-4 flex justify-end">
                          <button type="submit" data-profile-settings-target="submitBtn" class="btn btn-primary">
                              {{ 'team_profile.submit'|trans }}
                          </button>
                      </div>
                  </form>
              </div>
         </div>
    </div>
</div>
