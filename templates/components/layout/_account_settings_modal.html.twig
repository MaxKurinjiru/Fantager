<div data-controller="modal" data-modal-event-name-value="modal:open-account-settings">
    {# Modal backdrop/dialog — uses .modal-overlay + .modal-box atoms per ui-guidelines §5.1 #}
    <div data-modal-target="dialog"
         class="hidden modal-overlay"
         data-action="click->modal#closeBackdrop">

         <div class="modal-box relative flex flex-col max-h-[90vh]"
              role="dialog"
              aria-modal="true"
              aria-labelledby="account-settings-title">

              {# Close button — §5.1.1 standard close button #}
              <button type="button"
                      data-action="click->modal#close"
                      class="modal-close"
                      aria-label="{{ 'modal.close'|trans }}">
                  <span aria-hidden="true" class="text-xl leading-none">✕</span>
                  <span class="sr-only">{{ 'modal.close'|trans }}</span>
              </button>

              {# Title #}
              <h2 id="account-settings-title" class="text-xl font-bold text-text-primary px-6 pt-6 mb-4 border-b border-border pb-3 flex items-center gap-2">
                  <span>⚙️</span> {{ 'settings.title'|trans }}
              </h2>

              <div class="space-y-6 overflow-y-auto flex-1 px-6 pb-6">
                  {# 1. Language Selector #}
                  <div class="space-y-2">
                      <h3 class="text-xs font-semibold text-text-muted uppercase tracking-wider">{{ 'settings.language'|trans }}</h3>
                      <div class="grid grid-cols-2 gap-2">
                          <a href="{{ path('app_change_locale', { locale: 'cs' }) }}"
                             class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg border transition-all text-sm
                                    {{ app.request.locale == 'cs'
                                        ? 'border-brand-500 bg-brand-500/10 text-brand-400 font-bold'
                                        : 'border-border text-text-secondary hover:border-border-strong hover:text-text-primary' }}">
                              Čeština (CS)
                          </a>
                          <a href="{{ path('app_change_locale', { locale: 'en' }) }}"
                             class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg border transition-all text-sm
                                    {{ app.request.locale == 'en'
                                        ? 'border-brand-500 bg-brand-500/10 text-brand-400 font-bold'
                                        : 'border-border text-text-secondary hover:border-border-strong hover:text-text-primary' }}">
                              English (EN)
                          </a>
                      </div>
                  </div>

                  <hr class="border-border" />

                  {# 2. Email Change (with AJAX) #}
                  <div data-controller="account-settings" class="space-y-4"
                       data-account-settings-text-processing-value="{{ 'js_flash.settings.processing'|trans }}"
                       data-account-settings-error-email-value="{{ 'js_flash.settings.failed_email'|trans }}"
                       data-account-settings-error-cancel-value="{{ 'js_flash.settings.failed_cancel'|trans }}"
                  >
                      {# Email Form #}
                      <form data-action="submit->account-settings#changeEmail" class="space-y-3">
                          <h3 class="text-xs font-semibold text-text-muted uppercase tracking-wider">{{ 'settings.email.title'|trans }}</h3>

                          <div class="mb-4">
                              <label for="account_new_email" class="form-label">{{ 'settings.email.label'|trans }}</label>
                              <div class="flex gap-2">
                                  <input type="email" id="account_new_email"
                                         data-account-settings-target="emailInput"
                                         required
                                         placeholder="{{ app.user.email }}"
                                         autocomplete="email"
                                         aria-describedby="account_new_email_error"
                                         class="form-input flex-1">
                                  <button type="submit"
                                          data-account-settings-target="emailSubmitBtn"
                                          class="btn btn-primary btn--sm shrink-0">
                                      {{ 'settings.email.submit'|trans }}
                                  </button>
                              </div>
                          </div>

                          {# Inline Alerts #}
                          <div id="account_new_email_error"
                               data-account-settings-target="emailError"
                               class="hidden alert alert-error"
                               role="alert"></div>
                          <div data-account-settings-target="emailSuccess"
                               class="hidden alert alert-success"
                               role="alert"></div>
                      </form>

                      <hr class="border-border" />

                      {# 3. Cancel Account #}
                      <div class="space-y-3">
                          <h3 class="text-xs font-semibold text-error-text uppercase tracking-wider">{{ 'settings.delete.title'|trans }}</h3>
                          <p class="text-xs text-text-muted">{{ 'settings.delete.warning'|trans }}</p>

                          {# Trigger Button #}
                          <button type="button"
                                  data-action="click->account-settings#showCancelConfirm"
                                  class="btn btn-danger btn--sm w-full">
                              {{ 'settings.delete.btn'|trans }}
                          </button>

                          {# Confirmation Prompt Panel #}
                          <div data-account-settings-target="cancelConfirmPanel"
                               class="hidden cancel-confirm-panel border border-error-border rounded-xl p-4 space-y-3">
                              <p class="text-xs text-error-text font-medium">{{ 'settings.delete.confirm_msg'|trans }}</p>
                              <div class="flex gap-2">
                                  <button type="button"
                                          data-action="click->account-settings#submitCancelAccount"
                                          data-account-settings-target="cancelSubmitBtn"
                                          class="btn btn-danger btn--sm flex-1">
                                      {{ 'settings.delete.confirm_yes'|trans }}
                                  </button>
                                  <button type="button"
                                          data-action="click->account-settings#hideCancelConfirm"
                                          class="btn btn-outline btn--sm flex-1">
                                      {{ 'settings.delete.confirm_no'|trans }}
                                  </button>
                              </div>
                          </div>

                          {# Inline Alerts #}
                          <div data-account-settings-target="cancelError"
                               class="hidden alert alert-error"
                               role="alert"></div>
                          <div data-account-settings-target="cancelSuccess"
                               class="hidden alert alert-success"
                               role="alert"></div>
                      </div>
                  </div>
              </div>
         </div>
    </div>
</div>
