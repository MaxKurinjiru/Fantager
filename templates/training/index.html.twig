{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'training.title'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="space-y-8 max-w-7xl mx-auto" data-controller="training"
     data-training-success-configure-value="{{ 'training.success_configure'|trans }}"
     data-training-success-assign-value="{{ 'training.success_assign'|trans }}"
     data-training-success-unassign-value="{{ 'training.success_unassign'|trans }}"
     data-training-error-fetch-value="{{ 'js_flash.training.error_fetch'|trans }}"
     data-training-error-queue-value="{{ 'js_flash.training.error_queue'|trans }}"
     data-training-error-cancel-value="{{ 'js_flash.training.error_cancel'|trans }}"
     data-training-text-processing-value="{{ 'js_flash.training.text_processing'|trans }}"
     data-training-is-locked-value="{{ isLocked ? 'true' : 'false' }}"
     data-training-text-saving-value="{{ 'js_flash.training.text_saving'|trans }}"
     data-training-text-removing-value="{{ 'js_flash.training.text_removing'|trans }}"
     data-training-error-save-focus-value="{{ 'js_flash.training.error_save_focus'|trans }}"
     data-training-error-assign-hero-value="{{ 'js_flash.training.error_assign_hero'|trans }}"
     data-training-error-remove-hero-value="{{ 'js_flash.training.error_remove_hero'|trans }}"
>
    
    {# --- Header Section --- #}
    {% set right_content %}
        {# --- Next Lock Box --- #}
        <div class="bg-gray-900/60 border border-gray-800 rounded-xl px-4 py-3 backdrop-blur-md text-sm shrink-0 flex items-center gap-3 min-w-[160px]">
            <div>
                <span class="block text-[10px] text-gray-550 uppercase font-bold tracking-wider mb-0.5">{{ 'training.next_lock'|trans }}</span>
                {% if isLocked %}
                    <span class="block text-red-400 font-extrabold text-sm flex items-center gap-1">
                        <span>🔒</span> {{ 'training.locked'|trans }}
                    </span>
                {% else %}
                    <span data-countdown-target="{{ nextLock|date('c') }}" class="block text-yellow-500 font-extrabold text-sm">--h --m --s</span>
                {% endif %}
                <span class="block text-[10px] text-gray-400 mt-1 font-medium">{{ nextLockFormatted }}</span>
            </div>
        </div>

        {# --- Next Evaluation Box --- #}
        <div class="bg-gray-900/60 border border-gray-800 rounded-xl px-4 py-3 backdrop-blur-md text-sm shrink-0 flex items-center gap-3 min-w-[160px]">
            <div>
                <span class="block text-[10px] text-gray-550 uppercase font-bold tracking-wider mb-0.5">{{ 'training.next_evaluation'|trans }}</span>
                <span data-countdown-target="{{ nextTick|date('c') }}" class="block text-white font-extrabold text-sm">--h --m --s</span>
                <span class="block text-[10px] text-gray-400 mt-1 font-medium">{{ nextTickFormatted }}</span>
            </div>
        </div>
    {% endset %}

    {% include 'components/ui/page_header.html.twig' with {
        title: 'training.title',
        subtitle: 'training.subtitle',
        right_content: right_content
    } %}

    {# --- Alert Box --- #}
    {% include 'components/ui/alert_box.html.twig' with {
        target: 'training',
        message_target: 'alertMessage',
        close_action: 'training#hideAlert'
    } %}

    {# --- Lock Warning --- #}
    {% if isLocked %}
        <div class="bg-red-950/40 border border-red-900/50 rounded-2xl p-5 flex items-start gap-4 text-red-200 shadow-md">
            <span class="text-3xl select-none leading-none">🔒</span>
            <div class="space-y-1">
                <h4 class="font-bold text-white text-sm">{{ 'training.lock_warning'|trans }}</h4>
                <p class="text-xs text-red-300/80">{{ 'training.lock_desc'|trans }}</p>
            </div>
        </div>
    {% endif %}

    {# --- Multi-Tab Navigation --- #}
    <div class="flex border-b border-gray-850 gap-2 overflow-x-auto pb-px" data-controller="tab">
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="trainers-tab"
                class="tab-btn tab-btn--active">
            💼 {{ 'training.tab_trainers'|trans }}
        </button>
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch"
                data-tab="active-tab"
                class="tab-btn">
            🏋️ {{ 'training.tab_active'|trans }}
        </button>
    </div>

    {# --- Content: Trainers Tab --- #}
    <div id="trainers-tab" class="tab-content space-y-6">
        <div class="flex items-center justify-between bg-gray-900/20 border border-gray-850 px-6 py-4 rounded-2xl">
            <span class="text-xs font-bold text-gray-400">
                {{ 'training.trainer_limit'|trans({'%count%': trainers|length, '%limit%': trainerLimit}) }}
            </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {% for trainer in trainers %}
                {% include 'components/training/trainer_card.html.twig' with {
                    trainer: trainer,
                    heroes: heroes,
                    isLocked: isLocked
                } %}
            {% else %}
                <div class="text-center py-16 border border-gray-800 border-dashed rounded-2xl opacity-60 w-full col-span-2">
                    <span class="text-5xl block mb-2">📭</span>
                    <h3 class="font-bold text-white">{{ 'training.no_trainers_title'|trans }}</h3>
                    <p class="text-xs text-gray-400">{{ 'training.no_trainers_desc'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# --- Content: Active Trainees Tab --- #}
    <div id="active-tab" class="tab-content hidden space-y-6">
        {% include 'components/training/active_trainees_table.html.twig' with {
            trainers: trainers
        } %}
    </div>

</div>

{% endblock %}
