{# templates/components/dashboard/stats_card.html.twig #}
{% set stats = [
    { label: 'dashboard.total_heroes', value: dashboard.heroes.total },
    { label: 'dashboard.available_heroes', value: dashboard.heroes.available, modifier: 'success' },
    { label: 'dashboard.in_training', value: dashboard.heroes.in_training, modifier: 'warning' },
    { label: 'dashboard.hq_level', value: dashboard.headquarters.total_level },
    { label: 'dashboard.summons_cycle', value: dashboard.summoning.summons_this_cycle }
] %}

<div class="db-stats-card">
    <h3 class="db-stats-card__title">{{ 'dashboard.stats'|trans }}</h3>
    <div class="db-stats-card__list">
        {% for stat in stats %}
            <div class="db-stats-card__row">
                <span class="db-stats-card__label">{{ stat.label|trans }}</span>
                <span class="db-stats-card__value{% if stat.modifier is defined %} db-stats-card__value--{{ stat.modifier }}{% endif %}">{{ stat.value }}</span>
            </div>
        {% endfor %}
    </div>
</div>
