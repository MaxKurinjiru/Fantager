{% set wrapper_class = wrapper_class|default('hero-attr-grid hero-attr-grid--bordered mb-6') %}
{% set attr_keys = [
    { key: 'str', field: 'str' },
    { key: 'dex', field: 'dex' },
    { key: 'kon', field: 'kon' },
    { key: 'spd', field: 'spd' },
    { key: 'int', field: 'intel' },
    { key: 'wil', field: 'wil' },
    { key: 'cha', field: 'cha' },
    { key: 'lck', field: 'lck' },
] %}
<div class="{{ wrapper_class }}">
    {% for attr in attr_keys %}
        <div class="hero-attr-cell">
            <span class="hero-attr-cell__label">{{ ('training.attr.' ~ attr.key)|trans }}</span>
            <span class="hero-attr-cell__value">{{ attribute(hero, attr.field) }}</span>
        </div>
    {% endfor %}
</div>
