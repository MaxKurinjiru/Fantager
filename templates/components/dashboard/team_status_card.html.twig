{# templates/components/dashboard/team_status_card.html.twig #}
{% set label = label|default('') %}
{% set emoji = emoji|default('') %}
{% set value = value|default(0) %}
{% set progress_color = progress_color|default('emerald') %}
{% set desc = desc|default('') %}

<div class="bg-gray-900/60 backdrop-blur-md rounded-xl p-6 border border-gray-800 flex flex-col justify-between">
    <div class="flex justify-between items-center mb-4">
        <span class="text-gray-400 text-sm font-semibold uppercase tracking-wider">{{ label|trans }}</span>
        <span class="text-2xl select-none">{{ emoji }}</span>
    </div>
    <div class="flex items-baseline gap-2 mb-2">
        <span class="text-4xl font-extrabold text-white">{{ value }}</span>
        <span class="text-gray-500 text-sm">/ 100</span>
    </div>
    {% include 'components/ui/progress_bar.html.twig' with {
        percentage: value,
        container_class: 'w-full bg-gray-950 rounded-full h-2.5 overflow-hidden',
        progress_class: 'bg-' ~ progress_color ~ '-500 h-full rounded-full transition-all'
    } %}
    <p class="text-xs text-gray-550 mt-3">{{ desc|trans }}</p>
</div>
