{# templates/components/formation/pitch_grid.html.twig #}
<div class="bg-gradient-to-b from-gray-950 to-gray-900/80 border border-gray-850 p-6 rounded-3xl relative overflow-hidden flex flex-col gap-6 shadow-inner">
    {# Grid midfield line #}
    <div class="absolute inset-x-0 top-1/2 h-0.5 bg-gray-800/40 -translate-y-1/2"></div>
    
    {# BACK LINE ROW (3 Slots) #}
    <div class="space-y-2 relative z-10">
        <span class="block text-[9px] font-extrabold text-gray-650 uppercase tracking-wide text-center">Back Line (Defense / Support)</span>
        <div class="grid grid-cols-3 gap-4">
            {% set back_slots = [
                {pos: 'back_1', label: 'Back Left'},
                {pos: 'back_2', label: 'Back Center'},
                {pos: 'back_3', label: 'Back Right'}
            ] %}
            
            {% for slot in back_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                <div data-formation-target="gridSlot" data-position="{{ slot.pos }}" data-hero-id="{{ hero ? hero.id : '' }}"
                     class="bg-gray-950/60 border border-gray-850 rounded-2xl p-3 flex flex-col justify-between items-center text-center min-h-[140px] shadow-sm relative">
                    <span class="text-[9px] font-extrabold text-gray-550 uppercase tracking-wider mb-2">{{ slot.label }}</span>
                    
                    {# Empty Slot Quick Select #}
                    <div data-empty-view class="w-full space-y-2 {% if hero %}hidden{% endif %}">
                        <span class="text-2xl block select-none opacity-40">🛡️</span>
                        <select data-quick-select data-action="change->formation#quickAssign" data-position="{{ slot.pos }}"
                                class="w-full rounded bg-gray-900 border border-gray-800 text-[10px] text-gray-400 p-1 select-none focus:outline-none focus:border-emerald-500">
                            <option value="">-- Assign --</option>
                            {% for h in heroes %}
                                <option value="{{ h.id }}">{{ h.name }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Occupied View #}
                    <div data-occupied-view class="w-full h-full flex flex-col justify-between items-center relative {% if not hero %}hidden{% endif %}">
                        <button data-action="click->formation#removeHero" data-position="{{ slot.pos }}"
                                class="absolute -right-1 -top-1 w-5 h-5 bg-red-950/40 hover:bg-red-900 border border-red-900/30 text-red-400 hover:text-white rounded-full flex items-center justify-center text-[8px] font-extrabold transition-colors">
                            ✕
                        </button>
                        <span class="text-3xl mb-1 select-none">👤</span>
                        <h4 data-hero-name class="text-xs font-bold text-gray-250 truncate w-full">{{ hero ? hero.name : '' }}</h4>
                        <p data-hero-details class="text-[9px] text-gray-555">{{ hero ? 'Lvl ' ~ hero.level ~ ' ' ~ hero.race.value|capitalize : '' }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    {# FRONT LINE ROW (3 Slots) #}
    <div class="space-y-2 relative z-10">
        <span class="block text-[9px] font-extrabold text-gray-655 uppercase tracking-wide text-center">Front Line (Attack / Offense)</span>
        <div class="grid grid-cols-3 gap-4">
            {% set front_slots = [
                {pos: 'front_1', label: 'Front Left'},
                {pos: 'front_2', label: 'Front Center'},
                {pos: 'front_3', label: 'Front Right'}
            ] %}
            
            {% for slot in front_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                <div data-formation-target="gridSlot" data-position="{{ slot.pos }}" data-hero-id="{{ hero ? hero.id : '' }}"
                     class="bg-gray-950/60 border border-gray-850 rounded-2xl p-3 flex flex-col justify-between items-center text-center min-h-[140px] shadow-sm relative">
                    <span class="text-[9px] font-extrabold text-gray-555 uppercase tracking-wider mb-2">{{ slot.label }}</span>
                    
                    {# Empty Slot Quick Select #}
                    <div data-empty-view class="w-full space-y-2 {% if hero %}hidden{% endif %}">
                        <span class="text-2xl block select-none opacity-40">⚔️</span>
                        <select data-quick-select data-action="change->formation#quickAssign" data-position="{{ slot.pos }}"
                                class="w-full rounded bg-gray-900 border border-gray-800 text-[10px] text-gray-400 p-1 select-none focus:outline-none focus:border-emerald-500">
                            <option value="">-- Assign --</option>
                            {% for h in heroes %}
                                <option value="{{ h.id }}">{{ h.name }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Occupied View #}
                    <div data-occupied-view class="w-full h-full flex flex-col justify-between items-center relative {% if not hero %}hidden{% endif %}">
                        <button data-action="click->formation#removeHero" data-position="{{ slot.pos }}"
                                class="absolute -right-1 -top-1 w-5 h-5 bg-red-950/40 hover:bg-red-900 border border-red-900/30 text-red-400 hover:text-white rounded-full flex items-center justify-center text-[8px] font-extrabold transition-colors">
                            ✕
                        </button>
                        <span class="text-3xl mb-1 select-none">👤</span>
                        <h4 data-hero-name class="text-xs font-bold text-gray-250 truncate w-full">{{ hero ? hero.name : '' }}</h4>
                        <p data-hero-details class="text-[9px] text-gray-555">{{ hero ? 'Lvl ' ~ hero.level ~ ' ' ~ hero.race.value|capitalize : '' }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
