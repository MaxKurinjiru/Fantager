{# templates/components/formation/pitch_grid.html.twig #}
<div class="formation-pitch-board">
    <div class="formation-pitch-board__midline" aria-hidden="true"></div>

    {# FRONT LINE ROW (3 Slots) — closer to opponent / top of pitch #}
    <div class="layout-stack layout-stack--sm formation-pitch-board__row">
        <span class="formation-pitch-board__line-label">{{ 'formation.front_line'|trans }}</span>
        <div class="formation-pitch">
            {% set front_slots = [
                {pos: 'front_1'},
                {pos: 'front_2'},
                {pos: 'front_3'}
            ] %}

            {% for slot in front_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                {% include 'components/formation/pitch_slot.html.twig' with {
                    slot: slot,
                    hero: hero,
                    default_emoji: '⚔️',
                    title_class: 'formation-slot__pos-label',
                    heroes: heroes
                } %}
            {% endfor %}
        </div>
    </div>

    {# BACK LINE ROW (3 Slots) — defense / bottom of pitch #}
    <div class="layout-stack layout-stack--sm formation-pitch-board__row">
        <span class="formation-pitch-board__line-label">{{ 'formation.back_line'|trans }}</span>
        <div class="formation-pitch">
            {% set back_slots = [
                {pos: 'back_1'},
                {pos: 'back_2'},
                {pos: 'back_3'}
            ] %}

            {% for slot in back_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                {% include 'components/formation/pitch_slot.html.twig' with {
                    slot: slot,
                    hero: hero,
                    default_emoji: '🛡️',
                    title_class: 'formation-slot__pos-label',
                    heroes: heroes
                } %}
            {% endfor %}
        </div>
    </div>
</div>
