{# templates/components/training/magic_tab.html.twig #}
<div id="magic-tab" class="tab-content hidden space-y-6">
    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 md:p-8 backdrop-blur-md max-w-2xl mx-auto text-center space-y-6">
        <span class="text-6xl block select-none">🔮</span>
        <div class="space-y-2">
            <h2 class="text-2xl font-bold text-white">{{ 'training.expand_capacity_title'|trans }}</h2>
            <p class="text-gray-400 text-sm max-w-md mx-auto">{{ 'training.expand_capacity_desc'|trans }}</p>
        </div>
        
        <div class="flex flex-col items-center gap-3">
            <span data-training-target="magicCost" class="text-sm font-extrabold text-yellow-500">{{ 'training.cost_select_hero'|trans }}</span>
            <button data-training-target="magicBtn" data-training-btn data-action="click->training#startMagicTraining" disabled
                    class="btn btn-primary px-8 py-3.5 uppercase font-bold tracking-wider text-xs shadow-lg shadow-emerald-950/20 disabled:bg-gray-800 disabled:text-gray-500 disabled:cursor-not-allowed">
                {{ 'training.expand_btn'|trans }}
            </button>
        </div>
    </div>
</div>
