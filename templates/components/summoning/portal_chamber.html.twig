{# templates/components/summoning/portal_chamber.html.twig #}
<div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 backdrop-blur-md shadow-lg min-h-[400px] flex flex-col items-center justify-center relative overflow-hidden">
    {# Portal background glow #}
    <div class="absolute inset-0 bg-radial-gradient from-emerald-500/5 to-transparent pointer-events-none"></div>

    {# Default state: Idle #}
    <div data-summoning-target="chamberState" class="text-center p-8 space-y-4">
        <span class="text-6xl animate-pulse block select-none">🔮</span>
        <h2 class="text-xl font-bold text-white">{{ 'summoning.portal_title'|trans }}</h2>
        <p class="text-xs text-gray-550 max-w-[250px] mx-auto">{{ 'summoning.portal_desc'|trans }}</p>
    </div>

    {# Portal state: Loading / Channeling #}
    <div data-summoning-target="portal" class="hidden text-center space-y-6 relative z-10">
        <div class="relative w-32 h-32 mx-auto flex items-center justify-center">
            {# Magic Summoning Circle SVG Spinner #}
            <svg class="animate-spin text-emerald-400 w-full h-full" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-15" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"></circle>
                <path class="opacity-80" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="absolute text-4xl select-none animate-ping">🌀</span>
        </div>
        <div class="space-y-1">
            <h3 class="font-extrabold text-white text-lg">{{ 'summoning.portal_channeling'|trans }}</h3>
            <p class="text-xs text-gray-400">{{ 'summoning.portal_channeling_desc'|trans }}</p>
        </div>
    </div>

    {# Portal state: Reveal Hero Card #}
    <div data-summoning-target="reveal" class="hidden w-full text-center space-y-6 relative z-10 animate-fade-in">
        <div class="bg-gray-950 border border-emerald-500/30 rounded-2xl p-5 shadow-2xl relative">
            <div class="absolute -right-2 -top-2 bg-emerald-500 text-gray-950 text-[9px] font-extrabold uppercase px-2.5 py-0.5 rounded shadow-lg">{{ 'summoning.new_recruit'|trans }}</div>
            
            {# Hero Details Card #}
            <div class="w-20 h-20 mx-auto rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center text-4xl mb-4 select-none">
                👤
            </div>
            <h3 data-summoning-target="heroName" class="text-xl font-extrabold text-white mb-0.5">---</h3>
            <p class="text-xs font-semibold text-emerald-400 flex items-center justify-center gap-1.5 mb-1">
                <span>👤</span>
                <span data-summoning-target="heroRace">Race</span>
            </p>
            <p data-summoning-target="heroLevel" class="text-[10px] text-gray-500 uppercase font-bold tracking-wider mb-4">{{ 'heroes.level'|trans }} 1</p>
            
            {# Attributes Grid #}
            <div data-summoning-target="heroStats" class="grid grid-cols-4 gap-2 text-xs border-t border-gray-900 pt-4">
                {# JavaScript injected #}
            </div>
        </div>

        <div class="flex gap-3 justify-center">
            <a id="inspect-summoned" href="#" class="btn btn-primary btn--sm flex-1">
                {{ 'summoning.inspect_details'|trans }}
            </a>
            <button onclick="window.location.reload()" class="btn btn-outline btn--sm flex-1">
                {{ 'summoning.summon_again'|trans }}
            </button>
        </div>
    </div>
</div>
