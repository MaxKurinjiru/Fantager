{% set phase = hero_age_phase(hero) %}
{% set p_icon = hero_age_phase_icon(hero) %}

<div data-roster-filter-target="card"
     data-name="{{ hero.name|lower }}"
     data-race="{{ hero.race.value }}"
     data-status="{{ hero.status.value }}"
     data-level="{{ hero.level }}"
     data-age="{{ hero.age }}"
     data-morale="{{ hero.morale }}"
     data-form="{{ hero.form }}"
     data-str="{{ hero.str }}"
     data-dex="{{ hero.dex }}"
     data-kon="{{ hero.kon }}"
     data-spd="{{ hero.spd }}"
     data-int="{{ hero.intel }}"
     class="hero-card">
    
    <div>
        {# Card Header #}
        <div class="hero-card__header">
            <div class="flex items-center gap-3">
                {% include 'components/hero/avatar.html.twig' with { race: hero.race } %}
                <div>
                    <h3 class="font-bold text-white leading-tight hover:text-emerald-400">
                        <a href="{{ path('app_heroes_detail', {id: hero.id}) }}">{{ hero.name }}</a>
                    </h3>
                    <p class="hero-card__meta">{{ 'heroes.level'|trans }} {{ hero.level }} &bull; {{ ('heroes.race_' ~ hero.race.value)|trans }}</p>
                </div>
            </div>
        </div>

        {# Secondary Attributes List #}
        <div class="hero-stats-box">
            <div>
                <span class="hero-attr-cell__label">{{ 'heroes.age'|trans }}</span>
                <span class="hero-attr-cell__value" title="{{ 'heroes.age_phase.phase'|trans({'%phase%': ('heroes.age_phase.' ~ phase|lower)|trans}) }}">{{ hero.age }} {{ p_icon }}</span>
            </div>
            <div>
                <span class="hero-attr-cell__label" title="{{ 'heroes.combat_form'|trans }}">{{ 'heroes.combat_form_short'|trans }}</span>
                <span class="hero-attr-cell__value">{{ hero.form }}%</span>
            </div>
            <div>
                <span class="hero-attr-cell__label" title="{{ 'heroes.fatigue'|trans }}">{{ 'heroes.fatigue_short'|trans }}</span>
                <span class="hero-attr-cell__value">{{ hero.fatigue }}%</span>
            </div>
        </div>

        {# Attributes Grid #}
        {% include 'components/hero/compact_attributes.html.twig' with { hero: hero } %}
    </div>

    {# Actions #}
    <div class="hero-card__actions">
        <a href="{{ path('app_heroes_detail', {id: hero.id}) }}" class="btn btn-outline btn--sm flex-1">
            {{ 'heroes.inspect'|trans }}
        </a>
        {% include 'components/hero/status_badge.html.twig' with { status: hero.status } %}
    </div>
</div>
