{#
  Auth modal — login and register panels with JS-controlled tab switching.
  Included in base.html.twig for all unauthenticated users.

  Variables resolved with fallbacks so the modal works on any page:
    - error / last_username  → passed by AuthController on /login error
    - errors / form_data     → passed by RegisterController on /register error
    - kingdoms               → passed by RegisterController; otherwise loaded via auth_kingdoms()
#}
{% if not app.user %}

{# Resolve variables with safe fallbacks #}
{% set modal_error         = error         is defined ? error         : null %}
{% set modal_last_username = last_username is defined ? last_username : ''   %}
{% set modal_errors        = errors        is defined ? errors        : {}   %}
{% set modal_form_data     = form_data     is defined ? form_data     : {}   %}
{% if kingdoms is defined %}
    {% set modal_kingdoms = kingdoms %}
{% else %}
    {% set modal_kingdoms = auth_kingdoms() %}
{% endif %}

{# ── Overlay backdrop ──────────────────────────────────────────────────── #}
<div data-auth-modal-target="overlay"
    data-action="click->auth-modal#closeOverlay"
    class="hidden modal-overlay"
    aria-hidden="true">

    {# ── Modal box ─────────────────────────────────────────────────────── #}
        <div class="modal-box"
            role="dialog" aria-modal="true" aria-labelledby="auth-modal-title" tabindex="-1">

        {# Close button #}
        <button type="button"
            data-action="click->auth-modal#close"
            class="modal-close"
            aria-label="{{ 'modal.close'|trans }}">
            <span aria-hidden="true" class="text-xl leading-none">✕</span>
            <span class="sr-only">{{ 'modal.close'|trans }}</span>
        </button>

        {# ══════════════════════════════════════════════════════════════════
           LOGIN PANEL
           ══════════════════════════════════════════════════════════════════ #}
        <div data-auth-modal-target="loginPanel" class="p-8">
            <h2 id="auth-modal-title" class="text-2xl font-bold text-brand-400 mb-6">{{ 'auth.login_title'|trans }}</h2>

            {% if modal_error %}
                <div class="alert alert-error" role="alert">
                    {{ modal_error.messageKey|trans(modal_error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="POST" action="{{ path('app_login') }}" class="space-y-3 sm:space-y-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-3 sm:mb-4">
                    <label for="modal_email" class="form-label">{{ 'auth.email'|trans }}</label>
                    <input type="email" id="modal_email" name="_username"
                           value="{{ modal_last_username }}" required autofocus
                           autocomplete="email"
                           class="form-input">
                </div>

                <div class="mb-3 sm:mb-4">
                    <label for="modal_password" class="form-label">{{ 'auth.password'|trans }}</label>
                    <div class="relative">
                        <input type="password" id="modal_password" name="_password" required
                               autocomplete="current-password"
                               class="form-input pr-10">
                        <button type="button"
                                data-action="click->auth-modal#togglePassword"
                                data-input-id="modal_password"
                                class="password-toggle-btn"
                                aria-label="Toggle password visibility">
                            <svg class="eye-open w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            <svg class="eye-closed w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="form-check mb-3 sm:mb-4">
                    <input type="checkbox" id="modal_remember_me" name="_remember_me" value="on" class="rounded">
                    <label for="modal_remember_me">{{ 'auth.remember_me'|trans }}</label>
                </div>

                <button type="submit" class="btn btn-primary w-full">
                    {{ 'auth.submit_login'|trans }}
                </button>
            </form>

            <div class="mt-4 text-sm text-text-muted space-y-1">
                <p>
                    <button type="button"
                        data-action="click->auth-modal#switchToRegister"
                        class="btn btn-ghost">
                        {{ 'auth.switch_to_register'|trans }}
                    </button>
                </p>
                <p>
                    <a href="{{ path('app_password_reset') }}">
                        {{ 'auth.forgot_password'|trans }}
                    </a>
                </p>
            </div>
        </div>

        {# ══════════════════════════════════════════════════════════════════
           REGISTER PANEL
           ══════════════════════════════════════════════════════════════════ #}
        <div data-auth-modal-target="registerPanel" class="hidden p-8">
            <h2 id="auth-modal-title-register" class="text-2xl font-bold text-brand-400 mb-4 sm:mb-6">{{ 'auth.register_title'|trans }}</h2>

            <form method="POST" action="{{ path('app_register') }}" class="space-y-3 sm:space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('register') }}">

                {# Email #}
                <div class="mb-3 sm:mb-4">
                    <label for="modal_reg_email" class="form-label">{{ 'auth.email'|trans }}</label>
                    <input type="email" id="modal_reg_email" name="email" required maxlength="180"
                           value="{{ modal_form_data.email ?? '' }}"
                           autocomplete="email"
                           class="form-input {{ modal_errors.email is defined ? 'form-input--error' : '' }}"
                           {% if modal_errors.email is defined %}aria-describedby="modal-reg-email-error"{% endif %}>
                    {% if modal_errors.email is defined %}
                        <p id="modal-reg-email-error" class="form-error" role="alert">{{ modal_errors.email|trans([], 'validators') }}</p>
                    {% endif %}
                </div>

                {# Password #}
                <div class="mb-3 sm:mb-4">
                    <label for="modal_reg_password" class="form-label">
                        {{ 'auth.password'|trans }}
                        <span class="text-text-muted">{{ 'auth.password_hint'|trans }}</span>
                    </label>
                    <div class="relative">
                        <input type="password" id="modal_reg_password" name="password" required minlength="8" maxlength="4096"
                               autocomplete="new-password"
                               class="form-input pr-10 {{ modal_errors.password is defined ? 'form-input--error' : '' }}"
                               {% if modal_errors.password is defined %}aria-describedby="modal-reg-password-error"{% endif %}>
                        <button type="button"
                                data-action="click->auth-modal#togglePassword"
                                data-input-id="modal_reg_password"
                                class="password-toggle-btn"
                                aria-label="Toggle password visibility">
                            <svg class="eye-open w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            <svg class="eye-closed w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                            </svg>
                        </button>
                    </div>
                    {% if modal_errors.password is defined %}
                        <p id="modal-reg-password-error" class="form-error" role="alert">{{ modal_errors.password|trans([], 'validators') }}</p>
                    {% endif %}
                </div>

                {# Nickname #}
                <div class="mb-3 sm:mb-4">
                    <label for="modal_display_name" class="form-label">{{ 'auth.display_name'|trans }}</label>
                    <input type="text" id="modal_display_name" name="display_name" required maxlength="50"
                           value="{{ modal_form_data.display_name ?? '' }}"
                           class="form-input {{ modal_errors.display_name is defined ? 'form-input--error' : '' }}"
                           {% if modal_errors.display_name is defined %}aria-describedby="modal-reg-name-error"{% endif %}>
                    {% if modal_errors.display_name is defined %}
                        <p id="modal-reg-name-error" class="form-error" role="alert">{{ modal_errors.display_name|trans([], 'validators') }}</p>
                    {% endif %}
                </div>

                {# Kingdom selection #}
                <div class="mb-3 sm:mb-4">
                    <label class="form-label">
                        {{ 'auth.choose_kingdom'|trans }}
                        <span class="text-text-muted">{{ 'auth.kingdom_permanent_warn'|trans }}</span>
                    </label>
                    {% if modal_errors.kingdom is defined %}
                        <p class="form-error" role="alert">{{ modal_errors.kingdom|trans([], 'validators') }}</p>
                    {% endif %}

                    {% if modal_kingdoms is empty %}
                        <div class="alert alert-warning" role="alert">{{ 'auth.kingdom_no_available'|trans }}</div>
                        <input type="hidden" name="kingdom_id" value="0">
                    {% else %}
                        {# Compact mobile select dropdown #}
                        <div class="block sm:hidden mb-2">
                            <select name="kingdom_id" class="form-input" data-action="change->auth-modal#syncKingdomSelect">
                                <option value="" disabled {{ (modal_form_data.kingdom_id ?? 0) == 0 ? 'selected' : '' }}>
                                    {{ 'auth.choose_kingdom'|trans }}
                                </option>
                                {% for entry in modal_kingdoms %}
                                    {% set k    = entry.kingdom %}
                                    {% set full = entry.capacity > 0 and entry.playerCount >= entry.capacity %}
                                    <option value="{{ k.id }}"
                                            {{ full ? 'disabled' : '' }}
                                            {{ (modal_form_data.kingdom_id ?? 0) == k.id ? 'selected' : '' }}>
                                        {{ k.name }} ({{ k.language }} &bull; {{ k.gameSpeed }}x &bull; {{ entry.playerCount }}{% if entry.capacity > 0 %}/{{ entry.capacity }}{% endif %})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        {# Detailed desktop radio cards #}
                        <div class="hidden sm:block space-y-2">
                            {% for entry in modal_kingdoms %}
                                {% set k    = entry.kingdom %}
                                {% set full = entry.capacity > 0 and entry.playerCount >= entry.capacity %}
                                <label class="flex items-start gap-3 p-3 rounded border cursor-pointer
                                              {{ full ? 'border-border opacity-50 cursor-not-allowed' : 'border-border-strong hover:border-brand-400' }}
                                              {{ (modal_form_data.kingdom_id ?? 0) == k.id ? 'border-brand-400' : '' }}">
                                    <input type="radio" name="kingdom_id" value="{{ k.id }}"
                                           {{ full ? 'disabled' : '' }}
                                           {{ (modal_form_data.kingdom_id ?? 0) == k.id ? 'checked' : '' }}
                                           data-action="change->auth-modal#syncKingdomRadio"
                                           class="mt-1 accent-brand-400">
                                    <div>
                                        <div class="font-semibold text-text-primary">{{ k.name }}</div>
                                        <div class="text-xs text-text-muted">
                                            {{ 'auth.kingdom_language'|trans }} {{ k.language }} &bull;
                                            {{ 'auth.kingdom_speed'|trans }} {{ k.gameSpeed }}x &bull;
                                            {{ 'auth.kingdom_season'|trans }} {{ k.seasonLength }} {{ 'auth.kingdom_days'|trans }} &bull;
                                            {{ 'auth.kingdom_players'|trans }} {{ entry.playerCount }}{% if entry.capacity > 0 %}/{{ entry.capacity }}{% endif %}
                                            {% if full %}&bull; <span class="text-error-text">{{ 'auth.kingdom_full'|trans }}</span>{% endif %}
                                        </div>
                                    </div>
                                </label>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <button type="submit" class="btn btn-primary w-full">
                    {{ 'auth.submit_register'|trans }}
                </button>
            </form>

            <p class="mt-4 text-sm text-text-muted">
                <button type="button"
                    data-action="click->auth-modal#switchToLogin"
                    class="btn btn-ghost">
                    {{ 'auth.switch_to_login'|trans }}
                </button>
            </p>
        </div>

    </div>{# /modal box #}
</div>{# /overlay #}

{% endif %}
