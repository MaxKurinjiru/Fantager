{# templates/components/formation/pitch_slot.html.twig #}
{% set slot = slot|default(null) %}
{% set hero = hero|default(null) %}
{% set default_emoji = default_emoji|default('👤') %}
{% set title_class = title_class|default('formation-slot__pos-label') %}
{% set heroes = heroes|default([]) %}

<div data-formation-target="gridSlot" data-position="{{ slot.pos }}" data-hero-id="{{ hero ? hero.id : '' }}"
     class="formation-slot">
    <span class="{{ title_class }}">{{ ('formation.slots.' ~ slot.pos)|trans }}</span>
    
    {# Empty Slot Quick Select #}
    <div data-empty-view class="w-full space-y-2 {% if hero %}hidden{% endif %}">
        <span class="text-2xl block select-none opacity-40">{{ default_emoji }}</span>
        <select data-quick-select data-action="change->formation#quickAssign" data-position="{{ slot.pos }}"
                class="form-input formation-slot__quick-select">
            <option value="">-- {{ 'formation.assign'|trans }} --</option>
            {% for h in heroes %}
                <option value="{{ h.id }}">{{ h.name }}</option>
            {% endfor %}
        </select>
    </div>

    {# Occupied View #}
    <div data-occupied-view class="w-full h-full flex flex-col justify-between items-center relative {% if not hero %}hidden{% endif %}">
        <button type="button"
                data-action="click->formation#removeHero" data-position="{{ slot.pos }}"
                class="formation-slot__remove-btn"
                aria-label="{{ 'formation.delete_btn'|trans }}">
            <span aria-hidden="true">✕</span>
        </button>
        <span class="text-3xl mb-1 select-none">👤</span>
        <h4 data-hero-name class="formation-slot__hero-name">{{ hero ? hero.name : '' }}</h4>
        <p data-hero-details class="formation-slot__hero-details">{{ hero ? 'js_flash.hq.lvl_short'|trans ~ ' ' ~ hero.level ~ ' ' ~ ('heroes.race_' ~ hero.race.value)|trans : '' }}</p>
    </div>
</div>
