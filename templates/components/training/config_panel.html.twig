{# templates/components/training/config_panel.html.twig #}
<div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 backdrop-blur-md shadow-lg grid grid-cols-1 md:grid-cols-2 gap-6">
    {# Hero Selection #}
    <div class="space-y-2">
        <label for="hero-select" class="form-label">{{ 'training.select_trainee'|trans }}</label>
        <select id="hero-select" data-training-target="heroSelect" data-action="change->training#loadHeroOptions"
                class="form-input font-medium">
            <option value="">{{ 'training.choose_trainee_opt'|trans }}</option>
            {% for hero in heroes %}
                {% if hero.status.value != 'dead' %}
                    <option value="{{ hero.id }}" {% if app.request.query.get('hero_id') == hero.id %}selected{% endif %}>
                        {{ 'heroes.level'|trans }} {{ hero.level }} &bull; {{ hero.name }} ({{ hero.race.value|capitalize }}) - [{{ 'heroes.status_condition'|trans }}: {{ ('heroes.status_' ~ hero.status.value)|trans }}]
                    </option>
                {% endif %}
            {% endfor %}
        </select>
    </div>

    {# Trainer Selection #}
    <div class="space-y-2">
        <label for="trainer-select" class="form-label">{{ 'training.assign_trainer'|trans }}</label>
        <select id="trainer-select" data-training-target="trainerSelect" data-action="change->training#loadHeroOptions"
                class="form-input font-medium">
            <option value="">{{ 'training.no_trainer_opt'|trans }}</option>
            {% for trainer in trainers %}
                <option value="{{ trainer.id }}">
                    {{ trainer.name }} &bull; {{ trainer.race.value|capitalize }} ({{ 'heroes.primary_attrs'|trans }} Avg: T{{ (trainer.str + trainer.dex + trainer.kon + trainer.spd + trainer.intel + trainer.wil + trainer.cha + trainer.lck) // 8 }})
                </option>
            {% endfor %}
        </select>
    </div>
</div>
