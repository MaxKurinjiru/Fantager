{# templates/components/dashboard/quick_actions.html.twig #}
{% set actions = [
    { path: 'app_summon', emoji: '🌀', label: 'nav.summon' },
    { path: 'app_training', emoji: '🏋️', label: 'nav.training' },
    { path: 'app_hq', emoji: '🏰', label: 'nav.hq' },
    { path: 'app_heroes', emoji: '👥', label: 'nav.heroes' },
    { path: 'app_formation', emoji: '🛡️', label: 'nav.formation' },
    { path: 'app_inventory', emoji: '🎒', label: 'nav.inventory' },
    { path: 'app_spells', emoji: '📖', label: 'nav.spells' }
] %}

<div class="bg-gray-900/40 rounded-xl p-6 border border-gray-800">
    <h3 class="text-lg font-bold text-white mb-6">{{ 'dashboard.quick_actions'|trans }}</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {% for action in actions %}
            <a href="{{ path(action.path) }}" class="flex flex-col items-center justify-center p-4 rounded-xl bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-emerald-500/30 transition-all text-center group">
                <span class="text-3xl mb-3 group-hover:scale-110 transition-transform">{{ action.emoji }}</span>
                <span class="text-sm font-semibold text-gray-300">{{ action.label|trans }}</span>
            </a>
        {% endfor %}
    </div>
</div>
