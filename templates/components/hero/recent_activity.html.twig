{# templates/components/hero/recent_activity.html.twig #}
<div class="hero-panel">
    <div>
        <h2 class="hero-panel__title hero-panel__title--tight">{{ 'heroes.recent_activity'|trans }}</h2>
        <p class="hero-panel__desc">{{ 'heroes.recent_activity_desc'|trans }}</p>
    </div>

    <div class="hero-activity-list hero-activity-list--no-scroll">
        {% for log in heroHistory %}
            <div class="hero-activity-item">
                <div>
                    <div class="hero-activity-item__title">
                        {{ log.icon }} {{ log.message|raw }}
                    </div>
                    <div class="hero-activity-item__time">{{ log.created_at|date('Y-m-d H:i', hero.team.kingdom.timezone) }}</div>
                </div>
                <div class="hero-activity-item__aside">
                    {% if log.type == 'summoned' %}
                        <span class="status-chip status-chip--indigo">
                            {{ ('heroes.race_' ~ hero.race.value)|trans }}
                        </span>
                    {% elseif log.type == 'levelup' %}
                        <span class="status-chip status-chip--success">
                            LVL {{ hero.level }}
                        </span>
                    {% elseif log.type == 'mastery_gained' %}
                        <span class="status-chip status-chip--warning">
                            MASTERY
                        </span>
                    {% elseif log.type == 'match_played' %}
                        {% if 'win' in log.message or 'Výhra' in log.message or 'Won' in log.message %}
                            <span class="status-chip status-chip--success">{{ 'activity.battle_win_chip'|default('WIN')|trans }}</span>
                        {% elseif 'loss' in log.message or 'Prohra' in log.message or 'Lost' in log.message %}
                            <span class="status-chip status-chip--danger">{{ 'activity.battle_loss_chip'|default('LOSS')|trans }}</span>
                        {% else %}
                            <span class="status-chip status-chip--warning">{{ 'activity.battle_draw_chip'|default('DRAW')|trans }}</span>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="hero-activity-empty">
                <span class="hero-activity-empty__icon">💤</span>
                <span class="hero-panel__desc">{{ 'heroes.no_activity'|trans }}</span>
            </div>
        {% endfor %}
    </div>
</div>
