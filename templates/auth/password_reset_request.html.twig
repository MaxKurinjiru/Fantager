{% extends 'layouts/public.html.twig' %}

{% block title %}{{ 'auth.reset_password_title'|trans }} — Fantager{% endblock %}

{% block guest_body %}
<div class="max-w-md mx-auto mt-8">
    <h1 class="text-2xl font-bold text-brand-400 mb-6">{{ 'auth.reset_password_title'|trans }}</h1>

    <form method="POST" action="{{ path('app_password_reset') }}" class="space-y-4">
        <input type="hidden" name="_token" value="{{ csrf_token('password_reset_request') }}">

        <div class="mb-4">
            <label for="email" class="form-label">{{ 'auth.reset_password_email'|trans }}</label>
            <input type="email" id="email" name="email" required maxlength="180" autofocus
                   autocomplete="email"
                   class="form-input">
        </div>

        <button type="submit" class="btn btn-primary w-full">
            {{ 'auth.reset_password_submit'|trans }}
        </button>
    </form>

    <p class="mt-4 text-sm text-text-muted">
        <a href="{{ path('app_login') }}">{{ 'auth.back_to_login'|trans }}</a>
    </p>
</div>
{% endblock %}
