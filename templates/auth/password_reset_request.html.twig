{% extends 'layouts/public.html.twig' %}

{% block title %}{{ 'auth.reset_password_title'|trans }} — Fantager{% endblock %}

{% block guest_body %}
<div class="max-w-md mx-auto mt-8">
    <h1 class="text-2xl font-bold text-emerald-400 mb-6">{{ 'auth.reset_password_title'|trans }}</h1>

    <form method="POST" action="{{ path('app_password_reset') }}" class="space-y-4">
        <input type="hidden" name="_token" value="{{ csrf_token('password_reset_request') }}">

        <div>
            <label for="email" class="block text-sm text-gray-400 mb-1">{{ 'auth.reset_password_email'|trans }}</label>
                 <input type="email" id="email" name="email" required maxlength="180" autofocus
                     class="w-full rounded bg-gray-800 border border-gray-700 px-3 py-2 text-gray-100 focus:outline-none focus:border-emerald-400">
        </div>

        <button type="submit"
            class="w-full bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-semibold py-2 rounded">
            {{ 'auth.reset_password_submit'|trans }}
        </button>
    </form>

    <p class="mt-4 text-sm text-gray-500">
        <a href="{{ path('app_login') }}" class="text-emerald-400 hover:underline">{{ 'auth.back_to_login'|trans }}</a>
    </p>
</div>
{% endblock %}
