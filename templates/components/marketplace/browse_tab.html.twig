{# templates/components/marketplace/browse_tab.html.twig #}
<div data-marketplace-target="tabContent" data-tab-name="browse" class="layout-stack{% if tab|default('browse') != 'browse' %} hidden{% endif %}">
    {# Category tabs #}
    <div class="segmented-control">
        <a href="{{ path('app_marketplace', { tab: 'browse', category: 'hero' }) }}"
           class="segmented-btn {{ category|default('hero') == 'hero' ? 'segmented-btn--active' : '' }}">
            👥 {{ 'marketplace.type_hero'|trans }}
        </a>
        <a href="{{ path('app_marketplace', { tab: 'browse', category: 'trainer' }) }}"
           class="segmented-btn {{ category|default('hero') == 'trainer' ? 'segmented-btn--active' : '' }}">
            🏋️ {{ 'marketplace.type_trainer'|trans }}
        </a>
        <a href="{{ path('app_marketplace', { tab: 'browse', category: 'item' }) }}"
           class="segmented-btn {{ category|default('hero') == 'item' ? 'segmented-btn--active' : '' }}">
            🎒 {{ 'marketplace.type_item'|trans }}
        </a>
    </div>

    {# Filters Grid #}
    <div class="game-panel">
        <form data-marketplace-target="browseFilterForm" data-action="submit->marketplace#applyFilters" class="marketplace-filter-grid">
            <input type="hidden" name="type" value="{{ category|default('hero') }}" data-marketplace-target="browseTypeInput">

            {# Search #}
            <div class="form-field-group form-field-group--tight">
                <label for="filter-search" class="form-label">{{ 'heroes.search_placeholder'|trans }}</label>
                <input type="text" id="filter-search" name="search" placeholder="{{ 'marketplace.filter_search'|trans }}"
                       class="form-input">
            </div>

            {# Race Filter (Heroes/Trainers) #}
            <div class="form-field-group form-field-group--tight{% if category|default('hero') == 'item' %} hidden{% endif %}" data-marketplace-target="raceFilterContainer">
                <label for="filter-race" class="form-label">{{ 'heroes.race'|trans }}</label>
                <select id="filter-race" name="race" class="form-input">
                    <option value="">{{ 'marketplace.filter_all_races'|trans }}</option>
                    <option value="human">{{ 'heroes.race_human'|trans }}</option>
                    <option value="elf">{{ 'heroes.race_elf'|trans }}</option>
                    <option value="dwarf">{{ 'heroes.race_dwarf'|trans }}</option>
                    <option value="orc">{{ 'heroes.race_orc'|trans }}</option>
                    <option value="undead">{{ 'heroes.race_undead'|trans }}</option>
                    <option value="giant">{{ 'heroes.race_giant'|trans }}</option>
                    <option value="ent">{{ 'heroes.race_ent'|trans }}</option>
                    <option value="genie">{{ 'heroes.race_genie'|trans }}</option>
                </select>
            </div>

            {# Rarity Filter (Items) #}
            <div class="form-field-group form-field-group--tight{% if category|default('hero') != 'item' %} hidden{% endif %}" data-marketplace-target="rarityFilterContainer">
                <label for="filter-rarity" class="form-label">{{ 'marketplace.rarity_label'|trans }}</label>
                <select id="filter-rarity" name="rarity" class="form-input">
                    <option value="">{{ 'marketplace.filter_all_rarities'|trans }}</option>
                    <option value="common">{{ 'inventory.rarity_common'|trans }}</option>
                    <option value="uncommon">{{ 'inventory.rarity_uncommon'|trans }}</option>
                    <option value="rare">{{ 'inventory.rarity_rare'|trans }}</option>
                    <option value="epic">{{ 'inventory.rarity_epic'|trans }}</option>
                    <option value="legendary">{{ 'inventory.rarity_legendary'|trans }}</option>
                    <option value="mythic">{{ 'inventory.rarity_mythic'|trans }}</option>
                </select>
            </div>

            {# Sort #}
            <div class="form-field-group form-field-group--tight">
                <label for="filter-sort" class="form-label">{{ 'marketplace.filter_sort'|trans }}</label>
                <select id="filter-sort" name="sort" class="form-input">
                    <option value="newest">{{ 'marketplace.sort_newest'|trans }}</option>
                    <option value="price_asc">{{ 'marketplace.sort_price_asc'|trans }}</option>
                    <option value="price_desc">{{ 'marketplace.sort_price_desc'|trans }}</option>
                    <option value="expires_asc">{{ 'marketplace.sort_expires_asc'|trans }}</option>
                </select>
            </div>

            {# Submit / Reset Buttons #}
            <div class="marketplace-filter-actions">
                <button type="button" data-action="click->marketplace#resetFilters" class="btn btn-outline">
                    {{ 'marketplace.btn_reset'|trans }}
                </button>
                <button type="submit" class="btn btn-primary">
                    {{ 'marketplace.btn_filter'|trans }}
                </button>
            </div>
        </form>
    </div>

    {# Listings Grid #}
    <div data-marketplace-target="browseContainer" class="marketplace-browse-grid">
        {# AJAX Loaded cards #}
        <div class="grid-span-full loading-spinner">
            <div class="loading-spinner__icon" aria-hidden="true"></div>
        </div>
    </div>

    <nav class="news-pagination hidden" data-marketplace-target="browsePagination">
        <button type="button" data-action="click->marketplace#browsePrevPage" data-marketplace-target="browsePrevBtn" class="btn btn-outline btn--sm">{{ 'news.prev_page'|trans }}</button>
        <span class="news-pagination__info" data-marketplace-target="browsePageInfo"></span>
        <button type="button" data-action="click->marketplace#browseNextPage" data-marketplace-target="browseNextBtn" class="btn btn-outline btn--sm">{{ 'news.next_page'|trans }}</button>
    </nav>
</div>
