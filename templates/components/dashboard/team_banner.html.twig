{# templates/components/dashboard/team_banner.html.twig #}
<div class="db-banner">
    <div class="absolute inset-0 bg-grid-white/[0.01] -z-10"></div>
    
    {# Plovoucí ozubené kolečko pro editaci vpravo nahoře #}
    <button onclick="window.dispatchEvent(new CustomEvent('modal:open-team-profile')); return false;" class="db-banner__edit-btn" aria-label="{{ 'dashboard.edit_profile'|trans }}">
        <span aria-hidden="true" class="text-sm group-hover:rotate-45 transition-transform duration-300">⚙️</span>
        <span class="sr-only">{{ 'dashboard.edit_profile'|trans }}</span>
    </button>

    {# Znak / Logo týmu #}
    <div class="db-banner__emblem">
        {{ team.emblem ?: '🛡️' }}
    </div>

    {# Základní informace vpravo #}
    <div class="db-banner__content">
        
        {# 1. Řádek: Název týmu #}
        <div class="text-center md:text-left">
            <h1 class="db-banner__title">{{ team.name }}</h1>
        </div>

        {# 2. Řádek: Království a manažer #}
        <div class="db-banner__meta">
            <p>{{ 'dashboard.manager'|trans }}: <span class="text-emerald-400 font-semibold">{{ user.displayName }}</span></p>
            <span class="hidden md:inline text-gray-700 select-none">•</span>
            <p>{{ 'dashboard.kingdom'|trans }}: <span class="text-gray-300 font-semibold">{{ team.kingdom.name }}</span></p>
        </div>

        {# 3. Řádek: Morálka, chemie a reputace vedle sebe #}
        <div class="db-banner__badges">
            {# Morálka #}
            <div class="db-banner__badge db-banner__badge--morale">
                <span>😊</span>
                <span class="font-medium">
                    {{ 'dashboard.morale'|trans }}: <span class="font-bold text-white">{{ team.morale }}</span><span class="text-gray-500 text-[10px]">/100</span>
                </span>
            </div>

            {# Chemie #}
            <div class="db-banner__badge db-banner__badge--chemistry">
                <span>⚡</span>
                <span class="font-medium">
                    {{ 'dashboard.chemistry'|trans }}: <span class="font-bold text-white">{{ team.chemistry }}</span><span class="text-gray-550 text-[10px]">/100</span>
                </span>
            </div>

            {# Reputace #}
            <div class="db-banner__badge db-banner__badge--reputation">
                <span>⭐</span>
                <span class="font-medium">
                    {{ 'dashboard.reputation'|trans }}: <span class="font-bold text-white">{{ team.reputation }}</span>
                </span>
            </div>
        </div>

        {# 4. Řádek: Optimalizace rasy #}
        <div class="db-opt" data-controller="dashboard-optimization"
             data-dashboard-optimization-confirm-value="{{ 'hq.race_opt_confirm'|trans }}"
             data-dashboard-optimization-text-saving-value="{{ 'js_flash.dashboard.saving'|trans }}"
             data-dashboard-optimization-error-save-value="{{ 'js_flash.dashboard.failed'|trans }}"
             data-dashboard-optimization-success-save-value="{{ 'js_flash.dashboard.success'|trans }}"
        >
            {# Alert box #}
            {% include 'components/ui/alert_box.html.twig' with {
                target: 'dashboard-optimization',
                message_target: 'alertMessage',
                close_action: 'dashboard-optimization#closeAlert',
                classes: 'text-[10px] py-1 px-2 mb-2 max-w-xl'
            } %}

            {% set is_locked = dashboard.headquarters.is_optimization_locked %}
            {% set active_opt = dashboard.headquarters.race_optimization %}
            {% set pending_opt = dashboard.headquarters.pending_race_optimization %}

            <div class="db-opt__row">
                <div class="db-opt__label">
                    <span>🏰</span> {{ 'hq.race_opt_title'|trans }}:
                </div>

                <div class="db-opt__controls">
                    <select id="race-optimize-dashboard" data-dashboard-optimization-target="raceSelect"
                            {% if is_locked %}disabled{% endif %}
                            class="db-opt__select">
                        <option value="">{{ 'hq.no_opt'|trans }}</option>
                        {% for race in ['human', 'elf', 'dwarf', 'orc', 'undead', 'giant', 'ent', 'genie'] %}
                            <option value="{{ race }}" {% if active_opt == race %}selected{% endif %}>
                                {{ ('heroes.race_' ~ race)|trans }}{% if active_opt == race %} ({{ 'dashboard.active_suffix'|trans }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>

                    {% if is_locked or pending_opt %}
                        {# Stavové informace místo tlačítka #}
                        {% if pending_opt %}
                            <div class="db-opt__status db-opt__status--pending">
                                <span class="animate-pulse">⏳</span>
                                <span>{{ 'hq.race_opt_pending'|trans({'%race%': ('heroes.race_' ~ pending_opt)|trans}) }}</span>
                            </div>
                        {% elseif is_locked %}
                            <div class="db-opt__status db-opt__status--locked">
                                <span>🔒</span>
                                <span>{{ 'hq.race_opt_locked'|trans }}</span>
                            </div>
                        {% endif %}
                    {% else %}
                        {# Tlačítko změny #}
                        <button data-dashboard-optimization-target="optimizeBtn" data-action="click->dashboard-optimization#optimize"
                                class="btn btn-primary btn--sm px-4 py-1.5 font-bold uppercase tracking-wider text-[10px] cursor-pointer">
                            {{ 'hq.save_opt'|trans }}
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>
</div>
