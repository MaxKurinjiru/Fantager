{# templates/components/hero/equipped_gear.html.twig #}
<div class="hero-panel">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="hero-panel__title">{{ 'heroes.equipped_gear'|trans }}</h2>
            <p class="hero-panel__desc">{{ 'heroes.equipped_gear_desc'|trans }}</p>
        </div>
        <a href="{{ path('app_inventory') }}?hero_id={{ hero.id }}" class="btn btn-outline btn--sm gap-1">
            🎒 {{ 'heroes.manage_gear'|trans }}
        </a>
    </div>

    <div class="hero-gear-grid">
        {% set slot_configs = [
            {key: 'head', emoji: '🪖'},
            {key: 'amulet', emoji: '📿'},
            {key: 'body', emoji: '🛡️'},
            {key: 'hands', emoji: '🧤'},
            {key: 'main_hand', emoji: '⚔️'},
            {key: 'off_hand', emoji: '🛡️'},
            {key: 'ring', emoji: '💍'},
            {key: 'feet', emoji: '🥾'}
        ] %}

        {% for slot in slot_configs %}
            {% set item = equipped[slot.key] ?? null %}
            {% if item %}
                {# Active Item Slot #}
                <div class="hero-gear-slot hero-gear-slot--filled relative">
                    <span class="hero-gear-slot__label">{{ ('inventory.slot_' ~ slot.key)|trans }}</span>
                    <span class="text-3xl mb-1 select-none">
                        {% if item.slotType.value == 'main_hand' or item.slotType.value == 'weapon' %}🗡️
                        {% elseif item.slotType.value == 'head' %}🪖
                        {% elseif item.slotType.value == 'body' %}🛡️
                        {% elseif item.slotType.value == 'ring' %}💍
                        {% else %}🎒{% endif %}
                    </span>
                    <span class="hero-gear-slot__name" title="{{ item.name }}">{{ item.name }}</span>
                    <span class="rarity-tag rarity-tag--{{ item.rarity.value }}">
                        {{ ('inventory.rarity_' ~ item.rarity.value)|trans }}
                    </span>
                </div>
            {% else %}
                {# Empty Slot Placeholder #}
                <div class="hero-gear-slot hero-gear-slot--empty">
                    <span class="hero-gear-slot__label hero-gear-slot__label--faint">{{ ('inventory.slot_' ~ slot.key)|trans }}</span>
                    <span class="text-2xl mb-1">{{ slot.emoji }}</span>
                    <span class="hero-gear-slot__empty-hint">{{ 'inventory.empty_slot'|trans }}</span>
                </div>
            {% endif %}
        {% endfor %}
    </div>
</div>
