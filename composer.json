{
    "name": "fantager/fantager",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5",
        "symfony/framework-bundle": "^7.4",
        "symfony/console": "^7.4",
        "symfony/apache-pack": "^1.0",
        "symfony/yaml": "^7.4",
        "symfony/webpack-encore-bundle": "^2.4",
        "symfony/ux-turbo": "^3.0",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/translation": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/security-bundle": "^8.0",
        "symfony/rate-limiter": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/messenger": "^8.0",
        "doctrine/dbal": "^4.4",
        "symfony/doctrine-messenger": "^8.0",
        "doctrine/orm": "*",
        "doctrine/doctrine-bundle": "*",
        "doctrine/doctrine-migrations-bundle": "*",
        "symfony/dotenv": "^8.1",
        "sentry/sentry-symfony": "^5.10",
        "symfony/flex": "^2.11",
        "symfony/monolog-bundle": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php bin/console doctrine:migrations:migrate --no-interaction",
        "migrate-diff": "php bin/console doctrine:migrations:diff",
        "cache-clear": "php bin/console cache:clear",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "php-cs": "vendor/bin/php-cs-fixer check --diff",
        "php-cs-fix": "vendor/bin/php-cs-fixer fix --diff",
        "test": "vendor/bin/phpunit",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^13.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "symfony/flex": true
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    }
}