{% extends 'layouts/public.html.twig' %}

{% block title %}{{ 'homepage.title'|trans }} — {{ 'homepage.description'|trans }}{% endblock %}

{% block guest_body %}
<div class="text-center py-16">
    <h1 class="text-4xl font-bold text-emerald-400 mb-4">{{ 'homepage.title'|trans }}</h1>
    <p class="text-gray-400 text-lg mb-8">{{ 'homepage.tagline'|trans }}</p>
    <div class="flex justify-center gap-4">
        {% if app.user %}
            <a href="{{ path('app_dashboard') }}"
               class="btn btn-primary btn--lg">
                {{ 'nav.enter_game'|trans }}
            </a>
        {% else %}
            <a href="{{ path('app_register') }}"
               data-action="click->auth-modal#openRegister"
               class="btn btn-primary btn--lg">
                {{ 'homepage.cta_play'|trans }}
            </a>
            <a href="{{ path('app_login') }}"
               data-action="click->auth-modal#openLogin"
               class="btn btn-outline btn--lg">
                {{ 'homepage.cta_login'|trans }}
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}
