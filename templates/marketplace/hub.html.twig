{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'marketplace.title'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="space-y-6" data-controller="marketplace"
     data-marketplace-tax-rate-value="{{ taxRate }}"
     data-marketplace-current-team-id-value="{{ team.id }}"
     data-marketplace-csrf-token-value="{{ csrf_token('api') }}"
     data-marketplace-races-value="{{ {
         'human': 'heroes.race_human'|trans,
         'elf': 'heroes.race_elf'|trans,
         'dwarf': 'heroes.race_dwarf'|trans,
         'orc': 'heroes.race_orc'|trans,
         'undead': 'heroes.race_undead'|trans,
         'giant': 'heroes.race_giant'|trans,
         'ent': 'heroes.race_ent'|trans,
         'genie': 'heroes.race_genie'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-rarities-value="{{ {
         'common': 'inventory.rarity_common'|trans,
         'uncommon': 'inventory.rarity_uncommon'|trans,
         'rare': 'inventory.rarity_rare'|trans,
         'epic': 'inventory.rarity_epic'|trans,
         'legendary': 'inventory.rarity_legendary'|trans,
         'mythic': 'inventory.rarity_mythic'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-slots-value="{{ {
         'head': 'inventory.slot_head'|trans,
         'amulet': 'inventory.slot_amulet'|trans,
         'body': 'inventory.slot_body'|trans,
         'hands': 'inventory.slot_hands'|trans,
         'main_hand': 'inventory.slot_main_hand'|trans,
         'weapon': 'inventory.slot_weapon'|trans,
         'off_hand': 'inventory.slot_off_hand'|trans,
         'ring': 'inventory.slot_ring'|trans,
         'feet': 'inventory.slot_feet'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-statuses-value="{{ {
         'active': 'marketplace.status_active'|trans,
         'sold': 'marketplace.status_sold'|trans,
         'expired': 'marketplace.status_expired'|trans,
         'cancelled': 'marketplace.status_cancelled'|trans
     }|json_encode|e('html_attr') }}"
     data-marketplace-translations-value="{{ {
         'own_listing_hint': 'marketplace.own_listing_hint'|trans,
         'select_entity_first': 'marketplace.select_entity_first'|trans,
         'confirm_cancel': 'marketplace.confirm_cancel'|trans,
         'confirm_bid': 'marketplace.confirm_bid'|trans,
         'confirm_buyout': 'marketplace.confirm_buyout'|trans,
         'time_expired': 'marketplace.time_expired'|trans,
         'time_remaining': 'marketplace.time_remaining'|trans,
         'time_remaining_hours': 'marketplace.time_remaining_hours'|trans,
         'empty_listings': 'marketplace.empty_listings'|trans,
         'empty_my_listings': 'marketplace.empty_my_listings'|trans,
         'empty_history': 'marketplace.empty_history'|trans,
         'label_min_bid': 'marketplace.label_min_bid'|trans,
         'label_buyout_price': 'marketplace.label_buyout_price'|trans,
         'label_no_bonuses': 'marketplace.label_no_bonuses'|trans,
         'none_selected': 'marketplace.select_entity_placeholder'|trans,
         'active_auction': 'marketplace.status_active'|trans,
         'direct_buy': 'marketplace.mode_buy_now'|trans,
         'highest_bid_format': 'marketplace.label_highest_bid_val'|trans,
         'no_bids': 'marketplace.label_no_bids_val'|trans,
         'btn_bid': 'marketplace.btn_bid'|trans,
         'btn_buyout': 'marketplace.btn_buyout'|trans,
         'btn_cancel': 'marketplace.btn_cancel'|trans,
         'years_suffix': 'marketplace.years_suffix'|trans
     }|json_encode|e('html_attr') }}">

    {# Hub Header #}
    <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-gray-800 pb-4">
        <div>
            <h1 class="text-3xl font-extrabold text-white tracking-tight">{{ 'marketplace.title'|trans }}</h1>
            <p class="text-sm text-gray-400 mt-1">{{ 'marketplace.subtitle'|trans }}</p>
        </div>
        <div class="mt-4 md:mt-0 flex items-center space-x-3 bg-gray-900 px-4 py-2 rounded-xl border border-gray-800 shadow-lg">
            <span class="text-sm text-gray-400">{{ 'dashboard.treasury'|trans }}:</span>
            <span class="text-lg font-bold text-amber-400 flex items-center">
                <span class="mr-1">🪙</span> {{ team.gold }} {{ 'dashboard.gold'|trans }}
            </span>
        </div>
    </div>

    {# --- Alert Box --- #}
    {% include 'components/ui/alert_box.html.twig' with {
        target: 'marketplace',
        message_target: 'alertMessage',
        close_action: 'marketplace#hideAlert'
    } %}

    {# Hub Tabs #}
    <div class="flex border-b border-gray-800 overflow-x-auto">
        <button type="button" data-action="click->marketplace#switchTab" data-tab="browse" data-marketplace-target="tabButton"
                class="tab-btn tab-btn--active">
            ⚖️ {{ 'marketplace.tab_browse'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="sell" data-marketplace-target="tabButton"
                class="tab-btn">
            💰 {{ 'marketplace.tab_sell'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="mylistings" data-marketplace-target="tabButton"
                class="tab-btn">
            📦 {{ 'marketplace.tab_my_listings'|trans }}
        </button>
        <button type="button" data-action="click->marketplace#switchTab" data-tab="history" data-marketplace-target="tabButton"
                class="tab-btn">
            📜 {{ 'marketplace.tab_history'|trans }}
        </button>
    </div>

    {# TABS CONTENT #}
    
    {# 1. BROWSE TAB #}
    <div data-marketplace-target="tabContent" data-tab-name="browse" class="space-y-6">
        {# Filters Grid #}
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <form data-action="submit->marketplace#applyFilters" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                {# Search #}
                <div class="flex flex-col gap-1">
                    <label for="filter-search" class="form-label">{{ 'heroes.search_placeholder'|trans }}</label>
                    <input type="text" id="filter-search" name="search" placeholder="{{ 'marketplace.filter_search'|trans }}"
                           class="form-input">
                </div>

                {# Type #}
                <div class="flex flex-col gap-1">
                    <label for="filter-type" class="form-label">Typ</label>
                    <select id="filter-type" name="type" data-action="change->marketplace#onTypeChange" class="form-input">
                        <option value="">-- Vše --</option>
                        <option value="hero">{{ 'marketplace.type_hero'|trans }}</option>
                        <option value="item">{{ 'marketplace.type_item'|trans }}</option>
                        <option value="trainer">{{ 'marketplace.type_trainer'|trans }}</option>
                    </select>
                </div>

                {# Race Filter (Heroes/Trainers) #}
                <div class="flex flex-col gap-1" data-marketplace-target="raceFilterContainer">
                    <label for="filter-race" class="form-label">{{ 'heroes.race'|trans }}</label>
                    <select id="filter-race" name="race" class="form-input">
                        <option value="">{{ 'marketplace.filter_all_races'|trans }}</option>
                        <option value="human">{{ 'heroes.race_human'|trans }}</option>
                        <option value="elf">{{ 'heroes.race_elf'|trans }}</option>
                        <option value="dwarf">{{ 'heroes.race_dwarf'|trans }}</option>
                        <option value="orc">{{ 'heroes.race_orc'|trans }}</option>
                        <option value="undead">{{ 'heroes.race_undead'|trans }}</option>
                        <option value="giant">{{ 'heroes.race_giant'|trans }}</option>
                        <option value="ent">{{ 'heroes.race_ent'|trans }}</option>
                        <option value="genie">{{ 'heroes.race_genie'|trans }}</option>
                    </select>
                </div>

                {# Rarity Filter (Items) #}
                <div class="flex flex-col gap-1 hidden" data-marketplace-target="rarityFilterContainer">
                    <label for="filter-rarity" class="form-label">Rarita</label>
                    <select id="filter-rarity" name="rarity" class="form-input">
                        <option value="">{{ 'marketplace.filter_all_rarities'|trans }}</option>
                        <option value="common">{{ 'inventory.rarity_common'|trans }}</option>
                        <option value="uncommon">{{ 'inventory.rarity_uncommon'|trans }}</option>
                        <option value="rare">{{ 'inventory.rarity_rare'|trans }}</option>
                        <option value="epic">{{ 'inventory.rarity_epic'|trans }}</option>
                        <option value="legendary">{{ 'inventory.rarity_legendary'|trans }}</option>
                        <option value="mythic">{{ 'inventory.rarity_mythic'|trans }}</option>
                    </select>
                </div>

                {# Sort #}
                <div class="flex flex-col gap-1">
                    <label for="filter-sort" class="form-label">{{ 'marketplace.filter_sort'|trans }}</label>
                    <select id="filter-sort" name="sort" class="form-input">
                        <option value="newest">{{ 'marketplace.sort_newest'|trans }}</option>
                        <option value="price_asc">{{ 'marketplace.sort_price_asc'|trans }}</option>
                        <option value="price_desc">{{ 'marketplace.sort_price_desc'|trans }}</option>
                        <option value="expires_asc">{{ 'marketplace.sort_expires_asc'|trans }}</option>
                    </select>
                </div>

                {# Submit / Reset Buttons #}
                <div class="md:col-span-4 flex justify-end gap-3 mt-2">
                    <button type="button" data-action="click->marketplace#resetFilters" class="btn btn-outline">
                        Reset
                    </button>
                    <button type="submit" class="btn btn-primary">
                        🔍 Filtrovat
                    </button>
                </div>
            </form>
        </div>

        {# Listings Grid #}
        <div data-marketplace-target="browseContainer" class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {# AJAX Loaded cards #}
            <div class="col-span-3 flex justify-center py-12">
                <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-emerald-500"></div>
            </div>
        </div>
    </div>

    {# 2. SELL TAB #}
    <div data-marketplace-target="tabContent" data-tab-name="sell" class="space-y-6 hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {# Category Selector & Roster list #}
            <div class="lg:col-span-2 bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-xl space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-white">{{ 'marketplace.select_entity'|trans }}</h2>
                    <p class="text-sm text-gray-400 mt-1">Vyberte kategorii a entitu, kterou si přejete umístit na trh.</p>
                </div>

                {# Roster tabs #}
                <div class="flex space-x-2 bg-gray-950 p-1 rounded-xl border border-gray-800">
                    <button type="button" data-action="click->marketplace#switchSellCategory" data-sell-cat="hero" data-marketplace-target="sellCatButton"
                            class="segmented-btn segmented-btn--active">
                        👥 {{ 'marketplace.type_hero'|trans }}
                    </button>
                    <button type="button" data-action="click->marketplace#switchSellCategory" data-sell-cat="item" data-marketplace-target="sellCatButton"
                            class="segmented-btn">
                        🎒 {{ 'marketplace.type_item'|trans }}
                    </button>
                    <button type="button" data-action="click->marketplace#switchSellCategory" data-sell-cat="trainer" data-marketplace-target="sellCatButton"
                            class="segmented-btn">
                        🏋️ {{ 'marketplace.type_trainer'|trans }}
                    </button>
                </div>

                {# Grid selection containers #}
                
                {# Heroes list #}
                <div data-marketplace-target="sellEntitiesContainer" data-sell-cat-name="hero" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[450px] overflow-y-auto pr-2">
                    {% for hero in heroes %}
                        <div data-action="click->marketplace#selectEntityToSell"
                             data-entity-id="{{ hero.id }}"
                             data-entity-name="{{ hero.name }}"
                             class="sell-card flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl select-none">👥</span>
                                <div>
                                    <h4 class="font-bold text-white leading-snug">{{ hero.name }}</h4>
                                    <span class="text-xs text-gray-400">Lvl {{ hero.level }} &bull; {{ hero.race.value|trans }}</span>
                                </div>
                            </div>
                            <span class="text-xs bg-gray-900 text-gray-400 px-2.5 py-1 rounded-lg border border-gray-800 uppercase tracking-wide">
                                {{ ('heroes.age_phase.' ~ (hero.age < 25 ? 'junior' : (hero.age < 50 ? 'prime' : (hero.age < 75 ? 'veteran' : 'elder'))))|trans }}
                            </span>
                        </div>
                    {% else %}
                        <div class="col-span-2 text-center py-8 text-gray-500">Žádní dostupní hrdinové pro prodej.</div>
                    {% endfor %}
                </div>

                {# Items list #}
                <div data-marketplace-target="sellEntitiesContainer" data-sell-cat-name="item" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[450px] overflow-y-auto pr-2 hidden">
                    {% for item in items %}
                        <div data-action="click->marketplace#selectEntityToSell"
                             data-entity-id="{{ item.id }}"
                             data-entity-name="{{ item.name }}"
                             class="sell-card flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl select-none">🗡️</span>
                                <div>
                                    <h4 class="font-bold text-white leading-snug">{{ item.name }}</h4>
                                    <span class="text-xs text-gray-400">{{ item.slotType.value|trans }} &bull; Durability: {{ item.durability }}%</span>
                                </div>
                            </div>
                            <span class="rarity-tag rarity-tag--{{ item.rarity.value }}">
                                {{ ('inventory.rarity_' ~ item.rarity.value)|trans }}
                            </span>
                        </div>
                    {% else %}
                        <div class="col-span-2 text-center py-8 text-gray-500">Žádné volné předměty pro prodej.</div>
                    {% endfor %}
                </div>

                {# Trainers list #}
                <div data-marketplace-target="sellEntitiesContainer" data-sell-cat-name="trainer" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[450px] overflow-y-auto pr-2 hidden">
                    {% for trainer in trainers %}
                        <div data-action="click->marketplace#selectEntityToSell"
                             data-entity-id="{{ trainer.id }}"
                             data-entity-name="{{ trainer.name }}"
                             class="sell-card flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl select-none">🏋️</span>
                                <div>
                                    <h4 class="font-bold text-white leading-snug">{{ trainer.name }}</h4>
                                    <span class="text-xs text-gray-400">{{ trainer.race.value|trans }} &bull; Věk: {{ trainer.age }} let</span>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-span-2 text-center py-8 text-gray-500">Žádní dostupní trenéři pro prodej.</div>
                    {% endfor %}
                </div>
            </div>

            {# Listing Form Options #}
            <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-xl space-y-6 flex flex-col justify-between">
                <form data-action="submit->marketplace#submitListing" class="space-y-5">
                    <div>
                        <h2 class="text-xl font-bold text-white">{{ 'marketplace.btn_sell'|trans }}</h2>
                        <p class="text-sm text-gray-400 mt-1">Nastavte obchodní podmínky a nahrajte do nabídky.</p>
                    </div>

                    {# Selected entity summary badge #}
                    <div class="marketplace-notice flex items-center justify-between">
                        <span class="text-xs text-gray-400 uppercase font-bold tracking-wider">Vybráno</span>
                        <span data-marketplace-target="selectedEntityLabel" class="font-bold text-white text-sm">-- Nic --</span>
                    </div>

                    <input type="hidden" name="sell_id" data-marketplace-target="sellIdInput" value="">

                    {# Listing Mode #}
                    <div class="flex flex-col gap-1.5">
                        <label for="listing-mode" class="form-label">Obchodní režim</label>
                        <select id="listing-mode" name="mode" data-action="change->marketplace#onListingModeChange" data-marketplace-target="listingModeSelect"
                                class="form-input">
                            <option value="buy_now">{{ 'marketplace.mode_buy_now'|trans }}</option>
                            <option value="auction">{{ 'marketplace.mode_auction'|trans }}</option>
                        </select>
                    </div>

                    {# Price Gold #}
                    <div class="flex flex-col gap-1.5">
                        <label for="listing-price" data-marketplace-target="priceLabel" class="form-label">
                            {{ 'marketplace.price_gold'|trans }}
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-2 text-gray-500 text-sm">🪙</span>
                            <input type="number" id="listing-price" name="price" required min="1" placeholder="Částka ve zlatě"
                                   class="form-input pl-8">
                        </div>
                    </div>

                    {# Buyout Price Gold (Optional for Auction) #}
                    <div class="flex flex-col gap-1.5 hidden" data-marketplace-target="buyoutFieldContainer">
                        <label for="listing-buyout" class="form-label">
                            {{ 'marketplace.buyout_gold'|trans }}
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-2 text-gray-500 text-sm">🪙</span>
                            <input type="number" id="listing-buyout" name="buyout" min="1" placeholder="Nepovinné — buyout cena"
                                   class="form-input pl-8">
                        </div>
                    </div>

                    {# Duration #}
                    <div class="flex flex-col gap-1.5">
                        <label for="listing-duration" class="form-label">
                            {{ 'marketplace.duration_days'|trans }}
                        </label>
                        <select id="listing-duration" name="duration" class="form-input">
                            <option value="3">3 dny</option>
                            <option value="5" selected>5 dní</option>
                            <option value="7">7 dní</option>
                        </select>
                    </div>

                    {# Tax notice #}
                    <div class="marketplace-notice text-xs">
                        ⚠️ {{ 'marketplace.tax_hint'|trans({'%tax%': taxRate}) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-full">
                        🚀 Vystavit na trh
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# 3. MY LISTINGS TAB #}
    <div data-marketplace-target="tabContent" data-tab-name="mylistings" class="space-y-6 hidden">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-xl overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                        <th class="py-3 px-4">{{ 'marketplace.col_entity'|trans }}</th>
                        <th class="py-3 px-4">Typ / Režim</th>
                        <th class="py-3 px-4">Základní cena</th>
                        <th class="py-3 px-4">{{ 'marketplace.label_highest_bid'|trans }}</th>
                        <th class="py-3 px-4">{{ 'marketplace.label_expires'|trans }}</th>
                        <th class="py-3 px-4">{{ 'marketplace.col_status'|trans }}</th>
                        <th class="py-3 px-4 text-right">Akce</th>
                    </tr>
                </thead>
                <tbody data-marketplace-target="myListingsContainer">
                    {# AJAX Loaded list #}
                    <tr>
                        <td colspan="7" class="text-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-500 mx-auto"></div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# 4. TRANSACTION HISTORY TAB #}
    <div data-marketplace-target="tabContent" data-tab-name="history" class="space-y-6 hidden">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-xl overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                        <th class="py-3 px-4">ID Transakce</th>
                        <th class="py-3 px-4">{{ 'marketplace.col_entity'|trans }}</th>
                        <th class="py-3 px-4">{{ 'marketplace.col_seller'|trans }}</th>
                        <th class="py-3 px-4">{{ 'marketplace.col_buyer'|trans }}</th>
                        <th class="py-3 px-4">Celková cena</th>
                        <th class="py-3 px-4">Poplatek (tax)</th>
                        <th class="py-3 px-4">{{ 'marketplace.col_date'|trans }}</th>
                    </tr>
                </thead>
                <tbody data-marketplace-target="historyContainer">
                    {# AJAX Loaded list #}
                    <tr>
                        <td colspan="7" class="text-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-500 mx-auto"></div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

{# ─────────────────────────────────────────────────────────────────────────────
   HTML TEMPLATES (CLONED IN STIMULUS CONTROLLER FOR DYNAMIC UI RENDERING)
───────────────────────────────────────────────────────────────────────────── #}

{# Hero Card Template #}
<template id="template-card-hero">
    <div class="marketplace-card marketplace-card--hero">
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <span class="text-xs uppercase font-bold text-blue-400 bg-blue-950/60 px-2.5 py-0.5 rounded border border-blue-900">👥 {{ 'marketplace.type_hero'|trans }}</span>
                <span class="text-xs text-gray-400 font-medium js-level"></span>
            </div>
            <h3 class="text-lg font-bold text-white leading-tight js-name"></h3>
            <div class="marketplace-card__details">
                <div>{{ 'heroes.race'|trans }}: <span class="text-gray-200 font-semibold js-race"></span></div>
                <div>{{ 'heroes.age'|trans }}: <span class="text-gray-200 font-semibold js-age"></span></div>
                <div>Forma: <span class="text-gray-200 font-semibold js-form"></span></div>
                <div>{{ 'heroes.fatigue'|trans }}: <span class="text-gray-200 font-semibold js-fatigue"></span></div>
            </div>
            <div class="marketplace-card__stats">
                <div class="marketplace-card__stat-item">STR <span class="block text-xs text-gray-300 font-bold mt-0.5 js-str"></span></div>
                <div class="marketplace-card__stat-item">DEX <span class="block text-xs text-gray-300 font-bold mt-0.5 js-dex"></span></div>
                <div class="marketplace-card__stat-item">KON <span class="block text-xs text-gray-300 font-bold mt-0.5 js-kon"></span></div>
                <div class="marketplace-card__stat-item">SPD <span class="block text-xs text-gray-300 font-bold mt-0.5 js-spd"></span></div>
            </div>
        </div>
        <div class="border-t border-gray-800/80 pt-3 space-y-1 js-footer-info">
            <div class="flex justify-between text-[11px] text-gray-500 pb-1 border-b border-gray-800/40">
                <span>{{ 'marketplace.col_seller'|trans }}: <span class="text-gray-300 font-medium js-seller-name"></span></span>
                <span class="text-red-400 font-semibold js-time-remaining"></span>
            </div>
            <div class="flex items-center justify-between py-1 border-b border-gray-800/60 js-buyout-section hidden">
                <span class="text-xs text-gray-400">{{ 'marketplace.label_buyout'|trans }}:</span>
                <span class="text-sm font-bold text-amber-400 flex items-center">🪙&nbsp;<span class="js-buyout-price"></span></span>
            </div>
            <div class="flex items-center justify-between py-1 js-bid-section hidden">
                <span class="text-xs text-gray-400">{{ 'marketplace.label_highest_bid'|trans }}:</span>
