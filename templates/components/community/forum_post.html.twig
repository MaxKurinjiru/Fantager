{# templates/components/community/forum_post.html.twig #}
<article class="forum-post{% if is_original|default(false) %} forum-post--original{% endif %} game-panel">
    <header class="forum-post__header">
        <div class="forum-post__author">
            {% if post.authorTeam %}
                <span class="forum-post__emblem">{{ post.authorTeam.emblem ?: '🛡️' }}</span>
            {% else %}
                <span class="forum-post__emblem">👤</span>
            {% endif %}
            <div>
                <button type="button"
                        class="forum-post__author-name profile-link"
                        data-action="click->player-profile#open"
                        data-player-profile-user-id-param="{{ post.authorUser.id }}"
                        aria-label="{{ 'community.view_profile'|trans({'%name%': post.authorUser.displayName}) }}">
                    {{ post.authorUser.displayName }}
                </button>
                {% if post.authorTeam %}
                    <span class="forum-post__team-name">
                        {% if post.authorTeam.colors %}
                            <span class="team-color-dot" style="--team-color-primary: {{ post.authorTeam.colors.primary }}; --team-color-secondary: {{ post.authorTeam.colors.secondary }};"></span>
                        {% endif %}
                        {{ post.authorTeam.name }}
                    </span>
                {% endif %}
                {% if is_original|default(false) %}
                    <span class="forum-post__role">{{ 'community.thread_starter'|trans }}</span>
                {% endif %}
            </div>
        </div>

        <time class="forum-post__time" datetime="{{ post.createdAt|date('c') }}">
            {{ post.createdAt|date('d. m. Y H:i') }}
        </time>
    </header>
    <div class="forum-post__body">{{ post.body }}</div>
</article>
