{# templates/components/finance/ledger_content.html.twig #}
<form method="GET" action="{{ ledger_action|default(path('app_finance')) }}" class="finance-ledger__filters filter-form" data-controller="form-auto-submit">
    {% if ledger_tab_param|default(true) %}
        <input type="hidden" name="tab" value="ledger">
    {% endif %}
    <div class="filter-form__fields">
        <div>
            <label for="finance-type-filter" class="sr-only">{{ 'finance.filter_type'|trans }}</label>
            <select id="finance-type-filter" name="type" data-action="change->form-auto-submit#submit" class="form-input">
                <option value="">{{ 'finance.all_types'|trans }}</option>
                {% for type in types %}
                    <option value="{{ type.value }}" {% if current_type == type.value %}selected{% endif %}>
                        {{ ('finance.type_' ~ type.value)|trans }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="finance-actor-filter" class="sr-only">{{ 'finance.filter_actor'|trans }}</label>
            <select id="finance-actor-filter" name="actor" data-action="change->form-auto-submit#submit" class="form-input">
                <option value="">{{ 'finance.all_actors'|trans }}</option>
                {% for actor in actors %}
                    <option value="{{ actor.value }}" {% if current_actor == actor.value %}selected{% endif %}>
                        {{ ('finance.actor_' ~ actor.value)|trans }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>
    <div class="filter-form__sort">
        <label for="finance-sort-by" class="filter-form__sort-label">{{ 'summoning.sort_by'|trans }}</label>
        <select id="finance-sort-by" name="sort" data-action="change->form-auto-submit#submit" class="form-input">
            <option value="date-desc" {% if current_sort == 'date-desc' %}selected{% endif %}>{{ 'finance.sort_date_desc'|trans }}</option>
            <option value="date-asc" {% if current_sort == 'date-asc' %}selected{% endif %}>{{ 'finance.sort_date_asc'|trans }}</option>
            <option value="amount-desc" {% if current_sort == 'amount-desc' %}selected{% endif %}>{{ 'finance.sort_amount_desc'|trans }}</option>
            <option value="amount-asc" {% if current_sort == 'amount-asc' %}selected{% endif %}>{{ 'finance.sort_amount_asc'|trans }}</option>
        </select>
    </div>
</form>

<div class="finance-ledger__table-container">
    {% if records|length > 0 %}
        <div class="overflow-x-auto">
            <table class="finance-ledger-table">
                <thead>
                    <tr>
                        <th class="finance-ledger-table__cell">{{ 'finance.col_type'|trans }}</th>
                        <th class="finance-ledger-table__cell">{{ 'finance.col_actor'|trans }}</th>
                        <th class="finance-ledger-table__cell">{{ 'finance.col_changes'|trans }}</th>
                        <th class="finance-ledger-table__cell finance-ledger-table__cell--right">{{ 'finance.col_date'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in records %}
                        <tr class="finance-ledger-table__row">
                            <td class="p-4 font-semibold">{{ ('finance.type_' ~ item.type.value)|trans }}</td>
                            <td class="finance-ledger-table__cell">
                                <span class="finance-actor-badge finance-actor-badge--{{ item.actor.value }}">
                                    {{ ('finance.actor_' ~ item.actor.value)|trans }}
                                </span>
                            </td>
                            <td class="finance-ledger-table__cell">
                                {% if item.goldChange != 0 %}
                                    <span class="finance-changes__item {{ item.goldChange > 0 ? 'finance-changes__item--positive' : 'finance-changes__item--negative' }}">
                                        {{ item.goldChange > 0 ? '+' : '' }}{{ item.goldChange|number_format(0, '.', ' ') }} 🪙
                                    </span>
                                {% endif %}
                            </td>
                            <td class="p-4 text-right text-text-secondary text-xs whitespace-nowrap">
                                {{ item.createdAt|date('Y-m-d H:i') }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="finance-ledger__empty">
            <span class="finance-ledger__empty-icon">📭</span>
            <p>{{ 'finance.no_records'|trans }}</p>
        </div>
    {% endif %}
</div>
