{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'arena.title'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="page-shell">
    {% include 'components/ui/page_header.html.twig' with {
        title: 'arena.title',
        subtitle: 'arena.subtitle'
    } %}

    <div class="screen-3col screen-3col--gap-lg">
        <div class="screen-3col__main arena-section">
            <div class="game-panel">
                <h2 class="arena-panel__title">{{ 'arena.status_title'|trans }}</h2>
                <div class="stat-grid">
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.level'|trans }}</span>
                        <span class="arena-stat-card__value">{{ status.arena_level }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.capacity'|trans }}</span>
                        <span class="arena-stat-card__value">{{ status.seating_capacity }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.ticket_price'|trans }}</span>
                        <span class="arena-stat-card__value">🪙 {{ status.ticket_price }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.fan_base'|trans }}</span>
                        <span class="arena-stat-card__value">{{ status.fan_base }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.show_up_rate'|trans }}</span>
                        <span class="arena-stat-card__value">{{ (status.show_up_rate * 100)|number_format(0) }}%</span>
                    </div>
                </div>
                <p class="arena-hint">{{ 'arena.fan_club_hint'|trans({
                    '%fanBase%': status.fan_base,
                    '%targetFanBase%': status.target_fan_base,
                    '%reputation%': status.reputation,
                    '%morale%': status.morale,
                    '%chemistry%': status.chemistry
                }) }}</p>
                <p class="arena-hint--subtle">{{ 'arena.revenue_home_only_hint'|trans }}</p>
            </div>

            {% if status.next_home_match %}
            <div class="game-panel arena-section">
                <h2 class="arena-panel__title">{{ 'arena.next_home_match'|trans }}</h2>
                <p class="arena-match-lead">{{ 'arena.next_match_home'|trans({'%opponent%': status.next_home_match.opponent}) }}</p>
                <p class="arena-match-date">{{ status.next_home_match.scheduled_at|date('d.m.Y H:i') }}</p>

                {% if status.projected_attendance is not null %}
                <div class="arena-match-stats">
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.projected_attendance'|trans }}</span>
                        <span class="arena-stat-card__value arena-stat-card__delta--positive">{{ status.projected_attendance }} / {{ status.seating_capacity }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.home_fans'|trans }}</span>
                        <span class="arena-stat-card__value">{{ status.projected_home_attendees }}</span>
                    </div>
                    <div class="arena-stat-card">
                        <span class="arena-stat-card__label">{{ 'arena.away_fans'|trans }}</span>
                        <span class="arena-stat-card__value">{{ status.projected_away_attendees }}</span>
                    </div>
                </div>
                <p class="arena-projected-revenue">{{ 'arena.projected_revenue'|trans }}: 🪙 {{ status.projected_revenue }}</p>
                {% endif %}
            </div>
            {% else %}
            <div class="arena-match-date">
                {{ 'arena.no_home_match'|trans }}
            </div>
            {% endif %}

            <div class="game-panel">
                <h2 class="arena-panel__title">{{ 'arena.revenue_history'|trans }}</h2>
                {% if status.recent_revenue|length > 0 %}
                    <div class="data-table-wrap">
                        <table class="arena-revenue-table">
                            <thead>
                                <tr>
                                    <th class="arena-revenue-table__th">{{ 'finance.col_date'|trans }}</th>
                                    <th class="arena-revenue-table__th">{{ 'arena.col_opponent'|trans }}</th>
                                    <th class="arena-revenue-table__th">{{ 'arena.col_attendance'|trans }}</th>
                                    <th class="arena-revenue-table__th">{{ 'finance.col_amount'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in status.recent_revenue %}
                                <tr>
                                    <td class="arena-revenue-table__cell-date arena-match-lead">{{ row.created_at|date('d.m.Y H:i') }}</td>
                                    <td class="arena-revenue-table__cell-muted">{{ row.opponent_name ?? '—' }}</td>
                                    <td class="arena-revenue-table__cell-muted">
                                        {% if row.attendance is not null and row.capacity is not null %}
                                            {{ row.attendance }} / {{ row.capacity }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td class="arena-revenue-table__cell-amount">+🪙 {{ row.amount }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="arena-match-date">{{ 'arena.no_revenue_yet'|trans }}</p>
                {% endif %}
            </div>
        </div>

        <div class="arena-section">
            <div class="game-panel">
                <h2 class="hero-panel__title hero-panel__title--tight">{{ 'arena.how_it_works'|trans }}</h2>
                <ul class="arena-rules-list">
                    <li>{{ 'arena.rule_fixed_price'|trans({'%price%': status.ticket_price}) }}</li>
                    <li>{{ 'arena.rule_capacity'|trans }}</li>
                    <li>{{ 'arena.rule_attendance'|trans }}</li>
                    <li>{{ 'arena.rule_home_only'|trans }}</li>
                </ul>
                <p class="arena-upgrade-hint">{{ 'arena.upgrade_hint'|trans }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
