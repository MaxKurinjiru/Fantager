{# templates/components/layout/confirm_modal.html.twig #}
<div data-controller="confirm-modal" id="confirm-modal-wrapper">
    <div data-confirm-modal-target="dialog"
         class="hidden modal-overlay"
         data-action="click->confirm-modal#closeBackdrop">
         <div class="modal-box modal-box--spacious" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
             <button type="button"
                     data-action="click->confirm-modal#cancel"
                     class="modal-close"
                     aria-label="{{ 'modal.close'|trans }}">
                 <span aria-hidden="true" class="modal-close__icon">✕</span>
                 <span class="sr-only">{{ 'modal.close'|trans }}</span>
             </button>

             <div class="modal-header">
                 <h2 id="confirm-modal-title" class="modal-header__title" data-confirm-modal-target="title"></h2>
             </div>

             <div class="modal-body layout-stack">
                 <p class="confirm-modal-message" data-confirm-modal-target="message"></p>
                 <div class="layout-cluster layout-cluster--end">
                     <button type="button"
                             data-action="click->confirm-modal#cancel"
                             data-confirm-modal-target="cancelBtn"
                             class="btn btn-outline"></button>
                     <button type="button"
                             data-action="click->confirm-modal#confirm"
                             data-confirm-modal-target="confirmBtn"
                             class="btn btn-primary"></button>
                 </div>
             </div>
         </div>
    </div>
</div>
