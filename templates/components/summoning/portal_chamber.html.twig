{# templates/components/summoning/portal_chamber.html.twig #}
<div class="summoning-portal">
    <div class="summoning-portal__glow"></div>

    <div data-summoning-target="chamberState" class="summoning-portal__idle text-center p-8 space-y-4">
        <span class="text-6xl animate-pulse block select-none">🔮</span>
        <h2 class="text-xl font-bold text-white">{{ 'summoning.portal_title'|trans }}</h2>
        <p class="summoning-portal__desc">{{ 'summoning.portal_desc'|trans }}</p>
    </div>

    <div data-summoning-target="portal" class="summoning-portal__channeling hidden space-y-6">
        <div class="summoning-portal__channeling-visual">
            <div class="loading-spinner">
                <div class="loading-spinner__icon" aria-hidden="true"></div>
            </div>
            <span class="absolute text-4xl select-none">🌀</span>
        </div>
        <div class="space-y-1">
            <h3 class="font-extrabold text-white text-lg">{{ 'summoning.portal_channeling'|trans }}</h3>
            <p class="summoning-portal__channeling-desc">{{ 'summoning.portal_channeling_desc'|trans }}</p>
        </div>
    </div>

    <div data-summoning-target="reveal" class="summoning-portal__reveal hidden w-full space-y-6">
        <div class="summoning-reveal-card">
            <div class="summoning-reveal-card__badge">{{ 'summoning.new_recruit'|trans }}</div>

            <div class="summoning-reveal-card__avatar">👤</div>
            <h3 data-summoning-target="heroName" class="text-xl font-extrabold text-white mb-0.5">---</h3>
            <p class="summoning-reveal-card__race">
                <span>👤</span>
                <span data-summoning-target="heroRace">{{ 'summoning.race_placeholder'|trans }}</span>
            </p>
            <p data-summoning-target="heroLevel" class="summoning-reveal-card__level">{{ 'heroes.level'|trans }} 1</p>

            <div data-summoning-target="heroStats" class="summoning-reveal-card__stats"></div>
        </div>

        <div class="flex gap-3 justify-center">
            <button type="button" id="inspect-summoned" class="btn btn-primary btn--sm flex-1">
                {{ 'summoning.inspect_details'|trans }}
            </button>
            <button type="button" data-action="click->summoning#reloadPage" class="btn btn-outline btn--sm flex-1">
                {{ 'summoning.summon_again'|trans }}
            </button>
        </div>
    </div>
</div>
