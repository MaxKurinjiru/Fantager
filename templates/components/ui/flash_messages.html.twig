{% set is_guest = is_guest|default(false) %}

{% for type, messages in app.flashes(['success', 'error', 'warning', 'info']) %}
    {% for message in messages %}
        <div class="alert alert-{{ type }}" role="alert" data-controller="flash">
            <span>{{ message }}</span>
            <button type="button"
                    class="btn btn-ghost btn--sm btn--no-shrink"
                    aria-label="{{ 'modal.close'|trans }}"
                    data-action="click->flash#dismiss">
                <span aria-hidden="true">✕</span>
                <span class="sr-only">{{ 'modal.close'|trans }}</span>
            </button>
        </div>
    {% endfor %}
{% endfor %}
