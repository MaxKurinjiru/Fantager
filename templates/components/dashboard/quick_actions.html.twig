{# templates/components/dashboard/quick_actions.html.twig #}
{% set actions = [] %}
{% if dashboard.next_match|default() is not empty %}
    {% set actions = actions|merge([
        { path: 'app_formation', emoji: '🛡️', label: 'dashboard.action_formation', params: { fixture_id: dashboard.next_match.id } }
    ]) %}
{% endif %}
{% set actions = actions|merge([
    { path: 'app_hq', emoji: '🌀', label: 'dashboard.action_summon', params: { facility: 'summoning_chamber' } },
    { path: 'app_hq', emoji: '🏰', label: 'dashboard.action_hq', params: {} }
]) %}

<div class="db-quick-actions">
    <h3 class="db-quick-actions__title">
        <span>⚡</span> {{ 'dashboard.quick_actions'|trans }}
    </h3>
    <div class="db-quick-actions__grid">
        {% for action in actions %}
            <a href="{{ path(action.path, action.params) }}" class="db-quick-action">
                <span class="db-quick-action__emoji">{{ action.emoji }}</span>
                <span class="db-quick-action__label">{{ action.label|trans }}</span>
            </a>
        {% endfor %}
    </div>
</div>
