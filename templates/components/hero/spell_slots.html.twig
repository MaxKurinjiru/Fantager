{# templates/components/hero/spell_slots.html.twig #}
<div class="hero-panel space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="hero-panel__title hero-panel__title--tight">{{ 'heroes.spell_slots'|trans }}</h2>
            <p class="hero-panel__desc">{{ 'heroes.spell_slots_limit'|trans({'%limit%': hero.magicCapacity}) }}</p>
        </div>
        <a href="{{ path('app_heroes_detail', { id: hero.id, tab: 'spells' }) }}" class="btn btn-outline btn--sm p-1.5" title="{{ 'heroes.spells'|trans }}" aria-label="{{ 'heroes.spells'|trans }}">
            📖
        </a>
    </div>

    <div class="space-y-3">
        {# Filter equipped spells #}
        {% set equipped_spells = [] %}
        {% for hs in hero.heroSpells %}
            {% if hs.isEquipped %}
                {% set equipped_spells = equipped_spells|merge([hs]) %}
            {% endif %}
        {% endfor %}

        {% if hero.magicCapacity > 0 %}
            {% for i in 1..hero.magicCapacity %}
                {% set matching_hs = null %}
                {% for hs in equipped_spells %}
                    {% if hs.slotNumber == i %}
                        {% set matching_hs = hs %}
                    {% endif %}
                {% endfor %}

                {% if matching_hs %}
                    <div class="hero-spell-row hero-spell-row--filled">
                        <div class="flex items-center gap-2.5">
                            <span class="text-2xl">✨</span>
                            <div>
                                <h4 class="hero-spell-row__name">{{ matching_hs.spell.name }}</h4>
                                <p class="hero-spell-row__meta">Tier {{ matching_hs.spell.tier }} &bull; {{ ('school.' ~ matching_hs.spell.school.value)|trans }}</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-bold text-purple-400 bg-purple-950/40 px-2 py-0.5 rounded border border-purple-900/40">{{ 'heroes.equipped'|trans }}</span>
                    </div>
                {% else %}
                    <div class="hero-spell-row hero-spell-row--empty">
                        <div class="flex items-center gap-2.5">
                            <span class="hero-spell-row__empty-icon">🔮</span>
                            <span class="hero-spell-row__empty-label">{{ 'spells.slot_empty'|trans({'%slot%': i}) }}</span>
                        </div>
                        <a href="{{ path('app_heroes_detail', { id: hero.id, tab: 'spells' }) }}" class="inline-link">{{ 'heroes.equip'|trans }}</a>
                    </div>
                {% endif %}
            {% endfor %}
        {% else %}
            <div class="hero-spell-locked">
                <span class="text-2xl mb-1.5 block">🔒</span>
                <h4 class="hero-spell-row__name">{{ 'heroes.no_slots_unlocked'|trans }}</h4>
                <p class="hero-panel__desc mt-1">{{ 'heroes.no_slots_desc'|trans }}</p>
            </div>
        {% endif %}
    </div>
</div>
