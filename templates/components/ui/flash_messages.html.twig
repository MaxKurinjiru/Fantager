{% set is_guest = is_guest|default(false) %}

{% for type, messages in app.flashes(['success', 'error', 'warning', 'info']) %}
    {% for message in messages %}
        {% if not is_guest %}
            <div class="mb-6 rounded-lg px-4 py-3 text-sm flex items-center justify-between border
                {% if type == 'success' %}bg-green-950/40 text-green-300 border-green-900/50
                {% elseif type == 'error' %}bg-red-950/40 text-red-300 border-red-900/50
                {% elseif type == 'warning' %}bg-yellow-950/40 text-yellow-300 border-yellow-900/50
                {% else %}bg-blue-950/40 text-blue-300 border-blue-900/50{% endif %}">
                <span>{{ message }}</span>
                <button onclick="this.parentElement.remove()" class="text-xs hover:text-white opacity-50 hover:opacity-100 ml-4 font-bold">✕</button>
            </div>
        {% else %}
            <div class="mb-4 rounded px-4 py-3 text-sm
                {% if type == 'success' %}bg-green-900 text-green-200 border border-green-700
                {% elseif type == 'error' %}bg-red-900 text-red-200 border border-red-700
                {% elseif type == 'warning' %}bg-yellow-900 text-yellow-200 border border-yellow-700
                {% else %}bg-blue-900 text-blue-200 border border-blue-700{% endif %}">
                {{ message }}
            </div>
        {% endif %}
    {% endfor %}
{% endfor %}
