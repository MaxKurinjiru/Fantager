{# templates/components/formation/pitch_grid.html.twig #}
<div class="bg-gradient-to-b from-gray-955 to-gray-900/80 border border-gray-850 p-6 rounded-3xl relative overflow-hidden flex flex-col gap-6 shadow-inner">
    {# Grid midfield line #}
    <div class="absolute inset-x-0 top-1/2 h-0.5 bg-gray-800/40 -translate-y-1/2"></div>
    
    {# BACK LINE ROW (3 Slots) #}
    <div class="space-y-2 relative z-10">
        <span class="block text-[9px] font-extrabold text-gray-650 uppercase tracking-wide text-center">{{ 'formation.back_line'|trans }}</span>
        <div class="grid grid-cols-3 gap-4">
            {% set back_slots = [
                {pos: 'back_1'},
                {pos: 'back_2'},
                {pos: 'back_3'}
            ] %}
            
            {% for slot in back_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                {% include 'components/formation/pitch_slot.html.twig' with {
                    slot: slot,
                    hero: hero,
                    default_emoji: '🛡️',
                    title_class: 'text-gray-550',
                    heroes: heroes
                } %}
            {% endfor %}
        </div>
    </div>

    {# FRONT LINE ROW (3 Slots) #}
    <div class="space-y-2 relative z-10">
        <span class="block text-[9px] font-extrabold text-gray-655 uppercase tracking-wide text-center">{{ 'formation.front_line'|trans }}</span>
        <div class="grid grid-cols-3 gap-4">
            {% set front_slots = [
                {pos: 'front_1'},
                {pos: 'front_2'},
                {pos: 'front_3'}
            ] %}
            
            {% for slot in front_slots %}
                {% set hero = current_slots[slot.pos] ?? null %}
                {% include 'components/formation/pitch_slot.html.twig' with {
                    slot: slot,
                    hero: hero,
                    default_emoji: '⚔️',
                    title_class: 'text-gray-555',
                    heroes: heroes
                } %}
            {% endfor %}
        </div>
    </div>
</div>
