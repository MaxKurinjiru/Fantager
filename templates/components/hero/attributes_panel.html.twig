{# templates/components/hero/attributes_panel.html.twig #}
<div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 backdrop-blur-md shadow-lg space-y-6">
    <div>
        <h2 class="text-xl font-bold text-white mb-1">Primary Attributes</h2>
        <p class="text-xs text-gray-500">Base attributes determine combat efficiency.</p>
    </div>

    <div class="space-y-4">
        {% set attr_labels = {
            'str': 'Strength',
            'dex': 'Dexterity',
            'kon': 'Constitution',
            'spd': 'Speed',
            'int': 'Intelligence',
            'wil': 'Willpower',
            'cha': 'Charisma',
            'lck': 'Luck'
        } %}

        {% for attr_key, attr_name in attr_labels %}
            {% set val = attribute(hero, attr_key == 'int' ? 'intel' : attr_key) %}
            {% set bonus = statBonuses[attr_key] ?? 0 %}
            {% include 'components/hero/attribute_bar.html.twig' with {
                label: attr_name,
                val: val,
                bonus: bonus,
                max_val: 20
            } %}
        {% endfor %}
    </div>
</div>
