{% extends 'layouts/public.html.twig' %}

{% block title %}{{ 'auth.verify_email_title'|trans }} — Fantager{% endblock %}

{% block guest_body %}
<div class="max-w-md mx-auto mt-8 text-center">
    <div class="text-5xl mb-4">📬</div>
    <h1 class="text-2xl font-bold text-brand-400 mb-3">{{ 'auth.verify_email_title'|trans }}</h1>
    <p class="text-text-secondary mb-3">{{ 'auth.verify_email_body'|trans }}</p>
    <p class="text-sm text-text-muted mb-8 italic">{{ 'auth.verify_email_delay_hint'|trans }}</p>

    <div class="text-sm text-text-muted">
        <p class="mb-3">{{ 'auth.verify_email_no_email'|trans }}</p>
        <form method="POST" action="{{ path('app_register_resend') }}" class="flex gap-2 justify-center">
            <input type="hidden" name="_token" value="{{ csrf_token('register_resend') }}">
            <label for="resend_email" class="sr-only">{{ 'auth.email'|trans }}</label>
            <input type="email" id="resend_email" name="email" required placeholder="{{ 'auth.email'|trans }}"
                   autocomplete="email"
                   class="form-input">
            <button type="submit" class="btn btn-outline btn--sm">
                {{ 'auth.verify_email_resend'|trans }}
            </button>
        </form>
    </div>
</div>
{% endblock %}
