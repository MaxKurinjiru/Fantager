{# templates/components/notifications/read_notification_modal.html.twig #}
<div id="read-notification-modal" data-controller="modal" data-notifications-target="readModal" data-modal-event-name-value="modal:open-read-notification">
    <div data-modal-target="dialog"
         class="hidden modal-overlay"
         data-action="click->modal#closeBackdrop">

        <div class="modal-box modal-box--md p-8"
             role="dialog"
             aria-modal="true"
             aria-labelledby="notification-read-title">

            <button type="button"
                    data-action="click->modal#close"
                    class="modal-close"
                    aria-label="{{ 'modal.close'|trans }}">
                <span aria-hidden="true" class="text-xl leading-none">✕</span>
                <span class="sr-only">{{ 'modal.close'|trans }}</span>
            </button>

            <div class="modal-header">
                <h2 id="notification-read-title" data-notifications-target="readTitle" class="modal-header__title"></h2>
                <div class="message-meta">
                    <span data-notifications-target="readType" class="notification-type-badge"></span>
                    <span class="message-meta__separator">•</span>
                    <time data-notifications-target="readDate"></time>
                </div>
            </div>

            <div class="modal-body">
                <div class="message-content-box" data-notifications-target="readBody"></div>
            </div>
        </div>
    </div>
</div>
