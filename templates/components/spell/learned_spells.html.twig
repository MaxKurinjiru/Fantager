{# templates/components/spell/learned_spells.html.twig #}
<div id="learned-spells-tab" class="subtab-content space-y-4">
    {% if selected_hero and selected_hero.heroSpells|length > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% for hs in selected_hero.heroSpells %}
                <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-4 flex flex-col justify-between backdrop-blur-md shadow-md min-h-[140px]">
                    <div class="space-y-2.5">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-2">
                                <span class="text-2xl">✨</span>
                                <div>
                                    <h3 class="font-bold text-white text-sm leading-tight">{{ hs.spell.name }}</h3>
                                    <span class="text-[9px] font-bold uppercase tracking-wider text-purple-400">
                                        Tier {{ hs.spell.tier }} &bull; {{ ('school.' ~ hs.spell.school.value)|trans }}
                                    </span>
                                </div>
                            </div>
                        </div>
                        <p class="text-[10px] text-gray-400">{{ 'spells.mana_cooldown'|trans({'%mana%': hs.spell.manaCost, '%cooldown%': hs.spell.cooldown})|raw }}</p>
                    </div>

                    <div class="border-t border-gray-850 mt-3 pt-3 flex items-center justify-between gap-4">
                        <div class="text-[9px] font-bold text-gray-500">
                            {% if hs.isEquipped %}
                                {{ 'inventory.equipped'|trans }} (Slot {{ hs.slotNumber }})
                            {% else %}
                                <span class="text-emerald-500">{{ 'spells.known'|trans }}</span>
                            {% endif %}
                        </div>

                        {% if not hs.isEquipped and selected_hero.magicCapacity > 0 %}
                            {# Find first empty slot #}
                            {% set first_empty = 0 %}
                            {% set break = false %}
                            {% for i in 1..selected_hero.magicCapacity %}
                                {% if not break and not attribute(equipped, i) is defined %}
                                    {% set first_empty = i %}
                                    {% set break = true %}
                                {% endif %}
                            {% endfor %}

                            {% if first_empty > 0 %}
                                <button type="button" data-action="click->spellbook#equip" data-hero-spell-id="{{ hs.id }}" data-slot="{{ first_empty }}"
                                        class="btn btn-primary btn--sm px-3 py-1 text-[9px] font-bold uppercase tracking-wider">
                                    {{ 'spells.equip_slot_num'|trans({'%slot%': first_empty}) }}
                                </button>
                            {% else %}
                                <span class="text-[9px] font-bold text-red-400">{{ 'spells.slots_full'|trans }}</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-12 select-none border border-gray-850 border-dashed rounded-xl opacity-60 bg-gray-900/10">
            <span class="text-4xl block mb-2">📭</span>
            <h4 class="text-xs font-bold text-gray-455">{{ 'spells.no_spells'|trans }}</h4>
            <p class="text-[10px] text-gray-550 mt-1">{{ 'spells.no_spells_desc'|trans }}</p>
        </div>
    {% endif %}
</div>
