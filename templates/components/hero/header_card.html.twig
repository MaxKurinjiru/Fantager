{# templates/components/hero/header_card.html.twig #}
<div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 md:p-8 backdrop-blur-md relative overflow-hidden">
    {# Subtle glowing background orb #}
    <div class="absolute -right-16 -top-16 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-center md:items-start relative z-10">
        {# Race Avatar Box #}
        {% include 'components/hero/avatar.html.twig' with { race: hero.race, style: 'box', size_class: 'w-16 h-16 sm:w-20 sm:h-20 text-3xl sm:text-4xl' } %}

        {# Main Info #}
        <div class="flex-1 w-full text-center md:text-left space-y-4">
            <div class="flex flex-col sm:flex-row items-center gap-3 justify-center md:justify-start">
                {# Rename Container #}
                <div class="flex items-center gap-2 group">
                    <h1 data-hero-rename-target="nameDisplay" class="text-3xl font-extrabold tracking-tight text-white">
                        {{ hero.name }}
                    </h1>
                    <label for="hero-rename-input" class="sr-only">{{ 'heroes.rename_title'|trans }}</label>
                    <input type="text" id="hero-rename-input" data-hero-rename-target="nameInput" data-action="keydown.enter->hero-rename#save keydown.esc->hero-rename#cancel"
                           class="form-input hidden text-2xl font-semibold">
                    
                    <button type="button" data-hero-rename-target="editBtn" data-action="click->hero-rename#edit" 
                            class="opacity-0 group-hover:opacity-60 hover:!opacity-100 text-sm p-1 text-gray-400 hover:text-emerald-400 transition-opacity" 
                            title="{{ 'heroes.rename_title'|trans }}">
                        ✏️
                    </button>
                    
                    <div data-hero-rename-target="actions" class="hidden flex gap-1.5">
                        <button type="button" data-action="click->hero-rename#save" class="btn btn-primary btn--sm">{{ 'heroes.save'|trans }}</button>
                        <button type="button" data-action="click->hero-rename#cancel" class="btn btn-outline btn--sm">{{ 'heroes.cancel'|trans }}</button>
                    </div>
                </div>

                {# Status Badge #}
                {% include 'components/hero/status_badge.html.twig' with { status: hero.status, rounded_full: true } %}
            </div>

            <div class="flex flex-wrap items-center justify-center md:justify-start gap-x-6 gap-y-2 text-sm text-gray-400">
                <span class="flex items-center gap-1.5">
                    <span class="text-base">🧬</span> {{ 'heroes.race'|trans }}: <strong class="text-white capitalize">{{ ('heroes.race_' ~ hero.race.value)|trans }}</strong>
                </span>
                <span class="h-4 w-px bg-gray-800 hidden sm:block"></span>
                <span class="flex items-center gap-1.5">
                    <span class="text-base">{{ hero_age_phase_icon(hero) }}</span> {{ 'heroes.age'|trans }}: <strong class="text-white">{{ hero.age }} {{ 'heroes.years'|trans }}</strong>
                    <span class="text-[10px] font-bold bg-gray-950 px-2 py-0.5 rounded border border-gray-800 text-gray-500 uppercase tracking-wide">
                        {{ ('heroes.age_phase.' ~ hero_age_phase(hero)|lower)|trans }}
                    </span>
                </span>
                <span class="h-4 w-px bg-gray-800 hidden sm:block"></span>
                <span class="flex items-center gap-1.5">
                    <span class="text-base">🔥</span> {{ 'heroes.level'|trans }}: <strong class="text-white">{{ hero.level }}</strong>
                </span>
            </div>

            {# XP Bar #}
            <div class="space-y-1.5 max-w-md mx-auto md:mx-0">
                <div class="flex justify-between text-xs font-semibold text-gray-400">
                    <span>{{ 'heroes.xp'|trans }}</span>
                    {% set next_level_xp = 1000 * hero.level %} {# Simple illustrative formula #}
                    <span>{{ hero.xp }} / {{ next_level_xp }} XP</span>
                </div>
                {% set xp_pct = min(100, (hero.xp / next_level_xp) * 100) %}
                {% include 'components/ui/progress_bar.html.twig' with {
                    percentage: xp_pct,
                    container_class: 'w-full bg-gray-950 rounded-full h-2.5 border border-gray-800 p-0.5 shadow-inner',
                    progress_class: 'bg-gradient-to-r from-emerald-500 to-teal-400 h-1.5 rounded-full shadow-lg shadow-emerald-500/20'
                } %}
            </div>
        </div>
    </div>
</div>
