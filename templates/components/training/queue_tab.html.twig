{# templates/components/training/queue_tab.html.twig #}
<div id="queue-tab" class="tab-content hidden space-y-6">
    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 backdrop-blur-md shadow-lg space-y-4">
        <h2 class="text-xl font-bold text-white">{{ 'training.queue_title'|trans }}</h2>
        
        <div class="space-y-4">
            {% for job in queue %}
                {% set refund_gold = (job.goldCost * 0.5)|round(0, 'floor') %}
                
                <div class="bg-gray-955 border border-gray-850 p-4 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <span class="text-3xl select-none">
                            {% if job.trainingType.value == 'attribute' %}💪
                            {% elseif job.trainingType.value == 'magic' %}🔮
                            {% else %}🛌{% endif %}
                        </span>
                        
                        <div class="space-y-1">
                            <h4 class="text-sm font-bold text-white">{{ job.hero.name }}</h4>
                            <div class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider flex flex-wrap items-center gap-x-2">
                                <span>{{ 'training.type'|trans }}: {{ ('training.type_' ~ job.trainingType.value)|trans }}</span>
                                {% if job.targetAttribute %}
                                    <span>&bull;</span>
                                    <span>{{ 'training.attr_label'|trans }}: {{ ('training.attr.' ~ job.targetAttribute)|trans }}</span>
                                {% endif %}
                                {% if job.trainer %}
                                    <span>&bull;</span>
                                    <span class="text-emerald-450">{{ 'training.trainer'|trans }}: {{ job.trainer.name }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Execution and Actions #}
                    <div class="flex items-center justify-between sm:justify-end gap-6 w-full sm:w-auto border-t border-gray-900 sm:border-none pt-3 sm:pt-0">
                        <div>
                            <span class="block text-[9px] font-bold text-gray-550 uppercase tracking-wide">{{ 'training.time_remaining'|trans }}</span>
                            <span data-countdown-target="{{ job.executeAt|date('Y-m-d H:i:s') }}" class="text-xs font-extrabold text-emerald-455 tracking-wider">
                                --h --m --s
                            </span>
                        </div>
                        
                        <button data-action="click->training#cancelTraining" data-job-id="{{ job.id }}" data-refund="{{ refund_gold }}"
                                class="btn btn-outline btn--sm px-3 py-1.5 border-red-955/40 hover:border-red-500/30 text-red-400 hover:text-red-350 text-[10px] uppercase tracking-wider font-bold">
                            {{ 'training.cancel_btn'|trans }}
                        </button>
                    </div>
                </div>
            {% else %}
                <div class="text-center py-12 select-none border border-gray-850 border-dashed rounded-xl opacity-60">
                    <span class="text-4xl block mb-2">📭</span>
                    <h4 class="text-sm font-bold text-gray-300">{{ 'training.no_jobs'|trans }}</h4>
                    <p class="text-xs text-gray-550 mt-1">{{ 'training.no_jobs_desc'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
