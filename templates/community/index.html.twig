{% extends 'layouts/game.html.twig' %}

{% block title %}{{ 'nav.community'|trans }} — Fantager{% endblock %}

{% block body %}
<div class="space-y-8 max-w-7xl mx-auto" data-controller="community"
     data-community-active-team-id-value="{{ team.id }}"
     data-community-kingdom-id-value="{{ kingdom.id }}"
     data-community-empty-threads-msg-value="{{ 'community.no_threads'|trans }}"
     data-community-empty-inbox-msg-value="{{ 'community.empty_inbox'|trans }}"
     data-community-empty-sent-msg-value="{{ 'community.empty_sent'|trans }}"
     data-community-translations-value="{{ {
         'error_load_threads': 'community.error_load_threads'|trans,
         'warning_fill_fields': 'community.warning_fill_fields'|trans,
         'text_sending': 'community.text_sending'|trans,
         'error_create_thread': 'community.error_create_thread'|trans,
         'success_create_thread': 'community.success_create_thread'|trans,
         'btn_unlock': 'community.btn_unlock'|trans,
         'btn_lock': 'community.btn_lock'|trans,
         'error_load_thread_detail': 'community.error_load_thread_detail'|trans,
         'error_send_reply': 'community.error_send_reply'|trans,
         'error_refresh_posts': 'community.error_refresh_posts'|trans,
         'error_toggle_lock': 'community.error_toggle_lock'|trans,
         'error_load_mail': 'community.error_load_mail'|trans,
         'warning_compose_fields': 'community.warning_compose_fields'|trans,
         'error_send_msg': 'community.error_send_msg'|trans,
         'success_send_msg': 'community.success_send_msg'|trans,
         'error_read_msg': 'community.error_read_msg'|trans,
         'text_deleting': 'community.text_deleting'|trans,
         'success_delete_msg': 'community.success_delete_msg'|trans,
         'error_delete_msg': 'community.error_delete_msg'|trans,
         'inbox_title': 'community.inbox_title'|trans,
         'sent_title': 'community.sent_title'|trans,
         'col_sender': 'community.col_sender'|trans,
         'col_recipient': 'community.col_recipient'|trans,
         'post_reply': 'community.post_reply'|trans,
         'back_to_threads': 'community.back_to_threads'|trans,
         'categories': {
             'general': 'community.category_general'|trans,
             'strategy': 'community.category_strategy'|trans,
             'trading': 'community.category_trading'|trans,
             'bugs': 'community.category_bugs'|trans
         }
     }|json_encode|e('html_attr') }}"
>
    {# --- Header Section --- #}
    {% include 'components/ui/page_header.html.twig' with {
        title: 'community.title',
        subtitle: 'community.subtitle'
    } %}

    {# --- Alert Box --- #}
    {% include 'components/ui/alert_box.html.twig' with {
        target: 'community',
        message_target: 'alertMessage',
        close_action: 'community#hideAlert'
    } %}

    {# --- Multi-Tab Navigation --- #}
    <div class="flex border-b border-gray-850 gap-2 overflow-x-auto pb-px" data-controller="tab">
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch click->community#onTabSwitch"
                data-tab="forum-tab"
                class="tab-btn tab-btn--active">
            💬 {{ 'community.tab_forum'|trans }}
        </button>
        <button type="button"
                data-tab-target="btn"
                data-action="click->tab#switch click->community#onTabSwitch"
                data-tab="mail-tab"
                class="tab-btn">
            ✉️ {{ 'community.tab_mail'|trans }}
        </button>
    </div>

    {# --- FORUM TAB CONTENT --- #}
    <div id="forum-tab" class="tab-content">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            {# Forum Left Sidebar (Categories) #}
            <div class="lg:col-span-1 space-y-4">
                <div class="community-sidebar">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider px-2 mb-3">Kategorie</h3>
                    <button type="button" 
                            data-action="click->community#filterCategory" 
                            data-category="all" 
                            class="community-tab-btn community-tab-btn--active"
                            data-community-target="categoryBtn">
                        📁 Všechny diskuse
                    </button>
                    {% for cat in categories %}
                        <button type="button" 
                                data-action="click->community#filterCategory" 
                                data-category="{{ cat }}" 
                                class="community-tab-btn"
                                data-community-target="categoryBtn">
                            💬 {{ ('community.category_' ~ cat)|trans }}
                        </button>
                    {% endfor %}
                </div>

                <button type="button" 
                        data-action="click->community#openNewThreadModal" 
                        class="w-full btn btn-primary flex items-center justify-center gap-2 py-3 rounded-xl font-bold text-sm">
                    ➕ {{ 'community.new_thread'|trans }}
                </button>
            </div>

            {# Forum Main Pane #}
            <div class="lg:col-span-3 space-y-6">
                {# Threads List #}
                <div data-community-target="threadsContainer" class="community-panel space-y-4">
                    <h2 class="text-lg font-bold text-white mb-2">Témata diskuse</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-xs border-collapse">
                            <thead>
                                <tr class="border-b border-gray-800 text-gray-550 uppercase tracking-wider text-[10px] font-bold">
                                    <th class="pb-3">{{ 'community.col_title'|trans }}</th>
                                    <th class="pb-3">{{ 'community.col_author'|trans }}</th>
                                    <th class="pb-3 text-center">{{ 'community.col_replies'|trans }}</th>
                                    <th class="pb-3 text-right">Založeno</th>
                                </tr>
                            </thead>
                            <tbody data-community-target="threadsTableBody" class="divide-y divide-gray-850">
                                {% for thread in threads %}
                                    <tr class="community-row" data-action="click->community#viewThread" data-thread-id="{{ thread.id }}">
                                        <td class="py-4 font-bold text-white">
                                            <div class="flex items-center gap-2">
                                                {% if thread.isLocked %}
                                                    <span class="text-gray-500" title="Uzamčeno">🔒</span>
                                                {% endif %}
                                                <span>{{ thread.title }}</span>
                                            </div>
                                            <span class="text-[9px] uppercase font-bold text-emerald-400 tracking-wider bg-emerald-950/20 border border-emerald-900/40 px-2 py-0.5 rounded-full mt-1 inline-block">
                                                {{ ('community.category_' ~ thread.category)|trans }}
                                            </span>
                                        </td>
                                        <td class="py-4 text-gray-400">
                                            <div class="flex items-center gap-2">
                                                <span class="w-2.5 h-2.5 rounded-full border border-gray-700" style="background-color: {{ thread.authorTeam.colors.primary ?? '#10b981' }}; border-color: {{ thread.authorTeam.colors.secondary ?? '#0f1720' }};"></span>
                                                <span>{{ thread.authorTeam.name }}</span>
                                            </div>
                                        </td>
                                        <td class="py-4 text-center text-gray-300 font-semibold">{{ thread.posts|length }}</td>
                                        <td class="py-4 text-right text-gray-550">{{ thread.createdAt|date('d. m. Y H:i') }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="py-12 text-center text-gray-550 select-none">
                                            {{ 'community.no_threads'|trans }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# Selected Thread Detail Container (Hidden initially) #}
                <div data-community-target="threadDetailContainer" class="hidden community-panel space-y-6">
                    <div class="flex items-start justify-between border-b border-gray-800 pb-4">
                        <div>
                            <button type="button" data-action="click->community#backToThreads" class="text-xs text-emerald-400 hover:text-emerald-300 flex items-center gap-1 font-bold mb-2">
                                ⬅️ Zpět na seznam témat
                            </button>
                            <h2 data-community-target="threadTitle" class="text-xl font-extrabold text-white leading-tight">-- Název Vlákna --</h2>
                            <span data-community-target="threadCategory" class="text-[9px] uppercase font-bold text-emerald-400 tracking-wider bg-emerald-950/20 border border-emerald-900/40 px-2 py-0.5 rounded-full mt-2 inline-block">-- Kategorie --</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span data-community-target="threadLockBadge" class="hidden bg-red-950/40 border border-red-900/50 text-red-400 text-[9px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">🔒 Uzamčeno</span>
                            <button type="button" 
                                    data-community-target="lockBtn" 
                                    data-action="click->community#toggleLock"
                                    class="hidden btn btn-outline btn--sm text-[10px] font-bold tracking-wider py-1.5 px-3">
                                Lock
                            </button>
                        </div>
                    </div>

                    {# Posts Timeline #}
                    <div data-community-target="postsTimeline" class="space-y-4 max-h-[500px] overflow-y-auto pr-2">
                        <!-- Reply posts will be injected here -->
                    </div>

                    {# Reply Form #}
                    <div data-community-target="replyFormContainer" class="border-t border-gray-800 pt-4 space-y-3">
                        <label for="reply-body" class="form-label text-xs">Přidat odpověď</label>
                        <textarea id="reply-body" 
                                  data-community-target="replyInput" 
                                  class="form-input text-xs h-24 resize-none" 
                                  placeholder="{{ 'community.reply_placeholder'|trans }}"
                                  required></textarea>
                        <button type="button" 
                                data-community-target="submitReplyBtn"
                                data-action="click->community#submitReply" 
                                class="btn btn-primary font-bold text-xs py-2 px-5">
                            {{ 'community.post_reply'|trans }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- MAIL TAB CONTENT --- #}
    <div id="mail-tab" class="tab-content hidden">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            {# Mail Sidebar (Folder Controls) #}
            <div class="lg:col-span-1 space-y-4">
                <div class="community-sidebar">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider px-2 mb-3">Pošta</h3>
                    <button type="button" 
                            data-action="click->community#switchFolder" 
                            data-folder="inbox" 
                            class="community-tab-btn community-tab-btn--active"
                            data-community-target="folderBtn">
                        📥 Doručené
                    </button>
                    <button type="button" 
                            data-action="click->community#switchFolder" 
                            data-folder="sent" 
                            class="community-tab-btn"
                            data-community-target="folderBtn">
                        📤 Odeslané
                    </button>
                </div>

                <button type="button" 
                        data-action="click->community#openComposeModal" 
                        class="w-full btn btn-primary flex items-center justify-center gap-2 py-3 rounded-xl font-bold text-sm">
                    ✍️ {{ 'community.compose'|trans }}
                </button>
            </div>

            {# Mail Main Pane #}
            <div class="lg:col-span-3 space-y-6">
                <div class="community-panel space-y-4">
                    <h2 data-community-target="mailFolderTitle" class="text-lg font-bold text-white mb-2">Doručené zprávy</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-xs border-collapse">
                            <thead>
                                <tr class="border-b border-gray-800 text-gray-550 uppercase tracking-wider text-[10px] font-bold">
                                    <th class="pb-3 w-12 text-center">Stav</th>
                                    <th class="pb-3">{{ 'community.subject'|trans }}</th>
                                    <th data-community-target="mailSenderColTitle" class="pb-3">Odesílatel</th>
                                    <th class="pb-3 text-right">Odesláno</th>
                                </tr>
                            </thead>
                            <tbody data-community-target="mailTableBody" class="divide-y divide-gray-850">
                                {% for msg in inbox %}
                                    <tr class="community-row" data-action="click->community#readMessage" data-message-id="{{ msg.id }}">
                                        <td class="py-4 text-center text-lg">
                                            <span data-community-unread-indicator-id="{{ msg.id }}">
                                                {{ msg.readAt is null ? '✉️' : '📖' }}
                                            </span>
                                        </td>
                                        <td class="py-4 font-bold text-white">
                                            <span>{{ msg.subject }}</span>
                                        </td>
                                        <td class="py-4 text-gray-400">
                                            <div class="flex items-center gap-2">
                                                <span class="w-2.5 h-2.5 rounded-full border border-gray-700" style="background-color: {{ msg.senderTeam.colors.primary ?? '#10b981' }}; border-color: {{ msg.senderTeam.colors.secondary ?? '#0f1720' }};"></span>
                                                <span>{{ msg.senderTeam.name }}</span>
                                            </div>
                                        </td>
                                        <td class="py-4 text-right text-gray-550">{{ msg.sentAt|date('d. m. Y H:i') }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="py-12 text-center text-gray-550 select-none">
                                            {{ 'community.empty_inbox'|trans }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# =============================================================================
   MODAL WINDOWS
   ============================================================================= #}

{# Modal: Create New Thread #}
<div id="new-thread-modal" class="modal-overlay hidden" data-controller="modal" data-community-target="newThreadModal" data-modal-event-name-value="modal:open-new-thread">
    <div class="modal-box max-w-lg" data-modal-target="dialog" role="dialog" aria-modal="true" aria-labelledby="modal-title-new-thread">
        <button type="button" data-action="click->modal#close" class="modal-close" aria-label="{{ 'modal.close'|trans }}">
            <span aria-hidden="true" class="text-xl leading-none">✕</span>
            <span class="sr-only">{{ 'modal.close'|trans }}</span>
        </button>

        <h2 id="modal-title-new-thread" class="text-xl font-extrabold text-white mb-6">Založit nové téma</h2>

        <div class="space-y-4">
            <div>
                <label for="thread-category" class="form-label">Kategorie</label>
                <select id="thread-category" class="form-input text-xs font-semibold" data-community-target="newThreadCategory">
                    {% for cat in categories %}
                        <option value="{{ cat }}">{{ ('community.category_' ~ cat)|trans }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label for="thread-title" class="form-label">Nadpis / Předmět</label>
                <input id="thread-title" type="text" class="form-input text-xs font-semibold" data-community-target="newThreadTitle" required>
            </div>

            <div>
                <label for="thread-body" class="form-label">Obsah příspěvku</label>
                <textarea id="thread-body" class="form-input text-xs h-36 resize-none" data-community-target="newThreadBody" required></textarea>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-8 border-t border-gray-800 pt-4">
            <button type="button" data-action="click->modal#close" class="btn btn-outline text-xs py-2 px-4">Storno</button>
            <button type="button" data-action="click->community#submitNewThread" data-community-target="submitNewThreadBtn" class="btn btn-primary text-xs py-2 px-5 font-bold">Vytvořit téma</button>
        </div>
    </div>
</div>

{# Modal: Compose Private Message #}
<div id="compose-message-modal" class="modal-overlay hidden" data-controller="modal" data-community-target="composeModal" data-modal-event-name-value="modal:open-compose">
    <div class="modal-box max-w-lg" data-modal-target="dialog" role="dialog" aria-modal="true" aria-labelledby="modal-title-compose">
        <button type="button" data-action="click->modal#close" class="modal-close" aria-label="{{ 'modal.close'|trans }}">
            <span aria-hidden="true" class="text-xl leading-none">✕</span>
            <span class="sr-only">{{ 'modal.close'|trans }}</span>
        </button>

        <h2 id="modal-title-compose" class="text-xl font-extrabold text-white mb-6">Napsat zprávu</h2>

        <div class="space-y-4">
            <div>
                <label for="message-recipient" class="form-label">Příjemce (týmy ve vašem království)</label>
                <select id="message-recipient" class="form-input text-xs font-semibold" data-community-target="composeRecipient">
                    <option value="">-- Vyberte příjemce --</option>
                    {% for other in other_teams %}
                        <option value="{{ other.id }}">{{ other.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label for="message-subject" class="form-label">Předmět</label>
                <input id="message-subject" type="text" class="form-input text-xs font-semibold" data-community-target="composeSubject" required>
            </div>

            <div>
                <label for="message-body" class="form-label">Zpráva</label>
                <textarea id="message-body" class="form-input text-xs h-36 resize-none" data-community-target="composeBody" required></textarea>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-8 border-t border-gray-800 pt-4">
            <button type="button" data-action="click->modal#close" class="btn btn-outline text-xs py-2 px-4">Storno</button>
            <button type="button" data-action="click->community#submitCompose" data-community-target="submitComposeBtn" class="btn btn-primary text-xs py-2 px-5 font-bold">Odeslat zprávu</button>
        </div>
    </div>
</div>

{# Modal: Read Private Message #}
<div id="read-message-modal" class="modal-overlay hidden" data-controller="modal" data-community-target="readMessageModal" data-modal-event-name-value="modal:open-read-message">
    <div class="modal-box max-w-lg" data-modal-target="dialog" role="dialog" aria-modal="true" aria-labelledby="modal-title-read">
        <button type="button" data-action="click->modal#close" class="modal-close" aria-label="{{ 'modal.close'|trans }}">
            <span aria-hidden="true" class="text-xl leading-none">✕</span>
            <span class="sr-only">{{ 'modal.close'|trans }}</span>
        </button>

        <div class="border-b border-gray-800 pb-4 mb-4">
            <h2 id="modal-title-read" data-community-target="readSubject" class="text-lg font-extrabold text-white leading-tight">-- Předmět --</h2>
            <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                <span data-community-target="readSenderLabel">Od:</span>
                <span class="w-2 h-2 rounded-full border border-gray-700 hidden" data-community-target="readSenderColor"></span>
                <strong data-community-target="readSenderName" class="text-white">-- Odesílatel --</strong>
                <span class="text-gray-600">&bull;</span>
                <span data-community-target="readDate">-- Datum --</span>
            </div>
        </div>

        <div class="message-content-box" data-community-target="readBody">
            <!-- Message body will be injected here -->
        </div>

        <div class="flex justify-between items-center mt-8 border-t border-gray-800 pt-4">
            <button type="button" 
                    data-action="click->community#deleteCurrentMessage" 
                    data-community-target="deleteMsgBtn"
                    class="btn btn-danger text-xs py-2 px-4 font-bold">
                🗑️ Smazat zprávu
            </button>
            <button type="button" data-action="click->modal#close" class="btn btn-outline text-xs py-2 px-4">Zavřít</button>
        </div>
    </div>
</div>

{# Forum Thread Row Template #}
<template id="template-forum-thread-row">
    <tr class="community-row">
        <td class="py-4 font-bold text-white js-title-cell">
            <div class="flex items-center gap-2">
                <span class="text-gray-550 js-lock-icon hidden" title="Uzamčeno">🔒</span>
                <span class="js-thread-title"></span>
            </div>
            <span class="text-[9px] uppercase font-bold text-emerald-400 tracking-wider bg-emerald-950/20 border border-emerald-900/40 px-2 py-0.5 rounded-full mt-1 inline-block js-thread-category"></span>
        </td>
        <td class="py-4 text-gray-400">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full border border-gray-700 js-author-color"></span>
                <span class="js-author-name"></span>
            </div>
        </td>
        <td class="py-4 text-center text-gray-300 font-semibold js-replies-count"></td>
        <td class="py-4 text-right text-gray-550 js-created-at"></td>
    </tr>
</template>

{# Forum Post Template #}
<template id="template-forum-post">
    <div class="community-post">
        <div class="community-post__header">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full border border-gray-700 js-author-color"></span>
                <strong class="text-white js-author-name"></strong>
            </div>
            <span class="js-created-at"></span>
        </div>
        <div class="community-post__body js-post-body"></div>
    </div>
</template>

{# Mail Message Row Template #}
<template id="template-mail-message-row">
    <tr class="community-row">
        <td class="py-4 text-center text-lg">
            <span class="js-unread-indicator"></span>
        </td>
        <td class="py-4 font-bold text-white">
            <span class="js-subject"></span>
        </td>
        <td class="py-4 text-gray-400">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full border border-gray-700 js-team-color"></span>
                <span class="js-team-name"></span>
            </div>
        </td>
        <td class="py-4 text-right text-gray-550 js-sent-at"></td>
    </tr>
</template>

{# Community Empty Row Template #}
<template id="template-community-empty-row">
    <tr>
        <td colspan="4" class="py-12 text-center text-gray-550 select-none js-empty-text"></td>
    </tr>
</template>

{% endblock %}
